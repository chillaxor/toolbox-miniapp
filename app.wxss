page {
  --color-life: #FF6B35;
  --color-date: #4ECDC4;
  --color-text: #45B058;
  --color-image: #9B59B6;
  --color-primary: #333333;
  --color-secondary: #666666;
  --color-hint: #999999;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-border: #E5E5E5;
  --color-danger: #E74C3C;
  --color-success: #27AE60;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
}

/* 全局重置 */
view, text, input, textarea, button, image {
  box-sizing: border-box;
}

page {
  background-color: var(--color-bg);
  color: var(--color-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 卡片通用样式 */
.card {
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 主操作按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 次要按钮 */
.btn-secondary {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  border: 2rpx solid var(--color-border);
  background-color: var(--color-card);
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.btn-secondary::after {
  border: none;
}

/* 输入框 */
.input-field {
  height: 88rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border);
  padding: 0 24rpx;
  font-size: 30rpx;
  background-color: var(--color-card);
  transition: border-color 0.2s ease;
}

.input-field:focus {
  border-color: var(--color-life);
}

/* 表单组 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--color-secondary);
  margin-bottom: 12rpx;
  display: block;
}

/* 结果区域 */
.result-box {
  background-color: #F0FFF0;
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-top: 24rpx;
}

.result-title {
  font-size: 28rpx;
  color: var(--color-hint);
  margin-bottom: 16rpx;
}

.result-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.result-detail {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-secondary);
  line-height: 1.8;
}

/* 工具页面头部导航 */
.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.tool-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tool-header-fav {
  font-size: 44rpx;
  padding: 8rpx;
}

/* 通用 flex */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 文字辅助 */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-secondary); }
.text-hint { color: var(--color-hint); }
.text-danger { color: var(--color-danger); }
.text-success { color: var(--color-success); }
.text-life { color: var(--color-life); }
.text-date { color: var(--color-date); }
.text-text { color: var(--color-text); }
.text-image { color: var(--color-image); }

.font-bold { font-weight: 700; }
.font-sm { font-size: 24rpx; }
.font-md { font-size: 28rpx; }
.font-lg { font-size: 32rpx; }
.font-xl { font-size: 36rpx; }

.mt-sm { margin-top: 12rpx; }
.mt-md { margin-top: 24rpx; }
.mt-lg { margin-top: 32rpx; }
.mb-sm { margin-bottom: 12rpx; }
.mb-md { margin-bottom: 24rpx; }
.mb-lg { margin-bottom: 32rpx; }

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: var(--color-border);
  margin: 24rpx 0;
}

/* Picker 样式 */
.picker-field {
  height: 88rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border);
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-card);
  font-size: 30rpx;
}

.picker-field .picker-arrow {
  font-size: 24rpx;
  color: var(--color-hint);
}

/* 文本域 */
.textarea-field {
  width: 100%;
  min-height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border);
  padding: 24rpx;
  font-size: 28rpx;
  background-color: var(--color-card);
  line-height: 1.6;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}
