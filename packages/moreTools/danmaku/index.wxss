.container-full {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #1a1a2e;
  overflow: hidden;
}

.tool-header-abs {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  z-index: 10;
}

.tool-header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.7);
}

.tool-header-fav {
  font-size: 36rpx;
}

.danmaku-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.danmaku-item {
  position: absolute;
  left: 100%;
  white-space: nowrap;
  animation: danmaku-fly 8s linear forwards;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
  font-weight: 700;
}

@keyframes danmaku-fly {
  from { transform: translateX(0); }
  to { transform: translateX(-200%); }
}

.input-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(0,0,0,0.6);
  gap: 16rpx;
}

.danmaku-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #fff;
}

.send-btn {
  background: #FF6B35;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  white-space: nowrap;
}
