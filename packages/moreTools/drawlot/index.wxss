.textarea-field {
  width: 100%;
  min-height: 200rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.result-items {
  margin-bottom: 24rpx;
}

.result-item-box {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FDE8E8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.ri-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.ri-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #E74C3C;
}

.btn-again {
  width: 60%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #E74C3C;
  background: #FDE8E8;
  border-radius: 40rpx;
  border: none;
  margin: 0 auto;
}
