.wheel-area {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  width: 500rpx;
  height: 500rpx;
  margin: 0 auto;
}

.wheel-canvas {
  width: 500rpx;
  height: 500rpx;
}

.wheel-pointer {
  position: absolute;
  top: 8rpx;
  font-size: 48rpx;
  color: #E74C3C;
  z-index: 10;
  left: 50%;
  transform: translateX(-50%);
}

.wheel-tap-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 500rpx;
  height: 500rpx;
  z-index: 5;
}

.options-section {
  margin-top: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-preset {
  font-size: 24rpx;
  color: #E74C3C;
}

.add-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.add-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  font-size: 26rpx;
}

.add-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #E74C3C;
  color: #fff;
  border-radius: 50%;
  font-size: 36rpx;
  font-weight: 700;
}

.option-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #FDE8E8;
  border-radius: 24rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #333;
}

.tag-remove {
  font-size: 22rpx;
  color: #E74C3C;
  padding: 0 4rpx;
}

.preset-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.preset-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.preset-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.preset-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.preset-item:last-child {
  border-bottom: none;
}

.preset-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.preset-preview {
  font-size: 22rpx;
  color: #999;
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.result-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.result-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #E74C3C;
  margin-bottom: 32rpx;
}

.btn-retry {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #E74C3C;
  color: #fff;
  text-align: center;
}