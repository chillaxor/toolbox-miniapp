/* ===== 编辑模式 ===== */

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
}

/* 文本输入 */
.text-area {
  width: 100%;
  min-height: 300rpx;
  max-height: 600rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.8;
  background: #fafafa;
}

.char-count {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-hint);
}

.clear-link {
  color: var(--color-danger);
  padding: 8rpx 16rpx;
}

/* 预设文本 */
.preset-list {
  display: flex;
  flex-direction: column;
}

.preset-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.preset-item:last-child {
  border-bottom: none;
}

.preset-item:active {
  background: #f5f5f5;
}

.preset-label {
  font-size: 28rpx;
  color: var(--color-primary);
}

.preset-arrow {
  font-size: 36rpx;
  color: var(--color-hint);
}

/* 参数设置 */
.setting-row {
  margin-bottom: 32rpx;
}

.setting-row:last-child {
  margin-bottom: 0;
}

.setting-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: var(--color-secondary);
}

.setting-value {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 600;
}

.speed-hints {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-hint);
  margin-top: -4rpx;
}

/* 镜像开关 */
.mirror-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding-top: 8rpx;
  border-top: 1rpx solid var(--color-border);
}

.mirror-label {
  font-size: 28rpx;
  color: var(--color-secondary);
  margin-right: 16rpx;
}

.mirror-desc {
  font-size: 22rpx;
  color: var(--color-hint);
  flex: 1;
}

.mirror-switch {
  width: 88rpx;
  height: 44rpx;
  border-radius: 22rpx;
  position: relative;
  transition: background 0.2s;
}

.mirror-switch.off {
  background: #ddd;
}

.mirror-switch.on {
  background: #FF6B35;
}

.mirror-knob {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  top: 3rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.mirror-switch.off .mirror-knob {
  left: 3rpx;
}

.mirror-switch.on .mirror-knob {
  left: 47rpx;
}

/* 开始按钮 */
.play-btn-wrap {
  padding: 20rpx 0 40rpx;
}

.play-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.35);
}

.play-btn.disabled {
  opacity: 0.45;
}

.play-btn:active {
  transform: scale(0.97);
}

.play-btn-icon {
  font-size: 36rpx;
  color: #fff;
  margin-right: 12rpx;
}

.play-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

/* 提示卡片 */
.tip-card {
  background: #FFF8F5;
  border: 2rpx solid #FFE5D9;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-secondary);
  line-height: 1.8;
  margin-bottom: 4rpx;
}

/* ===== 全屏播放模式 ===== */

.fullscreen-view {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #111;
  z-index: 9999;
  overflow: hidden;
}

.prompter-scroll {
  width: 100%;
  height: 100%;
}

.scroll-padding-top {
  height: 45vh;
}

.scroll-padding-bottom {
  height: 60vh;
}

.prompter-text {
  display: block;
  padding: 0 48rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 2rpx;
  word-break: break-all;
}

/* 阅读引导线 */
.guide-line {
  position: fixed;
  top: 38%;
  left: 24rpx;
  right: 24rpx;
  height: 4rpx;
  background: rgba(255, 107, 53, 0.5);
  z-index: 10;
  pointer-events: none;
}

.guide-line::before,
.guide-line::after {
  content: '';
  position: absolute;
  top: -8rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
}

.guide-line::before {
  left: -4rpx;
  border-left: 14rpx solid rgba(255, 107, 53, 0.7);
}

.guide-line::after {
  right: -4rpx;
  border-right: 14rpx solid rgba(255, 107, 53, 0.7);
}

/* 上下渐变遮罩 */
.fade-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(180deg, #111 0%, transparent 100%);
  z-index: 5;
  pointer-events: none;
}

.fade-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 250rpx;
  background: linear-gradient(0deg, #111 0%, transparent 100%);
  z-index: 5;
  pointer-events: none;
}

/* 底部控制栏 */
.control-bar {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 48rpx;
  padding: 20rpx 48rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  z-index: 20;
}

.ctrl-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.ctrl-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.ctrl-play {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 107, 53, 0.8);
  border: none;
}

.ctrl-play:active {
  background: rgba(255, 107, 53, 1);
}

.ctrl-icon {
  font-size: 36rpx;
  color: #fff;
}

.ctrl-icon-lg {
  font-size: 44rpx;
  color: #fff;
}

/* 进度条 */
.progress-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  z-index: 20;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #FFB347);
  transition: width 0.1s linear;
}
