.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
  padding: 30rpx;
}

.score-bar {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.score-value.best { color: #FFD700; }
.score-value.streak { color: #4CAF50; }

.game-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

/* 开始/结果卡片 */
.start-card, .result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.start-icon, .result-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.start-title, .result-score {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.start-desc, .result-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 40rpx;
}

.result-rank {
  font-size: 32rpx;
  color: #FFD700;
  margin-bottom: 30rpx;
}

.btn-start {
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 关卡信息 */
.round-info {
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
  margin-bottom: 30rpx;
}

/* 计算题 */
.math-question {
  font-size: 72rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 50rpx;
}

.math-options {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
}

.math-opt, .logic-opt {
  width: 200rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.opt-correct {
  background: rgba(76, 175, 80, 0.3);
  border-color: #4CAF50;
}

.opt-wrong {
  background: rgba(244, 67, 54, 0.3);
  border-color: #f44336;
}

/* 计时条 */
.timer-bar {
  width: 80%;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  margin-top: 30rpx;
  overflow: hidden;
}

.timer-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.1s linear;
}

/* 记忆关卡 */
.memory-hint {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.memory-cells {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  width: 500rpx;
}

.memory-cell {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.cell-highlight {
  background: #E91E63 !important;
  border-color: #E91E63 !important;
}

.cell-clicked {
  background: #2196F3 !important;
  border-color: #2196F3 !important;
}

/* 反应关卡 */
.reaction-circle {
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0;
}

.reaction-ready {
  background: rgba(244, 67, 54, 0.5);
}

.reaction-go {
  background: rgba(76, 175, 80, 0.7);
}

.reaction-text {
  color: #fff;
  font-size: 28rpx;
}

.reaction-result {
  color: #4CAF50;
  font-size: 36rpx;
  font-weight: bold;
}

/* 逻辑题 */
.logic-question {
  font-size: 32rpx;
  color: #fff;
  line-height: 1.6;
  margin-bottom: 40rpx;
  padding: 0 40rpx;
  text-align: center;
}

.logic-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 80%;
}

.logic-opt {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
}