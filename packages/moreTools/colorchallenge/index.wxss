.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  align-items: center;
}

.stat-item {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #E74C3C;
}

.hint-text {
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 24rpx auto;
  gap: 8rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.grid-2 { width: 400rpx; }
.grid-3 { width: 480rpx; }
.grid-4 { width: 560rpx; }
.grid-5 { width: 600rpx; }
.grid-6 { width: 620rpx; }
.grid-7 { width: 630rpx; }
.grid-8 { width: 640rpx; }

.color-cell {
  border-radius: 8rpx;
  transition: transform 0.1s;
}

.color-cell:active {
  transform: scale(0.95);
}

.grid-2 .color-cell { width: 192rpx; height: 192rpx; }
.grid-3 .color-cell { width: 152rpx; height: 152rpx; }
.grid-4 .color-cell { width: 136rpx; height: 136rpx; }
.grid-5 .color-cell { width: 112rpx; height: 112rpx; }
.grid-6 .color-cell { width: 96rpx; height: 96rpx; }
.grid-7 .color-cell { width: 84rpx; height: 84rpx; }
.grid-8 .color-cell { width: 74rpx; height: 74rpx; }

.cell-wrong {
  animation: shake 0.3s;
  border: 4rpx solid #E74C3C !important;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.result-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-level {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #E74C3C;
  margin-bottom: 12rpx;
}

.result-score {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.result-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.btn-retry {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #E74C3C;
  color: #fff;
  border: none;
}