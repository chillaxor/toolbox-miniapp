.tip-bar {
  background: #FFF8F0;
  border: 1rpx solid #FFD8A8;
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #E67E22;
  line-height: 1.5;
}

.size-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  padding: 8rpx 0 16rpx;
}

.size-btn {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #666;
}

.size-active {
  background: #FDE8E8;
  color: #E74C3C;
}

.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #E74C3C;
}

/* 棋盘：用 grid 布局，最可靠 */
.puzzle-board {
  display: grid;
  gap: 8rpx;
  margin: 0 auto 20rpx;
  background: #EDEDED;
  border-radius: 16rpx;
  padding: 10rpx;
}

.puzzle-3 {
  width: 520rpx;
  grid-template-columns: repeat(3, 1fr);
}

.puzzle-4 {
  width: 540rpx;
  grid-template-columns: repeat(4, 1fr);
}

.puzzle-5 {
  width: 560rpx;
  grid-template-columns: repeat(5, 1fr);
}

.tile {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.10);
  transition: background 0.15s;
}

/* 可移动格子：橙色边框+背景提示 */
.tile-movable {
  background: #FFF3E0;
  border: 3rpx solid #FF9800;
}

.tile-movable:active {
  transform: scale(0.92);
  background: #FFE0B2;
}

.tile-empty {
  background: transparent !important;
  box-shadow: none;
  border: none !important;
}

.tile-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.puzzle-4 .tile-num {
  font-size: 34rpx;
}

.puzzle-5 .tile-num {
  font-size: 28rpx;
}

/* 目标提示行（已就位的数字显示绿色）*/
.target-hint {
  margin: 0 auto 20rpx;
  text-align: center;
}

.target-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.target-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
}

.target-num {
  font-size: 22rpx;
  color: #bbb;
  width: 36rpx;
  text-align: center;
}

.target-correct {
  color: #27AE60;
  font-weight: 700;
}

.btn-restart {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #E74C3C;
  color: #fff;
  text-align: center;
  margin-top: 8rpx;
}

.btn-restart:active {
  opacity: 0.85;
}

.complete-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.complete-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.complete-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.complete-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.complete-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.btn-primary {
  background: #E74C3C;
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}