.best-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.best-label {
  font-size: 28rpx;
  color: var(--color-secondary);
}

.best-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFD700;
}

.test-area {
  border-radius: var(--radius-lg);
  padding: 80rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
  margin-bottom: 24rpx;
}

.state-waiting {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.state-ready {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.state-go {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.state-result {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}

.state-tooearly {
  background: linear-gradient(135deg, #fbc2eb, #a6c1ee);
}

.area-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}

.area-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.area-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-bottom: 32rpx;
}

.start-btn {
  background: rgba(255,255,255,0.3);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 16rpx 64rpx;
  border-radius: 40rpx;
}
