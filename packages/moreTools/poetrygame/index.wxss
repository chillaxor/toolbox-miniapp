/* ========== CSS Variables ========== */
page {
  --color-primary: #C0392B;
  --color-primary-light: #E74C3C;
  --color-gold: #D4A017;
  --color-gold-light: #F0C75E;
  --color-bg: #F5F0E8;
  --color-card: #FFFDF7;
  --color-text: #2C2C2C;
  --color-text-light: #888;
  --color-border: #E8DFD0;
  --color-red-bg: rgba(192, 57, 43, 0.08);
  --font-poem: "STKaiti", "KaiTi", "楷体", "Noto Serif SC", serif;
  --radius-card: 16rpx;
  --radius-circle: 50%;
  --shadow-card: 0 4rpx 20rpx rgba(0,0,0,0.06);
  --shadow-hover: 0 8rpx 32rpx rgba(0,0,0,0.10);
}

/* ========== Container ========== */
.container {
  padding: 24rpx 28rpx;
  background: var(--color-bg);
  min-height: 100vh;
}

/* ========== Header ========== */
.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 24rpx;
}

.tool-header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
}

/* ========== Mode Tabs ========== */
.mode-tabs {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-light);
  border-radius: 12rpx;
  transition: all 0.25s;
  font-weight: 500;
}

.mode-active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

/* ========== Character Selector ========== */
.char-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.char-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 4rpx;
}

.char-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-circle);
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  font-size: 32rpx;
  font-family: var(--font-poem);
  color: var(--color-text);
  flex-shrink: 0;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.char-active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
  font-weight: 700;
  font-size: 34rpx;
  box-shadow: 0 4rpx 16rpx rgba(192, 57, 43, 0.3);
  transform: scale(1.08);
}

/* ========== Action Row ========== */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.random-btn {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: var(--color-card);
  border-radius: 40rpx;
  border: 2rpx solid var(--color-gold);
  font-size: 26rpx;
  color: var(--color-gold);
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(212, 160, 23, 0.15);
}

.random-btn:active {
  opacity: 0.7;
}

.poem-count {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* ========== Empty State ========== */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-light);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #bbb;
}

/* ========== Poem Cards ========== */
.poem-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.poem-card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
  position: relative;
}

.poem-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--color-primary), var(--color-gold));
  border-radius: 4rpx 0 0 4rpx;
}

.poem-card-inner {
  padding: 28rpx 28rpx 20rpx 36rpx;
}

.poem-line {
  padding: 10rpx 0;
  line-height: 1.8;
}

.line-text {
  font-family: var(--font-poem);
  font-size: 32rpx;
  color: var(--color-text);
  letter-spacing: 2rpx;
  line-height: 1.8;
}

.hl-char {
  font-family: var(--font-poem);
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
  line-height: 1.8;
  text-shadow: 0 0 8rpx rgba(192, 57, 43, 0.2);
}

.poem-meta {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx dashed var(--color-border);
}

.poem-source {
  font-size: 24rpx;
  color: var(--color-text-light);
  font-family: var(--font-poem);
}

/* ========== Game Mode ========== */
.game-start {
  padding: 40rpx 20rpx;
}

.game-intro-card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 48rpx 36rpx;
  box-shadow: var(--shadow-card);
  text-align: center;
  border: 2rpx solid var(--color-border);
}

.game-intro-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  font-family: var(--font-poem);
}

.game-intro-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-light);
  line-height: 1.8;
  margin-bottom: 40rpx;
}

.start-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 80rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow: 0 6rpx 24rpx rgba(192, 57, 43, 0.3);
}

.start-btn:active {
  opacity: 0.8;
  transform: scale(0.97);
}

/* ========== Game Area ========== */
.game-area {
  padding: 20rpx 0;
}

.game-char-ring {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-circle);
  background: linear-gradient(135deg, var(--color-primary), var(--color-gold));
  box-shadow: 0 8rpx 40rpx rgba(192, 57, 43, 0.25);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.game-char-text {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  font-family: var(--font-poem);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.game-char-label {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-light);
  margin-bottom: 36rpx;
}

/* ========== Timer ========== */
.timer-section {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.timer-ring {
  width: 140rpx;
  height: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-circle);
  border: 6rpx solid var(--color-gold);
  background: var(--color-card);
  box-shadow: 0 4rpx 16rpx rgba(212, 160, 23, 0.15);
  transition: border-color 0.3s;
}

.timer-warn {
  border-color: #E67E22;
  background: #FFF8F0;
}

.timer-danger {
  border-color: var(--color-primary);
  background: var(--color-red-bg);
  animation: timerShake 0.5s ease-in-out infinite;
}

@keyframes timerShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4rpx); }
  75% { transform: translateX(4rpx); }
}

.timer-num {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
}

.timer-warn .timer-num {
  color: #E67E22;
}

.timer-danger .timer-num {
  color: var(--color-primary);
}

.timer-label {
  font-size: 20rpx;
  color: var(--color-text-light);
  margin-top: 2rpx;
}

/* ========== Game Buttons ========== */
.game-btn-row {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 32rpx;
}

.game-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 40rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.game-btn:active {
  opacity: 0.7;
}

.hint-btn {
  background: var(--color-card);
  border: 2rpx solid var(--color-gold);
  color: var(--color-gold);
}

.next-btn {
  background: linear-gradient(135deg, #27AE60, #2ECC71);
  color: #fff;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(39, 174, 96, 0.25);
}

/* ========== Score ========== */
.score-section {
  display: flex;
  justify-content: space-around;
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 24rpx 0;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-card);
}

.score-item {
  text-align: center;
}

.score-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-bottom: 8rpx;
}

.score-val {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* ========== Hint List ========== */
.hint-list {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
}

.hint-title {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-light);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.hint-item {
  padding: 16rpx 0;
  border-bottom: 1rpx dashed var(--color-border);
}

.hint-item:last-child {
  border-bottom: none;
}

.hint-meta {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  font-family: var(--font-poem);
}

/* ========== Game Over ========== */
.game-over {
  padding: 40rpx 20rpx;
}

.game-over-card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 48rpx 36rpx;
  box-shadow: var(--shadow-hover);
  text-align: center;
  border: 2rpx solid var(--color-gold-light);
}

.game-over-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-gold);
  margin-bottom: 36rpx;
  font-family: var(--font-poem);
}

.game-over-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.go-stat {
  text-align: center;
}

.go-stat-num {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.go-stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 6rpx;
}

/* ========== Tip Card ========== */
.tip-card {
  margin-top: 40rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #FFF8E7, #FFF5DC);
  border-radius: var(--radius-card);
  border: 1rpx solid #F0E0B8;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-gold);
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: #9A8C6E;
  line-height: 1.8;
}

/* ========== 加载中 ========== */
.loading-mask {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-light);
}
