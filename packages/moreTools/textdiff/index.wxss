.textarea-field {
  width: 100%;
  min-height: 160rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-primary);
  font-family: monospace;
}

.card-title {
  font-size: 28rpx;
  color: var(--color-secondary);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-row .btn-primary {
  flex: 1;
}

.btn-row .btn-secondary {
  flex: 1;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stat-same { color: var(--color-secondary); }
.stat-add { color: #2ED573; }
.stat-del { color: #FF4757; }

.stat-label {
  font-size: 24rpx;
  color: var(--color-hint);
}

.diff-scroll {
  max-height: 600rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 16rpx;
}

.diff-line {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
}

.diff-same {
  background: transparent;
}

.diff-add {
  background: rgba(46, 213, 115, 0.15);
}

.diff-del {
  background: rgba(255, 71, 87, 0.15);
}

.diff-diff {
  background: rgba(255, 165, 2, 0.15);
}

.diff-num {
  font-size: 22rpx;
  color: var(--color-hint);
  width: 48rpx;
  flex-shrink: 0;
  font-family: monospace;
}

.diff-text {
  font-size: 24rpx;
  color: var(--color-primary);
  word-break: break-all;
  flex: 1;
  font-family: monospace;
  line-height: 1.5;
}
