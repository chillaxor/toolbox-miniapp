.score-bar {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.score-item {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.score-label {
  font-size: 24rpx;
  color: var(--color-hint);
}

.score-val {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.score-val.best {
  color: #FFD700;
}

.intro-box {
  text-align: center;
  padding: 32rpx 0;
}

.intro-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.intro-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.intro-desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-hint);
  line-height: 1.8;
}

.message-bar {
  text-align: center;
  padding: 16rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.message-bar.showing {
  background: #E8F5E9;
  color: #2E7D32;
}

.message-bar.input {
  background: #E3F2FD;
  color: #1565C0;
}

.message-bar.gameover {
  background: #FFEBEE;
  color: #C62828;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.cell {
  aspect-ratio: 1;
  background: #E8EAF6;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.cell-active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  transform: scale(0.92);
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.4);
}

.cell-disabled {
  opacity: 0.5;
}

.cell-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-hint);
}

.cell-active .cell-num {
  color: #fff;
}

.result-box {
  text-align: center;
  padding: 16rpx 0;
}

.result-score {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.result-best {
  display: block;
  font-size: 28rpx;
  color: #FFD700;
  font-weight: 600;
}
