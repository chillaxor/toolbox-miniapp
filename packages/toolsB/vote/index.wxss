.tool-header {
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.tool-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  font-size: 28rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.option-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FF6B35;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-input {
  flex: 1;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffe0e0;
  color: #E74C3C;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.add-option-btn {
  text-align: center;
  padding: 16rpx;
  color: #FF6B35;
  font-size: 26rpx;
  border: 2rpx dashed #FF6B35;
  border-radius: 12rpx;
  margin-top: 8rpx;
}

.start-btn {
  background: linear-gradient(135deg, #FF6B35, #ff8c5a);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.vote-title {
  text-align: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.vote-title-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.vote-count {
  font-size: 24rpx;
  color: var(--color-secondary);
}

.vote-options {
  margin-bottom: 24rpx;
}

.vote-option {
  position: relative;
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.vote-bar {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: rgba(255,107,53,0.1);
  transition: width 0.3s ease;
}

.vote-option-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-primary);
  z-index: 1;
}

.vote-option-count {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 600;
  z-index: 1;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.result-btn {
  flex: 1;
  background: #FF6B35;
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.reset-btn {
  flex: 1;
  background: #f5f5f5;
  color: var(--color-secondary);
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.winner-card {
  text-align: center;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #FF6B35, #ff8c5a);
  color: #fff;
}

.winner-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.winner-label {
  font-size: 26rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 8rpx;
}

.winner-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.winner-name {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.winner-votes {
  font-size: 26rpx;
  opacity: 0.9;
}

.result-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.result-name {
  width: 140rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.result-bar-wrap {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.result-bar {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35, #ff8c5a);
  border-radius: 12rpx;
  transition: width 0.3s ease;
  min-width: 4rpx;
}

.result-pct {
  width: 100rpx;
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
  text-align: right;
  flex-shrink: 0;
}

.result-votes {
  width: 80rpx;
  font-size: 22rpx;
  color: var(--color-secondary);
  text-align: right;
  flex-shrink: 0;
}

.clear-link {
  font-size: 24rpx;
  color: #E74C3C;
  font-weight: 400;
}

.history-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.history-title {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.history-time {
  font-size: 22rpx;
  color: var(--color-secondary);
}

.history-winner {
  font-size: 24rpx;
  color: #FF6B35;
}
