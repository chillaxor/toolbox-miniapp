.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.tool-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tool-header-fav {
  font-size: 44rpx;
  padding: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  display: block;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.grade-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grade-item {
  width: calc(50% - 8rpx);
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: #f8f8f8;
  text-align: center;
  transition: all 0.2s;
}

.grade-item:active {
  background-color: #45B058;
}

.grade-item:active .grade-name,
.grade-item:active .grade-count {
  color: #fff;
}

.grade-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  display: block;
}

.grade-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.progress-bar {
  margin-bottom: 24rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  display: block;
  margin-bottom: 12rpx;
}

.progress-track {
  height: 12rpx;
  background-color: #ECEFF1;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #45B058;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.practice-controls {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.control-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background-color: #f0f0f0;
  font-size: 28rpx;
  color: #666;
}

.control-btn.control-active {
  background-color: #45B058;
  color: #fff;
}

.word-card {
  text-align: center;
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.word-pinyin {
  font-size: 36rpx;
  color: #E74C3C;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.word-stroke {
  font-size: 26rpx;
  color: #F39C12;
  display: block;
  margin-bottom: 16rpx;
}

.word-answer-area {
  margin: 40rpx 0;
}

.word-answer {
  font-size: 160rpx;
  font-weight: 700;
  color: #2C3E50;
}

.word-placeholder {
  font-size: 160rpx;
  font-weight: 700;
  color: #ECEFF1;
}

.hint-btns {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.hint-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  color: #666;
  font-size: 26rpx;
  border: none;
  line-height: 1.5;
}

.hint-btn::after {
  border: none;
}

.hint-btn.hint-active {
  background-color: #ECEFF1;
  color: #45B058;
}

.judge-btns {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.judge-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.judge-btn::after {
  border: none;
}

.judge-wrong {
  background-color: #FDE8E8;
  color: #E74C3C;
}

.judge-correct {
  background-color: #D9F0DC;
  color: #27AE60;
}

.score-bar {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.score-correct,
.score-wrong {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-num {
  font-size: 48rpx;
  font-weight: 700;
}

.score-correct .score-num {
  color: #27AE60;
}

.score-wrong .score-num {
  color: #E74C3C;
}

.score-label {
  font-size: 24rpx;
  color: #999;
}

.result-emoji {
  text-align: center;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 32rpx;
  display: block;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #2C3E50;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.result-detail {
  padding-top: 24rpx;
  border-top: 1rpx solid #ECEFF1;
}

.detail-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 16rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
}

.detail-bar-wrap {
  flex: 1;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.detail-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  min-width: 80rpx;
  text-align: right;
}

.wrong-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.wrong-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-word {
  font-size: 48rpx;
  font-weight: 700;
  color: #2C3E50;
  min-width: 60rpx;
  text-align: center;
}

.wrong-pinyin {
  font-size: 28rpx;
  color: #E74C3C;
}

.wrong-stroke {
  font-size: 24rpx;
  color: #F39C12;
  flex: 1;
  text-align: right;
}

.btn-group {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #f0f0f0;
  color: #666;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-secondary::after {
  border: none;
}
