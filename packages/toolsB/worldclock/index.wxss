.clock-list {
  margin-bottom: 24rpx;
}

.clock-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: relative;
}

.clock-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.clock-emoji {
  font-size: 48rpx;
}

.clock-info {
  display: flex;
  flex-direction: column;
}

.clock-city {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.clock-country {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.clock-right {
  text-align: right;
  display: flex;
  flex-direction: column;
}

.clock-time {
  font-size: 44rpx;
  font-weight: 700;
  color: #4ECDC4;
}

.clock-night {
  color: #5B6ABF;
}

.clock-date {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.clock-remove {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  font-size: 24rpx;
  color: #ccc;
  padding: 8rpx;
}

.add-btn {
  text-align: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  color: #4ECDC4;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx dashed #4ECDC4;
}

.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.add-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 70vh;
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.add-panel.show {
  transform: translateY(0);
}

.add-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.add-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.add-panel-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.search-box {
  padding: 16rpx 32rpx;
}

.search-input {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.city-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 32rpx;
}

.city-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.city-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.city-info {
  flex: 1;
}

.city-name {
  font-size: 28rpx;
  color: #333;
}

.city-country {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

.city-offset {
  font-size: 24rpx;
  color: #999;
}
