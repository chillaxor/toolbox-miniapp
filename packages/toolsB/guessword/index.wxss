.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #6a5acd, #8a6fd6);
  padding: 40rpx 48rpx 60rpx;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

/* 游戏中：横屏锁定不滚动，深色调高级背景，三行布局 */
.page.play {
  overflow: hidden;
  background: radial-gradient(120% 80% at 50% 38%, #3b2d72 0%, #261b4e 52%, #18103a 100%);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: stretch;
  padding: 44rpx 56rpx 48rpx;
}

.play-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.play-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.16);
  overflow: hidden;
}

.play-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #7CFC9B, #4be0c4);
  transition: width .25s ease;
}

.play-count {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.play-count .muted {
  color: rgba(255, 255, 255, 0.5);
  font-weight: 500;
}

.play-stage {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.play-word {
  color: #fff;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-align: center;
  line-height: 1.1;
  white-space: nowrap;
  text-shadow: 0 8rpx 36rpx rgba(0, 0, 0, 0.4);
}

.play-word.pulse {
  animation: pop .22s cubic-bezier(.2, .8, .3, 1);
}

@keyframes pop {
  0% { transform: scale(0.86); opacity: 0.4; }
  100% { transform: scale(1); opacity: 1; }
}

.play-foot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.play-flip {
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
}

.play-tap {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.hero {
  color: #fff;
  font-size: 48rpx;
  font-weight: 800;
  text-align: center;
  margin: 20rpx 0;
}

.howto {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  line-height: 1.7;
}

.sec-label {
  color: #fff;
  font-size: 28rpx;
  margin: 28rpx 0 14rpx;
  font-weight: 600;
}

.chip-row {
  display: flex;
  gap: 20rpx;
}

.chip {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.chip-on {
  background: #fff;
  color: #6a5acd;
  font-weight: 700;
}

.switch-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.switch {
  width: 96rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: rgba(255, 255, 255, 0.25);
  position: relative;
  transition: .2s;
  flex-shrink: 0;
}

.switch-on {
  background: #7CFC9B;
}

.knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #fff;
  transition: .2s;
}

.switch-on .knob {
  left: 46rpx;
}

.switch-tip {
  color: #fff;
  font-size: 26rpx;
}

.btn-primary {
  margin-top: 40rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: #fff;
  color: #6a5acd;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary.inline {
  margin-top: 0;
  flex: 1;
}

/* 结果 */
.result-emoji {
  text-align: center;
  font-size: 96rpx;
  margin: 20rpx 0;
}

.result-title {
  text-align: center;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 30rpx;
}

.result-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.r-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 20rpx;
  padding: 28rpx 0;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
}

.r-num {
  font-size: 52rpx;
  font-weight: 800;
  margin-top: 6rpx;
}

.btn-row {
  display: flex;
  gap: 24rpx;
}

.btn-ghost {
  flex: 1;
  height: 92rpx;
  border-radius: 46rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
