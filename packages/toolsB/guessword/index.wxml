<view class="page {{phase==='playing' ? 'play' : ''}}" bindtap="nextWord">
  <!-- 设置 -->
  <block wx:if="{{phase==='setup'}}">
    <view class="hero">📱 头顶猜词</view>
    <view class="howto">
      <view>· 1 人把手机横放在额头（屏幕朝外），另 1 人看屏幕描述词语。</view>
      <view>· 猜完/不会，把手机向下翻一下自动换词，或轻触屏幕换词。</view>
    </view>

    <view class="sec-label">每局词数</view>
    <view class="chip-row">
      <view class="chip {{roundLen==='20'?'chip-on':''}}" bindtap="selectLen" data-len="20">20 个</view>
      <view class="chip {{roundLen==='40'?'chip-on':''}}" bindtap="selectLen" data-len="40">40 个</view>
      <view class="chip {{roundLen==='all'?'chip-on':''}}" bindtap="selectLen" data-len="all">全部</view>
    </view>

    <view class="sec-label">翻手机切词</view>
    <view class="switch-row" bindtap="toggleFlip">
      <view class="switch {{flipOn?'switch-on':''}}"><view class="knob"></view></view>
      <view class="switch-tip">{{flipOn ? '已开启·翻一下手机换词' : '已关闭·只用轻触'}}</view>
    </view>

    <view class="btn-primary" bindtap="onStart">开始游戏 🚀</view>
  </block>

  <!-- 游戏中：横屏，顶部进度条 + 居中大字 + 底部提示 -->
  <block wx:elif="{{phase==='playing'}}">
    <view class="play-top">
      <view class="play-bar"><view class="play-bar-fill" style="width:{{progressPercent}}%"></view></view>
      <view class="play-count">{{progress}} <text class="muted">/ {{total}}</text></view>
    </view>

    <view class="play-stage">
      <view class="play-word {{pulse ? 'pulse' : ''}}" style="font-size:{{wordSize}}rpx">{{currentWord}}</view>
    </view>

    <view class="play-foot">
      <view class="play-flip" wx:if="{{flipOn}}">📱 向下翻手机换词</view>
      <view class="play-tap">轻触屏幕 · 换下一个 ▸</view>
    </view>
  </block>

  <!-- 结果 -->
  <block wx:elif="{{phase==='result'}}">
    <view class="result-emoji">🎉</view>
    <view class="result-title">本局结束</view>
    <view class="result-stats">
      <view class="r-card">共 {{total}} 词<view class="r-num">{{total}}</view></view>
    </view>
    <view class="btn-row">
      <view class="btn-ghost" bindtap="onBackSetup">返回设置</view>
      <view class="btn-primary inline" bindtap="replay">再来一局</view>
    </view>
  </block>
</view>
