.mode-tabs {
  display: flex;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #4ECDC4;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #4ECDC4;
  background-color: #FFFFFF;
  transition: all 0.2s ease;
}

.mode-tab.mode-active {
  background-color: #4ECDC4;
  color: #FFFFFF;
  font-weight: 600;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: var(--color-hint);
  min-width: 80rpx;
}

.detail-value {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}
