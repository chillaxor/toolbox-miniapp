.container{min-height:100vh;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);padding:40rpx 32rpx;box-sizing:border-box}

/* 输入区域 */
.input-area{padding-top:60rpx}
.input-title{font-size:56rpx;color:#fff;text-align:center;font-weight:bold;margin-bottom:16rpx}
.input-desc{font-size:28rpx;color:rgba(255,255,255,0.5);text-align:center;margin-bottom:60rpx}
.input-row{margin-bottom:40rpx}
.row-label{font-size:28rpx;color:rgba(255,255,255,0.6);margin-bottom:16rpx;display:block}
.date-picker{padding:24rpx 30rpx;background:rgba(255,255,255,0.08);border-radius:16rpx;color:rgba(255,255,255,0.4);font-size:30rpx;border:2rpx solid rgba(255,255,255,0.1)}
.date-picker.has-val{color:#fff}
.life-btns{display:flex;gap:16rpx;flex-wrap:wrap}
.lbtn{flex:1;min-width:0;text-align:center;padding:20rpx 0;border-radius:16rpx;background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.6);font-size:26rpx;border:2rpx solid rgba(255,255,255,0.1)}
.lbtn.active{background:rgba(102,51,255,0.3);color:#fff;border-color:#6633FF}
.gen-btn{width:100%;height:96rpx;border-radius:48rpx;background:linear-gradient(135deg,#6633FF,#9B59B6);color:#fff;font-size:34rpx;font-weight:bold;border:none;margin-top:60rpx;line-height:96rpx}
.gen-btn::after{border:none}

/* 结果区域 */
.result-area{padding-top:20rpx}
.overview{display:flex;gap:16rpx;margin-bottom:30rpx}
.ov-item{flex:1;text-align:center;padding:24rpx 0;border-radius:16rpx;background:rgba(255,255,255,0.06)}
.ov-item.highlight{background:rgba(102,51,255,0.2);border:2rpx solid rgba(102,51,255,0.4)}
.ov-num{font-size:48rpx;color:#fff;font-weight:bold;display:block}
.ov-label{font-size:22rpx;color:rgba(255,255,255,0.5);display:block;margin-top:8rpx}

/* 进度条 */
.progress-section{margin-bottom:30rpx;padding:24rpx 30rpx;background:rgba(255,255,255,0.06);border-radius:16rpx}
.prog-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}
.prog-title{font-size:28rpx;color:rgba(255,255,255,0.7)}
.prog-pct{font-size:32rpx;color:#6633FF;font-weight:bold}
.prog-bar-bg{height:16rpx;background:rgba(255,255,255,0.1);border-radius:8rpx;overflow:hidden}
.prog-bar-fill{height:100%;background:linear-gradient(90deg,#6633FF,#9B59B6);border-radius:8rpx;transition:width 1s ease}

/* 更多数据 */
.more-stats{margin-bottom:30rpx}
.ms-item{display:flex;align-items:center;gap:16rpx;padding:16rpx 20rpx;background:rgba(255,255,255,0.04);border-radius:12rpx;margin-bottom:10rpx}
.ms-icon{font-size:32rpx}
.ms-text{font-size:26rpx;color:rgba(255,255,255,0.7)}

/* 格子日历 */
.cal-section{margin-bottom:30rpx}
.cal-title{font-size:24rpx;color:rgba(255,255,255,0.4);margin-bottom:20rpx}
.year-marks{position:relative;height:40rpx;margin-bottom:10rpx}
.ym{position:absolute;font-size:20rpx;color:rgba(255,255,255,0.3);transform:translateX(-50%)}
.cal-grid-wrap{max-height:600rpx}
.cal-grid{display:flex;flex-direction:column;gap:4rpx}
.cal-row{display:flex;align-items:center;gap:4rpx}
.cal-row-label{width:60rpx;font-size:18rpx;color:rgba(255,255,255,0.3);text-align:right;padding-right:8rpx;flex-shrink:0}
.cal-dot{width:14rpx;height:14rpx;border-radius:3rpx;flex-shrink:0}
.cal-dot.lived{background:#6633FF}
.cal-dot.current{background:#FFD700;box-shadow:0 0 8rpx rgba(255,215,0,0.6)}
.cal-dot.future{background:rgba(255,255,255,0.08)}

.cal-legend{display:flex;gap:30rpx;margin-top:20rpx;justify-content:center}
.leg-item{display:flex;align-items:center;gap:8rpx}
.leg-dot{width:16rpx;height:16rpx;border-radius:4rpx}
.leg-dot.lived{background:#6633FF}
.leg-dot.current{background:#FFD700}
.leg-dot.future{background:rgba(255,255,255,0.15)}
.leg-item text{font-size:22rpx;color:rgba(255,255,255,0.5)}

/* 提示语 */
.inspire-quote{padding:30rpx;background:rgba(255,255,255,0.06);border-radius:16rpx;margin-bottom:30rpx;text-align:center}
.inspire-quote text{font-size:28rpx;color:rgba(255,255,255,0.6);line-height:1.8}

.reset-btn{width:100%;height:88rpx;border-radius:44rpx;background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7);font-size:30rpx;border:2rpx solid rgba(255,255,255,0.15);line-height:88rpx;margin-bottom:40rpx}
