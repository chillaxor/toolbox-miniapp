/* ===== 儿童风格主题 · 谁是卧底 ===== */
.container {
  min-height: 100vh;
  padding: 24rpx 28rpx 60rpx;
  background: linear-gradient(180deg, #FFF7E6 0%, #E8F4FF 55%, #FDEFF6 100%);
  position: relative;
  box-sizing: border-box;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* 背景装饰（漂浮的 emoji） */
.bg-deco {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  overflow: hidden;
  z-index: 0;
  pointer-events: none;
}
.deco-emoji {
  position: absolute;
  font-size: 60rpx;
  opacity: 0.45;
}
.deco-emoji.d1 { top: 140rpx; left: 36rpx; transform: rotate(-12deg); }
.deco-emoji.d2 { top: 360rpx; right: 24rpx; font-size: 76rpx; opacity: 0.4; }
.deco-emoji.d3 { top: 760rpx; left: 56rpx; font-size: 84rpx; opacity: 0.3; }
.deco-emoji.d4 { bottom: 220rpx; right: 48rpx; font-size: 64rpx; }
.deco-emoji.d5 { bottom: 460rpx; left: 28rpx; font-size: 52rpx; opacity: 0.4; }

/* 头部 */
.tool-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx 28rpx;
  margin-bottom: 26rpx;
  background: linear-gradient(135deg, #FF9F45 0%, #FF6B6B 100%);
  border-radius: 40rpx;
  box-shadow: 0 12rpx 30rpx rgba(255, 107, 107, 0.35);
}
.tool-header-title {
  font-size: 50rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 0 rgba(0, 0, 0, 0.08);
}
.tool-header-fav {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
}

/* 卡片 */
.card {
  position: relative;
  z-index: 1;
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 26rpx;
  box-shadow: 0 10rpx 26rpx rgba(77, 150, 255, 0.12);
  border: 4rpx solid #FFF3D6;
}

/* 小节标题（彩色胶囊徽章） */
.card-title {
  display: inline-block;
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #4D96FF, #6BCBFF);
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 6rpx 14rpx rgba(77, 150, 255, 0.3);
}

/* 计数按钮 */
.count-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 26rpx;
}
.count-btn {
  min-width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #6B7A99;
  background: #F2F6FF;
  border-radius: 26rpx;
  border: 4rpx solid #E0E9FF;
  transition: transform 0.12s ease;
}
.count-btn:active {
  transform: scale(0.92);
}
.count-active {
  background: linear-gradient(135deg, #FF6B6B, #FF9F45);
  color: #fff;
  border-color: #FF6B6B;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 107, 0.4);
  transform: scale(1.08);
}
.count-btn-wide {
  min-width: 220rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
}

.spy-fixed {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #FF9F45;
  font-weight: 600;
}

/* 自定义词语输入 */
.word-input {
  margin-top: 22rpx;
  padding: 34rpx 36rpx;
  min-height: 104rpx;
  background: #FFF9F0;
  color: #333;
  border-radius: 26rpx;
  font-size: 40rpx;
  line-height: 1.4;
  font-weight: 600;
  border: 4rpx solid #FFE3C2;
}
.custom-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #FF9F45;
  font-weight: 600;
}

/* 规则说明 */
.rule-card {
  background: linear-gradient(135deg, #FFF7E6, #FFEFD6);
  border-color: #FFE0B2;
}
.rule-text {
  font-size: 28rpx;
  color: #7A6A52;
  line-height: 2;
  display: block;
  padding-left: 8rpx;
  font-weight: 600;
}

/* 开始按钮 */
.start-btn {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 112rpx;
  line-height: 112rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF9F45 100%);
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  border: none;
  margin-top: 44rpx;
  box-shadow: 0 14rpx 32rpx rgba(255, 107, 107, 0.4);
}
.start-btn:active {
  transform: scale(0.97);
}

/* 查看身份卡片 */
.viewing-card {
  text-align: center;
  padding: 56rpx 32rpx;
  background: linear-gradient(180deg, #FFFFFF, #FFF7FB);
}
.viewing-player {
  font-size: 54rpx;
  font-weight: 800;
  color: #4D96FF;
  display: block;
  margin-bottom: 12rpx;
}
.viewing-hint {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #FF6B6B;
  margin-bottom: 30rpx;
  text-align: center;
}
.reveal-area {
  padding: 40rpx 0;
}
.reveal-emoji {
  font-size: 130rpx;
  display: block;
  margin-bottom: 26rpx;
}
.reveal-text {
  font-size: 34rpx;
  color: #9AA7C2;
  display: block;
  margin-bottom: 40rpx;
  font-weight: 700;
}
.reveal-btn {
  width: 460rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  background: linear-gradient(135deg, #FF6B6B, #FF9F45);
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  border-radius: 999rpx;
  margin: 0 auto;
  box-shadow: 0 12rpx 28rpx rgba(255, 107, 107, 0.4);
}
.reveal-btn:active {
  transform: scale(0.96);
}
.word-text {
  font-size: 84rpx;
  font-weight: 800;
  color: #FF6B6B;
  display: block;
  margin-bottom: 18rpx;
  letter-spacing: 12rpx;
}
.word-pinyin {
  font-size: 36rpx;
  color: #4D96FF;
  letter-spacing: 3rpx;
  font-weight: 800;
  display: table;
  margin: 0 auto 14rpx;
  background: #EAF3FF;
  border-radius: 999rpx;
  padding: 8rpx 30rpx;
}
.role-text {
  font-size: 34rpx;
  font-weight: 800;
  display: table;
  margin: 24rpx auto 0;
  padding: 14rpx 40rpx;
  border-radius: 999rpx;
}
.spy-text {
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 107, 0.4);
}
.civilian-text {
  color: #fff;
  background: linear-gradient(135deg, #4ECCA3, #36B9A0);
  box-shadow: 0 8rpx 18rpx rgba(78, 204, 163, 0.4);
}

/* 进度小圆点 */
.progress-bar {
  margin: 36rpx 0 8rpx;
}
.progress-dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}
.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #D9E2F5;
  transition: transform 0.15s ease;
}
.dot-active {
  background: linear-gradient(135deg, #FF6B6B, #FF9F45);
  transform: scale(1.3);
}
.progress-text {
  font-size: 30rpx;
  color: #9AA7C2;
  font-weight: 700;
  display: block;
  text-align: center;
}
.next-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  text-align: center;
  background: linear-gradient(135deg, #4D96FF, #6BCBFF);
  color: #fff;
  font-size: 36rpx;
  font-weight: 800;
  border-radius: 999rpx;
  margin-top: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(77, 150, 255, 0.4);
}
.next-btn:active {
  transform: scale(0.97);
}
/* 未查看时禁用「下一位玩家」按钮 */
.next-disabled {
  background: #C7D2E8;
  color: #fff;
  box-shadow: none;
}
.next-disabled:active {
  transform: none;
}
/* 换词重开按钮 */
.reshuffle-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 800;
  color: #FF6B6B;
  background: #FFF0E6;
  border: 4rpx solid #FFD9C2;
  border-radius: 999rpx;
  margin-top: 18rpx;
}
.reshuffle-btn:active {
  transform: scale(0.97);
}

/* 讨论阶段 */
.round-header {
  text-align: center;
  margin-bottom: 26rpx;
}
.round-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #FF6B6B;
  display: inline-block;
  background: #FFF0E6;
  padding: 14rpx 40rpx;
  border-radius: 999rpx;
}
.discuss-hint {
  font-size: 30rpx;
  color: #5A6B8C;
  text-align: center;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 600;
}
.action-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 38rpx;
}
.action-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.12);
}
.action-btn:active {
  transform: scale(0.96);
}
.primary-btn {
  background: linear-gradient(135deg, #FF6B6B, #FF9F45);
  color: #fff;
}
.secondary-btn {
  background: linear-gradient(135deg, #4D96FF, #6BCBFF);
  color: #fff;
}

/* 投票阶段 */
.vote-hint {
  font-size: 28rpx;
  color: #FF9F45;
  font-weight: 700;
  display: block;
  margin-bottom: 22rpx;
}
.vote-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.vote-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 30rpx;
  background: #F2F6FF;
  border-radius: 26rpx;
  border: 4rpx solid #E0E9FF;
}
.vote-item:active {
  transform: scale(0.98);
  background: #E8EEFF;
}
.vote-player {
  font-size: 34rpx;
  font-weight: 800;
  color: #3A4A6B;
}
.vote-count {
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF9F45);
  padding: 8rpx 26rpx;
  border-radius: 999rpx;
}

/* 结果 / 揭晓 */
.result-card {
  text-align: center;
  padding: 56rpx 32rpx;
  background: linear-gradient(180deg, #FFFFFF, #FFF7FB);
}
.result-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #FF6B6B;
  display: block;
  margin-bottom: 34rpx;
}
.result-info {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 30rpx;
}
.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 30rpx;
  background: #F2F6FF;
  border-radius: 22rpx;
}
.ri-name {
  font-size: 32rpx;
  color: #3A4A6B;
  font-weight: 800;
}
.ri-role {
  font-size: 30rpx;
  font-weight: 800;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
}
.ri-spy {
  color: #fff;
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
}
.ri-civilian {
  color: #fff;
  background: linear-gradient(135deg, #4ECCA3, #36B9A0);
}
.result-words {
  margin-top: 22rpx;
  padding: 26rpx;
  background: #FFF7E6;
  border-radius: 26rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 12rpx 30rpx;
}
.rw-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.rw-label {
  font-size: 28rpx;
  color: #FF9F45;
  font-weight: 700;
}
.rw-word {
  font-size: 38rpx;
  font-weight: 800;
  color: #FF6B6B;
}
.rw-pinyin {
  font-size: 26rpx;
  color: #4D96FF;
  font-weight: 700;
  margin-left: 10rpx;
  background: #EAF3FF;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
}

.showwords-info {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 30rpx;
}
.sw-item {
  flex: 1;
  text-align: center;
  padding: 38rpx 20rpx;
  background: #F2F6FF;
  border-radius: 30rpx;
  border: 4rpx solid #E0E9FF;
}
.sw-label {
  font-size: 28rpx;
  color: #4D96FF;
  font-weight: 800;
  display: block;
  margin-bottom: 14rpx;
}
.sw-word {
  font-size: 54rpx;
  font-weight: 800;
  color: #FF6B6B;
  display: block;
  letter-spacing: 4rpx;
}
.sw-pinyin {
  font-size: 30rpx;
  color: #4D96FF;
  font-weight: 700;
  letter-spacing: 2rpx;
  display: table;
  margin: 12rpx auto 0;
}

/* ===== 查看阶段：每位玩家一整条横排卡片 ===== */
.viewing-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.vcard {
  width: 100%;
  box-sizing: border-box;
  background: #F2F6FF;
  border: 4rpx solid #E0E9FF;
  border-radius: 28rpx;
  padding: 26rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
}
.vcard-current {
  background: #FFF7FB;
  border-color: #FF9F45;
  box-shadow: 0 10rpx 26rpx rgba(255, 159, 69, 0.35);
}
.vcard-done, .vcard-pending {
  opacity: 0.65;
}
.vcard-no {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #3A4A6B;
}
.vcard-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  min-width: 0;
}
.vcard-q {
  font-size: 60rpx;
  line-height: 1;
}
.vcard-q.done {
  font-size: 48rpx;
  color: #4ECCA3;
}
.vcard-done {
  font-size: 28rpx;
  color: #9AA7C2;
  font-weight: 700;
}
.vcard-btn {
  padding: 16rpx 36rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF9F45);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 107, 0.35);
}
.vcard-btn:active {
  transform: scale(0.95);
}
.vcard-word {
  font-size: 52rpx;
  font-weight: 800;
  color: #FF6B6B;
  letter-spacing: 4rpx;
}
.vcard-py {
  font-size: 26rpx;
  color: #4D96FF;
  font-weight: 700;
  background: #EAF3FF;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
}
.vcard-role {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
}
.is-spy {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
}
.is-civ {
  background: linear-gradient(135deg, #4ECCA3, #36B9A0);
}

/* ===== 结果 / 揭晓：每位玩家一整条横排卡片（与查看阶段统一） ===== */
.result-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 10rpx;
}
.rcard {
  width: 100%;
  box-sizing: border-box;
  background: #F2F6FF;
  border: 4rpx solid #E0E9FF;
  border-radius: 28rpx;
  padding: 26rpx 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
}
.rc-body {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
  min-width: 0;
}
.rc-no {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #3A4A6B;
}
.rc-label {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #4D96FF;
}
.rc-word {
  font-size: 48rpx;
  font-weight: 800;
  color: #FF6B6B;
  letter-spacing: 4rpx;
}
.rc-py {
  font-size: 24rpx;
  color: #4D96FF;
  font-weight: 700;
  background: #EAF3FF;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.rc-role {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  padding: 8rpx 26rpx;
  border-radius: 999rpx;
}
