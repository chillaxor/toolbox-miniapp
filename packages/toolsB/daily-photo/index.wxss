.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 0 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* 拍照区域 */
.shoot-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0 30rpx;
}

.shoot-ring {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  border: 6rpx solid #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.shoot-ring::after {
  content: '';
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(102,126,234,0.3);
  animation: spin 8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.shoot-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(102,126,234,0.4);
}

.shoot-icon {
  font-size: 56rpx;
}

.shoot-text {
  font-size: 20rpx;
  color: #fff;
  margin-top: 8rpx;
}

.today-date {
  font-size: 28rpx;
  color: #333;
  margin-top: 24rpx;
  font-weight: bold;
}

.shoot-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 视图切换 */
.view-tabs {
  display: flex;
  margin: 0 30rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.view-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.view-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 时光轴 */
.photo-list {
  height: calc(100vh - 500rpx);
  padding: 0 30rpx;
}

.timeline-group {
  margin-bottom: 30rpx;
}

.timeline-date {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 30rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: absolute;
  left: 0;
}

.timeline-date-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.timeline-photos {
  padding-left: 30rpx;
  border-left: 4rpx solid #E8E8E8;
  margin-left: 7rpx;
}

.photo-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.photo-img {
  width: 100%;
  height: 400rpx;
}

.photo-info {
  padding: 16rpx 20rpx;
}

.photo-time {
  font-size: 24rpx;
  color: #999;
}

.photo-note {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-top: 8rpx;
}

/* 日历视图 */
.calendar-view {
  height: calc(100vh - 500rpx);
  padding: 0 30rpx;
}

.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  text-align: center;
  line-height: 60rpx;
  font-size: 28rpx;
  color: #667eea;
}

.month-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.week-header {
  display: flex;
  margin-bottom: 10rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 0;
}

.cal-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: 14.28%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  padding: 4rpx;
}

.cal-cell.today {
  background: rgba(102,126,234,0.1);
  border-radius: 12rpx;
}

.cal-cell.today .cal-day-num {
  color: #667eea;
  font-weight: bold;
}

.cal-cell.other-month .cal-day-num {
  color: #CCC;
}

.cal-day-num {
  font-size: 24rpx;
  color: #333;
  z-index: 1;
  position: absolute;
  top: 4rpx;
}

.cal-day-thumb {
  width: 80%;
  height: 80%;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

.cal-day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #667eea;
  position: absolute;
  bottom: 6rpx;
}

/* 备注弹窗 */
.note-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.note-card {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.note-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}

.note-input {
  width: 100%;
  height: 180rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.note-actions {
  display: flex;
  margin-top: 30rpx;
  gap: 20rpx;
}

.note-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.note-btn.cancel {
  background: #F5F5F5;
  color: #666;
}

.note-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 预览 */
.preview-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.95);
  z-index: 200;
  display: flex;
  flex-direction: column;
}

.preview-swiper {
  flex: 1;
  width: 100%;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.preview-info {
  text-align: center;
  padding: 20rpx;
}

.preview-date {
  font-size: 28rpx;
  color: #fff;
  margin-right: 16rpx;
}

.preview-time {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

.preview-close {
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: rgba(255,255,255,0.8);
}

.preview-delete {
  position: absolute;
  top: 80rpx;
  right: 30rpx;
  font-size: 28rpx;
  color: #FF6B6B;
  padding: 10rpx 20rpx;
}
