.container {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  padding: 0 0 30rpx 0;
}

.header {
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.turn-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.piece-indicator {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ccc;
}

.black-piece {
  background: #000;
  border-color: #000;
}

.white-piece {
  background: #fff;
  border-color: #ccc;
}

.turn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.score-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.piece-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.black-dot {
  background: #000;
}

.white-dot {
  background: #fff;
  border: 2rpx solid #ccc;
}

.score-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.score-vs {
  font-size: 24rpx;
  color: #999;
}

.board-scroll {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}

.board {
  margin: 0 auto;
  position: relative;
}

.board-canvas {
  display: block;
}

.actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  justify-content: center;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.btn-undo {
  background: #fff;
  color: #333;
  border: 2rpx solid #ddd;
}

.btn-undo[disabled] {
  opacity: 0.5;
}

.btn-restart {
  background: #FF6B35;
  color: #fff;
}
