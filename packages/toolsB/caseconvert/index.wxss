.btn-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-mode {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 20rpx 16rpx;
  border-radius: 44rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
}

.btn-mode:active { opacity: 0.8; }

.result-text {
  font-size: 28rpx;
  color: var(--color-primary);
  padding: 16rpx;
  background-color: #F0FFF0;
  border-radius: 12rpx;
  word-break: break-all;
  line-height: 1.8;
}

.btn-row { display: flex; justify-content: flex-end; }
.btn-small { padding: 12rpx 32rpx; background-color: var(--color-border); border-radius: 24rpx; font-size: 24rpx; color: var(--color-secondary); }
