.container {
  min-height: 100vh;
  background: #f5f0e8;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #8B4513;
  color: #fff;
}
.nav-left { width: 80rpx; }
.nav-icon { font-size: 36rpx; }
.nav-center { flex: 1; text-align: center; }
.nav-title { font-size: 34rpx; font-weight: bold; }
.nav-right { width: 80rpx; text-align: right; }
.fav-icon { font-size: 36rpx; color: rgba(255,255,255,0.5); }
.fav-icon.active { color: #FFD700; }

/* 操作按钮 */
.action-bar {
  padding: 30rpx;
}
.quiz-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #D2691E, #8B4513);
  color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(139,69,19,0.3);
}
.quiz-icon { font-size: 40rpx; margin-right: 16rpx; }
.quiz-text { font-size: 32rpx; font-weight: bold; }

/* 分类筛选 */
.category-scroll {
  white-space: nowrap;
  padding: 0 30rpx 20rpx;
}
.category-list {
  display: inline-flex;
  gap: 16rpx;
}
.category-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #8B4513;
  border: 2rpx solid #D2B48C;
}
.category-tag.active {
  background: #8B4513;
  color: #fff;
  border-color: #8B4513;
}

/* 成语列表 */
.idiom-list {
  flex: 1;
  padding: 0 30rpx;
}
.idiom-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.idiom-left { flex: 1; }
.idiom-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}
.idiom-pinyin {
  font-size: 24rpx;
  color: #999;
}
.idiom-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.idiom-category-tag {
  font-size: 22rpx;
  color: #8B4513;
  background: #FFF8F0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.idiom-difficulty { font-size: 20rpx; }
.list-footer {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 30rpx 0 60rpx;
}

/* 详情页 */
.page-detail { flex: 1; }
.detail-scroll { height: 100%; }
.detail-header {
  background: #8B4513;
  color: #fff;
  padding: 50rpx 40rpx 40rpx;
  text-align: center;
}
.detail-idiom {
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.detail-pinyin {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 20rpx;
}
.detail-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}
.meta-tag {
  background: rgba(255,255,255,0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}
.meta-origin { font-size: 24rpx; opacity: 0.7; }

.detail-section {
  margin: 24rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
}
.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}
.story-content {
  text-indent: 2em;
}

.detail-nav {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}
.nav-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #8B4513;
  font-size: 28rpx;
  border: 2rpx solid #D2B48C;
}
.nav-btn.primary {
  background: #8B4513;
  color: #fff;
  border-color: #8B4513;
}

/* 问答页 */
.page-quiz { flex: 1; }
.quiz-scroll { height: 100%; }
.quiz-progress {
  padding: 30rpx;
}
.progress-bar {
  height: 12rpx;
  background: #e0d5c5;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.progress-fill {
  height: 100%;
  background: #8B4513;
  border-radius: 6rpx;
  transition: width 0.3s;
}
.progress-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  display: block;
}

.quiz-score {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding-bottom: 20rpx;
}
.score-correct { font-size: 28rpx; color: #4CAF50; font-weight: bold; }
.score-wrong { font-size: 28rpx; color: #F44336; font-weight: bold; }

.quiz-question {
  text-align: center;
  padding: 20rpx 30rpx 30rpx;
}
.question-idiom {
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.question-hint {
  font-size: 28rpx;
  color: #999;
}

.quiz-options {
  padding: 0 30rpx;
}
.option-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.option-item.selected {
  border-color: #8B4513;
}
.option-item.correct {
  border-color: #4CAF50;
  background: #E8F5E9;
}
.option-item.wrong {
  border-color: #F44336;
  background: #FFEBEE;
}
.option-letter {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: #f5f0e8;
  border-radius: 50%;
  font-size: 26rpx;
  color: #8B4513;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.option-item.correct .option-letter { background: #4CAF50; color: #fff; }
.option-item.wrong .option-letter { background: #F44336; color: #fff; }
.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}
.option-icon {
  font-size: 32rpx;
  color: #4CAF50;
  margin-left: 16rpx;
}
.option-icon.wrong { color: #F44336; }

.quiz-next {
  margin: 30rpx;
  background: #8B4513;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 结果页 */
.page-result { flex: 1; }
.result-scroll { height: 100%; }
.result-card {
  margin: 40rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}
.result-emoji { font-size: 80rpx; margin-bottom: 20rpx; }
.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}
.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 50rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}
.stat-item.correct .stat-num { color: #4CAF50; }
.stat-item.wrong .stat-num { color: #F44336; }
.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.result-actions {
  display: flex;
  gap: 20rpx;
}
.result-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #8B4513;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}
.result-btn.secondary {
  background: #fff;
  color: #8B4513;
  border: 2rpx solid #8B4513;
}
