<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">古诗背诵卡</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 年级选择/古诗列表页 -->
  <view wx:if="{{page === 'list'}}">
    <view class="card" wx:if="{{poemList.length === 0}}">
      <text class="card-title">选择年级</text>
      <view class="grade-grid">
        <view class="grade-item" wx:for="{{gradeList}}" wx:key="key"
              data-grade="{{item.key}}" bindtap="onGradeSelect">
          <text class="grade-name">{{item.name}}</text>
          <text class="grade-count">{{item.count}}首</text>
        </view>
      </view>
    </view>

    <view wx:if="{{poemList.length > 0}}">
      <view class="back-bar" bindtap="onBackGrade">
        <text>← 返回选择年级</text>
      </view>

      <view class="card">
        <text class="card-title">📜 {{gradeList[selectedGrade-1].name}} 必背古诗</text>
        <view class="poem-list">
          <view class="poem-item" wx:for="{{poemList}}" wx:key="title"
                data-index="{{index}}" bindtap="onPoemTap">
            <view class="poem-info">
              <text class="poem-title">{{item.title}}</text>
              <text class="poem-author">〔{{item.dynasty}}〕{{item.author}}</text>
            </view>
            <text class="poem-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 背诵模式 -->
  <view wx:if="{{page === 'recite'}}">
    <view class="back-bar" bindtap="onBackList">
      <text>← 返回古诗列表</text>
    </view>

    <view class="poem-card">
      <view class="poem-header">
        <text class="poem-card-title">{{currentPoem.title}}</text>
        <text class="poem-card-author">〔{{currentPoem.dynasty}}〕{{currentPoem.author}}</text>
      </view>

      <view class="poem-lines">
        <view class="poem-line" wx:for="{{currentPoem.lines}}" wx:key="index"
              data-index="{{index}}" bindtap="onToggleLine">
          <text wx:if="{{!hiddenLines[index] || showAll}}" class="line-text">{{item}}</text>
          <text wx:else class="line-blank">__________</text>
        </view>
      </view>

      <view class="recite-controls">
        <button class="ctrl-btn" bindtap="onStartRecite">开始背诵</button>
        <button class="ctrl-btn" bindtap="onShowAll" wx:if="{{!showAll}}">显示全文</button>
        <button class="ctrl-btn" bindtap="onCheckRecite">我已背会</button>
      </view>
    </view>

    <view class="card" style="margin-top: 24rpx;">
      <text class="card-title">📝 默写练习</text>
      <text class="tip-text">点击下方按钮进入填空默写模式</text>
      <button class="btn-primary" style="background-color: #E74C3C; margin-top: 16rpx;" bindtap="onStartFill">开始默写</button>
    </view>

    <view class="card" style="margin-top: 24rpx;">
      <text class="card-title">💡 背诵技巧</text>
      <text class="tip-text">• 先通读全文理解诗意</text>
      <text class="tip-text">• 逐句背诵，点击诗句可切换显示/隐藏</text>
      <text class="tip-text">• 尝试默写检验记忆效果</text>
    </view>
  </view>

  <!-- 填空默写模式 -->
  <view wx:if="{{page === 'fill'}}">
    <view class="back-bar" bindtap="onBackList">
      <text>← 返回古诗列表</text>
    </view>

    <view class="poem-card">
      <view class="poem-header">
        <text class="poem-card-title">{{currentPoem.title}}</text>
        <text class="poem-card-author">〔{{currentPoem.dynasty}}〕{{currentPoem.author}}</text>
      </view>

      <view class="fill-lines">
        <view class="fill-line" wx:for="{{fillBlanks}}" wx:key="index">
          <text class="fill-blank-text">{{item.blank}}</text>
          <input class="fill-input" placeholder="填入关键字" value="{{userInputs[index]}}"
                 data-index="{{index}}" bindinput="onFillInput" />
        </view>
      </view>

      <button class="btn-primary" style="background-color: #45B058; margin-top: 24rpx;" bindtap="onSubmitFill">提交答案</button>
    </view>
  </view>

  <!-- 结果页 -->
  <view wx:if="{{page === 'result'}}">
    <view class="result-emoji">
      <text wx:if="{{resultSummary.accuracy >= 90}}">🎉</text>
      <text wx:elif="{{resultSummary.accuracy >= 70}}">💪</text>
      <text wx:else>📚</text>
    </view>
    <text class="result-title" wx:if="{{resultSummary.accuracy >= 90}}">默写完成！太棒了！</text>
    <text class="result-title" wx:elif="{{resultSummary.accuracy >= 70}}">默写完成！继续加油！</text>
    <text class="result-title" wx:else>默写完成！多背几遍哦！</text>

    <view class="result-stats">
      <view class="stat-item">
        <text class="stat-value">{{resultSummary.total}}</text>
        <text class="stat-label">总空数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value" style="color: #27AE60;">{{resultSummary.correct}}</text>
        <text class="stat-label">正确</text>
      </view>
      <view class="stat-item">
        <text class="stat-value" style="color: #E74C3C;">{{resultSummary.wrong}}</text>
        <text class="stat-label">错误</text>
      </view>
    </view>

    <view class="result-detail">
      <view class="detail-row">
        <text class="detail-label">正确率</text>
        <view class="detail-bar-wrap">
          <view class="detail-bar" style="width: {{resultSummary.accuracy}}%; background-color: {{resultSummary.accuracy >= 80 ? '#27AE60' : resultSummary.accuracy >= 60 ? '#F39C12' : '#E74C3C'}};"></view>
        </view>
        <text class="detail-value">{{resultSummary.accuracy}}%</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">古诗</text>
        <text class="detail-value">《{{resultSummary.title}}》</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">作者</text>
        <text class="detail-value">〔{{resultSummary.dynasty}}〕{{resultSummary.author}}</text>
      </view>
    </view>

    <view class="btn-group">
      <button class="btn-primary" style="background-color: #45B058;" bindtap="onRetry">再练一遍</button>
      <button class="btn-primary" style="background-color: #3498DB;" bindtap="onNextPoem">下一首</button>
      <button class="btn-secondary" bindtap="onBackList">返回列表</button>
    </view>
  </view>
</view>
