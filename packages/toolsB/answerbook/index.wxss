.container { padding: 24rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.tool-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.tool-header-title { font-size: 40rpx; font-weight: bold; color: #1a1a1a; }
.tool-header-fav { font-size: 44rpx; padding: 8rpx; }

.question-section { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 28rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,.06); text-align: center; }
.question-hint { font-size: 28rpx; color: #999; margin-bottom: 24rpx; }
.question-input-wrap { position: relative; margin-bottom: 28rpx; }
.question-input { width: 100%; height: 180rpx; background: #f8f8f8; border-radius: 18rpx; padding: 26rpx; font-size: 30rpx; box-sizing: border-box; line-height: 1.5; }
.char-count { position: absolute; right: 16rpx; bottom: 10rpx; font-size: 22rpx; color: #ccc; }

.ask-btn { background: linear-gradient(135deg, #6B5CE7, #8B7CF7); color: #fff; font-size: 32rpx; font-weight: 600; padding: 24rpx 0; border-radius: 50rpx; }
.btn-disabled { opacity: .6; }

.flip-animation { text-align: center; padding: 60rpx 0; }
.flip-book { display: flex; justify-content: center; gap: 16rpx; margin-bottom: 24rpx; }
.flip-page { width: 80rpx; height: 100rpx; background: linear-gradient(135deg, #6B5CE7, #8B7CF7); border-radius: 10rpx; animation: flipAnim 1.2s ease-in-out infinite; }
.flip-page:nth-child(2) { animation-delay: .2s; }
.flip-page:nth-child(3) { animation-delay: .4s; }
@keyframes flipAnim {
  0%, 100% { transform: rotateY(0deg); opacity: 1; }
  50% { transform: rotateY(180deg); opacity: .3; }
}
.flip-text { font-size: 28rpx; color: #6B5CE7; }

.answer-section { text-align: center; margin-bottom: 28rpx; }
.answer-card { background: linear-gradient(135deg, #6B5CE7, #8B7CF7); border-radius: 28rpx; padding: 60rpx 40rpx; color: #fff; margin-bottom: 24rpx; }
.answer-emoji { font-size: 80rpx; display: block; margin-bottom: 24rpx; }
.answer-text { font-size: 36rpx; font-weight: bold; line-height: 1.6; display: block; margin-bottom: 24rpx; }
.answer-question { font-size: 26rpx; opacity: .7; }

.reset-btn { font-size: 28rpx; color: #6B5CE7; padding: 16rpx 0; }

.history-section { background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,.06); }
.history-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.history-title { font-size: 30rpx; font-weight: bold; color: #333; }
.history-clear { font-size: 26rpx; color: #999; }

.history-list { }
.history-item { border-bottom: 1rpx solid #f5f5f5; padding: 18rpx 0; }
.history-item:last-child { border-bottom: none; }
.history-q { font-size: 26rpx; color: #333; margin-bottom: 6rpx; }
.history-a { font-size: 26rpx; color: #6B5CE7; font-weight: 600; margin-bottom: 4rpx; }
.history-time { font-size: 22rpx; color: #ccc; }
