<view class="page">
  <!-- 设置 -->
  <block wx:if="{{phase==='setup'}}">
    <view class="hero">🪨 Nim游戏</view>
    <view class="howto">多堆石子轮流拿，每次从一堆取任意颗（或变体规则），<text class="em">拿最后一颗者赢</text>（可切 misère 输）。正常版看「Nim和」——把它凑成 0 就掌握必胜节奏！</view>

    <view class="sec-label">选择难度</view>
    <view class="preset-row">
      <view wx:for="{{presets}}" wx:key="id" class="preset {{selectedPreset===item.id?'on':''}}" data-p="{{item.id}}" bindtap="selectPreset">
        <view class="preset-name">{{item.name}}</view>
      </view>
    </view>

    <view class="sec-label">堆数与上限</view>
    <view class="stepper">
      <view class="st-label">堆数</view>
      <view class="st-ctrl">
        <view class="st-btn" bindtap="decHeap">−</view>
        <view class="st-val">{{heapCount}}</view>
        <view class="st-btn" bindtap="incHeap">＋</view>
      </view>
    </view>
    <view class="stepper">
      <view class="st-label">每堆上限</view>
      <view class="st-ctrl">
        <view class="st-btn" bindtap="decMax">−</view>
        <view class="st-val">{{maxHeap}}</view>
        <view class="st-btn" bindtap="incMax">＋</view>
      </view>
    </view>

    <view class="sec-label">拿取规则</view>
    <view class="seg">
      <view class="seg-item {{variant==='standard'?'on':''}}" data-v="standard" bindtap="selectVariant">单堆自由</view>
      <view class="seg-item {{variant==='limitK'?'on':''}}" data-v="limitK" bindtap="selectVariant">限拿K颗</view>
      <view class="seg-item {{variant==='multiM'?'on':''}}" data-v="multiM" bindtap="selectVariant">多堆各1</view>
    </view>

    <view wx:if="{{variant==='limitK'}}" class="stepper">
      <view class="st-label">最多拿K</view>
      <view class="st-ctrl">
        <view class="st-btn" bindtap="decK">−</view>
        <view class="st-val">{{kVal}}</view>
        <view class="st-btn" bindtap="incK">＋</view>
      </view>
    </view>
    <view wx:if="{{variant==='multiM'}}" class="stepper">
      <view class="st-label">最多堆数M</view>
      <view class="st-ctrl">
        <view class="st-btn" bindtap="decM">−</view>
        <view class="st-val">{{mVal}}</view>
        <view class="st-btn" bindtap="incM">＋</view>
      </view>
    </view>

    <view class="toggle-row" bindtap="toggleLastWin">
      <view class="tg-label">拿最后一粒</view>
      <view class="tg-val {{lastWin?'on':'off'}}">{{lastWin?'赢 ✅':'输 misère 🔁'}}</view>
    </view>
    <view class="toggle-row" bindtap="toggleRandom">
      <view class="tg-label">随机事件（趣味）</view>
      <view class="tg-val {{randomOn?'on':'off'}}">{{randomOn?'开 🎲':'关'}}</view>
    </view>

    <view class="sec-label">提示档位</view>
    <view class="seg">
      <view class="seg-item {{hintLevel==='none'?'on':''}}" data-h="none" bindtap="selectHint">无</view>
      <view class="seg-item {{hintLevel==='nim'?'on':''}}" data-h="nim" bindtap="selectHint">Nim和</view>
      <view class="seg-item {{hintLevel==='move'?'on':''}}" data-h="move" bindtap="selectHint">走法</view>
      <view class="seg-item {{hintLevel==='full'?'on':''}}" data-h="full" bindtap="selectHint">全开</view>
    </view>

    <view wx:if="{{selectedPreset==='custom'}}" class="custom-extra">
      <view class="toggle-row" bindtap="toggleManual">
        <view class="tg-label">手动设置每堆数量</view>
        <view class="tg-val {{manual?'on':'off'}}">{{manual?'开 ✏️':'关'}}</view>
      </view>
      <view wx:if="{{manual}}" class="manual-row">
        <view wx:for="{{manualCounts}}" wx:key="index" class="manual-item">
          <view class="mi-label">堆{{index+1}}</view>
          <view class="mi-ctrl">
            <view class="st-btn" data-i="{{index}}" data-d="-1" bindtap="adjustManual">−</view>
            <view class="st-val">{{item}}</view>
            <view class="st-btn" data-i="{{index}}" data-d="1" bindtap="adjustManual">＋</view>
          </view>
        </view>
      </view>
    </view>

    <view class="btn-primary" bindtap="onStart">开始游戏 🎮</view>
  </block>

  <!-- 游戏中 -->
  <block wx:elif="{{phase==='playing'}}">
    <view class="topinfo">
      <view class="remain">剩余 <text class="remain-num">{{remaining}}</text></view>
      <view class="rule">{{lastWin?'拿最后赢':'拿最后输'}} · {{variant==='limitK'?'最多拿'+kVal:'单堆自由'}}{{variant==='multiM'?' · 最多'+mVal+'堆':''}}</view>
    </view>
    <view wx:if="{{showNim}}" class="nimsum">Nim和 = {{nimSumVal}}</view>
    <view wx:if="{{timing}}" class="timer">⏱ {{elapsedText}}</view>

    <view class="heaps">
      <view wx:for="{{heaps}}" wx:key="id" class="heap {{item.selected?'sel':''}} {{item.count === 0?'empty':''}}" data-i="{{index}}" bindtap="onHeapTap">
        <view class="heap-head"><text class="heap-name">堆{{index+1}}</text><text class="heap-cnt">{{item.count}}</text></view>
        <view class="stones">
          <view wx:for="{{item.stones}}" wx:for-item="s" wx:key="id" class="stone {{s.taken?'taken':''}} {{s.removing?'removing':''}}"></view>
        </view>
      </view>
    </view>

    <view class="status">{{status}}</view>

    <view wx:if="{{selectedHeap>=0 && variant!=='multiM'}}" class="take-row">
      <view wx:for="{{takeBtns}}" wx:key="n" class="take-btn" data-n="{{item.n}}" bindtap="take">{{item.n}}</view>
    </view>
    <view wx:if="{{variant==='multiM'}}" class="confirm-row">
      <view class="confirm-tip">已选 {{selectedHeapsLen}}/{{mVal}} 堆</view>
      <view class="btn-primary inline" bindtap="confirmMulti">确认拿取</view>
    </view>

    <view class="turn turn-{{current}}">👉 玩家{{current}} 回合</view>

    <view wx:if="{{showHintPanel && hintLevelEffective!=='none'}}" class="hint">
      {{hintText}} <text wx:if="{{hintWin}}">· 必胜 ✅</text>
    </view>

    <view wx:if="{{showHistory && history.length>0}}" class="history">
      <view wx:for="{{history}}" wx:key="index" class="hist-item"><text class="hist-who">玩家{{item.who}}</text> {{item.text}}</view>
    </view>

    <view class="bottom-bar">
      <view wx:if="{{hintLevelEffective!=='none'}}" class="mini-btn" bindtap="toggleHintPanel">{{showHintPanel?'隐藏提示':'提示 💡'}}</view>
      <view class="mini-btn {{undoLeft>0?'':'disabled'}}" bindtap="undo">悔棋 ({{undoLeft}})</view>
      <view class="mini-btn" bindtap="toggleHistory">{{showHistory?'隐藏记录':'记录 📜'}}</view>
      <view class="mini-btn" bindtap="backSetup">设置</view>
    </view>
  </block>

  <!-- 结果 -->
  <block wx:elif="{{phase==='result'}}">
    <view class="hero result-hero">{{winnerText}}</view>
    <view class="summary">{{summary}}</view>
    <view class="summary">{{modeText}}</view>
    <view class="btn-row">
      <view class="btn-ghost" bindtap="backSetup">返回设置</view>
      <view class="btn-primary inline" bindtap="replay">再来一局</view>
    </view>
  </block>
</view>
