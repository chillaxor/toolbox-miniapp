.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #F5F5F5;
}

.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.tool-header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.tool-header-fav {
  font-size: 44rpx;
}

/* 难度选择 */
.level-bar {
  display: flex;
  gap: 16rpx;
  margin: 16rpx 0;
}

.level-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #FFFFFF;
  border: 2rpx solid #E0E0E0;
  transition: all 0.2s;
}

.level-active {
  color: #FFFFFF;
  background: #2196F3;
  border-color: #2196F3;
  font-weight: bold;
}

/* 状态栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin: 16rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 互动画布 */
.canvas-wrapper {
  width: 100%;
  aspect-ratio: 1;
  margin: 16rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: #FAFAFA;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.game-canvas {
  width: 100%;
  height: 100%;
}

/* 提示 */
.hint-bar {
  text-align: center;
  padding: 16rpx 0;
}

.hint-text {
  font-size: 26rpx;
  color: #888;
}

/* 操作按钮 */
.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-action {
  flex: 1;
  font-size: 26rpx;
  padding: 20rpx 0;
  border-radius: 16rpx;
  color: #FFFFFF;
  line-height: 1.2;
}

.btn-hint {
  background: #FF9800;
}

.btn-retry {
  background: #607D8B;
}

.btn-next {
  background: #4CAF50;
}

.btn-restart {
  background: #2196F3;
}

/* 完成弹窗 */
.complete-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.complete-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  width: 80%;
  max-width: 560rpx;
}

.complete-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.complete-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.complete-desc {
  font-size: 28rpx;
  color: #888;
  display: block;
}

.btn-primary {
  background: #4CAF50;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
}
