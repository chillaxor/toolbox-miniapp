.btn-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.btn-small {
  padding: 12rpx 32rpx;
  background-color: var(--color-border);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--color-secondary);
}

.btn-small:active {
  opacity: 0.7;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.stat-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #45B058;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-hint);
  margin-top: 8rpx;
}
