/* 覆盖默认 .container 内边距 */
.container {
  padding: 0;
  margin: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background: #000;
}

/* 相机外层 — 用 transform scale 做数码变焦 */
.camera-wrapper {
  width: 100vw;
  height: 100vh;
  transform-origin: center center;
  transition: transform 0.15s ease-out;
}

.camera {
  width: 100%;
  height: 100%;
}

/* ---------- 冻结画面覆盖层 ---------- */
.frozen-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 10;
  background: #000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.frozen-image {
  width: 100vw;
  height: 100vh;
  transform-origin: center center;
}

.resume-btn {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 16rpx 64rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  color: #fff;
  font-size: 30rpx;
  z-index: 11;
}

/* ---------- 底部浮动控制栏（毛玻璃） ---------- */
.control-bar {
  position: fixed;
  bottom: 260rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 60rpx;
  padding: 20rpx 48rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  z-index: 5;
}

.btn-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.btn-circle:active {
  background: rgba(255, 255, 255, 0.35);
}

.btn-capture {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.btn-icon {
  font-size: 40rpx;
  color: #fff;
}

/* ---------- 缩放滑条 ---------- */
.zoom-bar {
  position: fixed;
  bottom: 140rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 5;
}

.zoom-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  flex-shrink: 0;
}

.zoom-slider {
  flex: 1;
}
