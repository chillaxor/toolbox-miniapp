.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 90rpx;
  box-sizing: border-box;
  background: linear-gradient(165deg, #EAF3FF 0%, #F6EEFF 100%);
}

/* ---------- 通用按钮 ---------- */
.btn {
  height: 90rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 31rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  transition: transform 0.12s ease;
}
.btn:active { transform: scale(0.97); }
.btn.big { height: 96rpx; font-size: 33rpx; }
.btn.primary {
  background: linear-gradient(135deg, #5B8DEF, #7C5BE0);
  color: #fff;
  box-shadow: 0 12rpx 26rpx rgba(91, 141, 239, 0.35);
}
.btn.ghost {
  background: #fff;
  color: #6f57c8;
  border: 3rpx solid #E6DEF8;
  font-size: 29rpx;
}

/* ---------- 案件卡片（通用） ---------- */
.case-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(120, 100, 180, 0.1);
}

/* ---------- 案件简介 ---------- */
.intro {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 70rpx 20rpx 50rpx;
  text-align: center;
}
.intro-badge {
  font-size: 26rpx;
  font-weight: 700;
  color: #6f57c8;
  background: #fff;
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 18rpx rgba(120, 100, 180, 0.12);
  margin-bottom: 34rpx;
}
.intro-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #34295a;
  line-height: 1.3;
}
.case-scene {
  font-size: 29rpx;
  color: #5f5878;
  line-height: 1.75;
}
.intro .case-card { margin: 30rpx 0 36rpx; }
.suspect-preview {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 18rpx 26rpx;
  margin-bottom: 30rpx;
}
.sp-item { display: flex; flex-direction: column; align-items: center; }
.sp-emoji { font-size: 64rpx; line-height: 1; }
.sp-name { font-size: 23rpx; color: #6b6480; margin-top: 6rpx; }
.intro-tip {
  font-size: 26rpx;
  color: #8a83a0;
  margin-bottom: 44rpx;
}

/* ---------- 侦查顶栏 ---------- */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(120, 100, 180, 0.1);
}
.topbar-left { display: flex; align-items: center; gap: 14rpx; min-width: 0; }
.topbar-emoji { font-size: 42rpx; }
.case-title {
  font-size: 33rpx;
  font-weight: 800;
  color: #34295a;
}
.badge-count {
  font-size: 29rpx;
  color: #C9A227;
  font-weight: 700;
  flex-shrink: 0;
}

.scene-card { margin-bottom: 22rpx; }

/* ---------- 区块 ---------- */
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(120, 100, 180, 0.1);
}
.sec-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.sec-title {
  font-size: 31rpx;
  font-weight: 800;
  color: #4a4068;
}
.sec-prog {
  font-size: 24rpx;
  color: #9a93ad;
  font-weight: 600;
}

/* ---------- 线索 ---------- */
.clue-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}
.clue-card {
  width: calc(50% - 9rpx);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 22rpx;
  background: #F4F2FB;
  border: 3rpx solid #ECE8F7;
  transition: all 0.2s ease;
}
.clue-card.found {
  background: #F7F5FC;
  border-color: #E2DBF2;
}
.clue-card.done {
  background: #EBF8EF;
  border-color: #C7EBD2;
}
.clue-card.active {
  background: #FFF7E0;
  border-color: #FFCE58;
  box-shadow: 0 8rpx 20rpx rgba(255, 206, 88, 0.38);
}
.clue-icon { font-size: 48rpx; line-height: 1; flex-shrink: 0; }
.clue-icon.q { font-size: 60rpx; opacity: 0.7; }
.clue-body { display: flex; flex-direction: column; gap: 8rpx; min-width: 0; flex: 1; }
.clue-text {
  font-size: 27rpx;
  color: #443d5c;
  line-height: 1.5;
}
.clue-text.dim {
  font-size: 31rpx;
  font-weight: 700;
  color: #7C5BE0;
}
.clue-tag {
  font-size: 21rpx;
  font-weight: 700;
  padding: 3rpx 12rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}
.clue-tag.ok { background: #D6F0DE; color: #2e9e5b; }
.clue-tag.thinking { background: #FFF0C2; color: #b07c00; }
.clue-tag.todo { background: #ECE6FA; color: #7C5BE0; }

/* ---------- 嫌疑圈 ---------- */
.suspect-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}
.suspect {
  position: relative;
  width: calc(33.33% - 12rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 26rpx 0;
  border-radius: 22rpx;
  background: #EEF4FF;
  border: 3rpx solid #DCE8FF;
  transition: all 0.2s ease;
}
.suspect.out {
  background: #F5F3F9;
  border-color: #ECEAF2;
  opacity: 0.42;
}
.suspect.out .s-emoji { filter: grayscale(1); }
.suspect.pick {
  background: #FFF5D9;
  border-color: #FFCE58;
  box-shadow: 0 8rpx 20rpx rgba(255, 206, 88, 0.42);
  transform: scale(1.05);
}
.suspect.sel {
  background: #E6F1FF;
  border-color: #5B8DEF;
  box-shadow: 0 8rpx 20rpx rgba(91, 141, 239, 0.42);
  transform: scale(1.05);
}
.s-emoji { font-size: 66rpx; line-height: 1; }
.s-name { font-size: 26rpx; color: #443d5c; margin-top: 10rpx; font-weight: 600; }
.s-cross {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  font-size: 32rpx;
}
.s-pick {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  font-size: 23rpx;
  color: #C9A227;
  font-weight: 700;
}
.s-sel {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  font-size: 30rpx;
  color: #5B8DEF;
  font-weight: 800;
}

/* ---------- 推理提示 / 操作 ---------- */
.reason-bar {
  background: #FFF7E0;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 22rpx;
  border: 3rpx solid #FFE39B;
}
.reason-tip {
  display: block;
  text-align: center;
  font-size: 27rpx;
  font-weight: 700;
  color: #b07c00;
  margin-bottom: 18rpx;
}
.reason-actions {
  display: flex;
  gap: 16rpx;
}
.reason-actions .btn { flex: 1; height: 82rpx; font-size: 29rpx; }

.hint {
  background: #FFF3D6;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  font-size: 27rpx;
  color: #9a6b00;
  text-align: center;
  margin-bottom: 22rpx;
}
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 6rpx;
}
.actions-row {
  display: flex;
  gap: 16rpx;
}
.actions-row .btn { flex: 1; }

/* ---------- 破案 ---------- */
.win {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 90rpx 20rpx 50rpx;
  text-align: center;
}
.win-medal { font-size: 140rpx; margin-bottom: 24rpx; }
.win-title {
  font-size: 50rpx;
  font-weight: 800;
  color: #34295a;
}
.win-card { margin: 30rpx 0 18rpx; }
.win-sub {
  font-size: 30rpx;
  color: #5f5878;
  line-height: 1.6;
}
.win-badges {
  font-size: 27rpx;
  color: #C9A227;
  font-weight: 700;
  margin-bottom: 44rpx;
}
