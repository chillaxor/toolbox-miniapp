<view class="page">

  <!-- ============ 案件简介 ============ -->
  <block wx:if="{{phase==='intro'}}">
    <view class="intro">
      <view class="intro-badge">🕵️ 小小侦探</view>
      <text class="intro-title">{{cur.title}}</text>
      <view class="case-card">
        <text class="case-scene">{{cur.scene}}</text>
      </view>
      <view class="suspect-preview">
        <view wx:for="{{cur.suspects}}" wx:key="name" class="sp-item">
          <text class="sp-emoji">{{item.emoji}}</text>
          <text class="sp-name">{{item.name}}</text>
        </view>
      </view>
      <view class="intro-tip">🔍 看线索 · 推理谁被排除 · 剩下的就是真凶</view>
      <view class="btn primary big" bindtap="beginInvestigate">开始侦查</view>
    </view>
  </block>

  <!-- ============ 侦查 ============ -->
  <block wx:elif="{{phase==='investigate'}}">
    <view class="topbar">
      <view class="topbar-left">
        <text class="topbar-emoji">🕵️</text>
        <text class="case-title">{{cur.title}}</text>
      </view>
      <text class="badge-count">🎖️ {{badges}}</text>
    </view>

    <view class="case-card scene-card">
      <text class="case-scene">{{cur.scene}}</text>
    </view>

    <view class="section">
      <view class="sec-head">
        <text class="sec-title">🔎 现场线索</text>
        <text class="sec-prog">已推理 {{foundCount}}/{{totalClues}}</text>
      </view>
      <view class="clue-grid">
        <view wx:for="{{cur.clues}}" wx:key="text"
          class="clue-card {{item.found ? 'found' : ''}} {{item.resolved ? 'done' : ''}} {{pendingClue===index ? 'active' : ''}}"
          data-idx="{{index}}" bindtap="tapClue">
          <block wx:if="{{item.found}}">
            <text class="clue-icon">{{item.icon}}</text>
            <view class="clue-body">
              <text class="clue-text">{{item.text}}</text>
              <text wx:if="{{item.resolved}}" class="clue-tag ok">✓ 已推理</text>
              <text wx:elif="{{pendingClue===index}}" class="clue-tag thinking">🤔 在想排除谁…</text>
              <text wx:else class="clue-tag todo">点我推理排除谁</text>
            </view>
          </block>
          <block wx:else>
            <text class="clue-icon q">❓</text>
            <text class="clue-text dim">点击搜查</text>
          </block>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="sec-head">
        <text class="sec-title">🎯 嫌疑圈</text>
        <text class="sec-prog">剩余 {{remaining.length}} 人</text>
      </view>

      <view wx:if="{{pendingClue>=0}}" class="reason-bar">
        <text class="reason-tip">这条线索能排除谁？点对应的小伙伴</text>
        <view class="reason-actions">
          <view class="btn primary" bindtap="confirmEliminate">就这些 →</view>
          <view class="btn ghost" bindtap="closeReasoning">先跳过</view>
        </view>
      </view>

      <view class="suspect-grid">
        <view wx:for="{{cur.suspects}}" wx:key="name"
          class="suspect {{states[index]}}"
          data-idx="{{index}}" bindtap="tapSuspect">
          <text class="s-emoji">{{item.emoji}}</text>
          <text class="s-name">{{item.name}}</text>
          <text wx:if="{{states[index]==='out'}}" class="s-cross">❌</text>
          <text wx:if="{{states[index]==='pick'}}" class="s-pick">指认</text>
          <text wx:if="{{states[index]==='sel'}}" class="s-sel">✓</text>
        </view>
      </view>
    </view>

    <view wx:if="{{wrongHint}}" class="hint">{{wrongHint}}</view>

    <view class="actions">
      <view wx:if="{{!accusing}}" class="btn primary big" bindtap="accuse">👉 指认凶手</view>
      <view wx:else class="btn ghost big" bindtap="closeAccuse">← 返回侦查</view>
      <view class="actions-row">
        <view class="btn ghost" bindtap="resetCase">↺ 重新侦查</view>
        <view class="btn ghost" bindtap="nextCase">🔁 换一案</view>
      </view>
    </view>
  </block>

  <!-- ============ 破案 ============ -->
  <block wx:elif="{{phase==='win'}}">
    <view class="win">
      <view class="win-medal">🎖️</view>
      <text class="win-title">破案成功！</text>
      <view class="case-card win-card">
        <text class="win-sub">真正的"凶手"是 {{cur.suspects[cur.culprit].emoji}} {{cur.suspects[cur.culprit].name}}</text>
      </view>
      <text class="win-badges">你已获得 {{badges}} 枚侦探徽章</text>
      <view class="btn primary big" bindtap="nextCase">🔁 下一个案件</view>
      <view class="btn ghost big" bindtap="resetCase">↺ 再查一次</view>
    </view>
  </block>

</view>
