<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">乘法口诀表</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 九九乘法表浏览 -->
  <view wx:if="{{page === 'table'}}">
    <view class="mode-bar">
      <view class="mode-btn {{mode === 'browse' ? 'mode-active' : ''}}" data-mode="browse" bindtap="onSwitchMode">
        <text>📖 背诵</text>
      </view>
      <view class="mode-btn {{mode === 'quiz' ? 'mode-active' : ''}}" data-mode="quiz" bindtap="onSwitchMode">
        <text>🧩 抽查</text>
      </view>
      <view class="mode-btn {{mode === 'speed' ? 'mode-active' : ''}}" data-mode="speed" bindtap="onSwitchMode">
        <text>⚡ 速度测试</text>
      </view>
    </view>

    <view class="card">
      <text class="card-title">九九乘法表</text>
      <view class="table-grid">
        <view class="table-row" wx:for="{{table}}" wx:key="row">
          <view class="table-cell {{highlightedRow === item.row ? 'cell-highlight' : ''}}"
                wx:for="{{item.items}}" wx:for-item="cell" wx:key="text"
                data-row="{{cell.b}}" data-col="{{cell.a}}" bindtap="onCellTap">
            <text class="cell-text">{{cell.a}}×{{cell.b}}={{cell.result}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card tips-card">
      <text class="card-title">💡 使用提示</text>
      <text class="tip-text">• 点击任意算式可放大查看</text>
      <text class="tip-text">• 「抽查」模式随机出题检验掌握程度</text>
      <text class="tip-text">• 「速度测试」60秒内答对尽可能多题</text>
    </view>
  </view>

  <!-- 答题页 -->
  <view wx:if="{{page === 'quiz'}}">
    <view class="status-bar">
      <view class="status-item">
        <text class="status-label">第</text>
        <text class="status-value">{{questionNum}}</text>
        <text class="status-label">题</text>
      </view>
      <view class="status-item" wx:if="{{mode === 'speed'}}">
        <text class="status-label">剩余</text>
        <text class="status-value {{timeLeft <= 10 ? 'time-warning' : ''}}">{{timeLeft}}</text>
        <text class="status-label">秒</text>
      </view>
      <view class="status-item">
        <text class="status-label">对</text>
        <text class="status-value status-correct">{{correctNum}}</text>
      </view>
      <view class="status-item">
        <text class="status-label">错</text>
        <text class="status-value status-wrong">{{wrongNum}}</text>
      </view>
    </view>

    <view class="card question-card" wx:if="{{question}}">
      <view class="question-expression">
        <text class="question-num">{{question.a}}</text>
        <text class="question-op">×</text>
        <text class="question-num">{{question.b}}</text>
        <text class="question-eq">=</text>
      </view>

      <view class="feedback {{isCorrect === true ? 'feedback-correct' : ''}} {{isCorrect === false ? 'feedback-wrong' : ''}}" wx:if="{{isCorrect !== null}}">
        <text wx:if="{{isCorrect}}" class="feedback-icon">✅ 正确！</text>
        <text wx:if="{{isCorrect === false}}" class="feedback-icon">❌ 答案是 {{question.answer}}</text>
      </view>
    </view>

    <view class="answer-area">
      <input class="answer-input" type="number" placeholder="输入答案" value="{{userAnswer}}" bindinput="onAnswerInput" bindconfirm="onSubmit" focus="{{isCorrect === null}}" />
      <button class="btn-primary btn-green" bindtap="onSubmit">确定</button>
    </view>

    <view class="finish-area">
      <button class="btn-finish" bindtap="onFinish">结束练习</button>
    </view>
  </view>

  <!-- 结果页 -->
  <view wx:if="{{page === 'result'}}">
    <view class="result-box">
      <view class="result-emoji">
        <text wx:if="{{resultSummary.accuracy >= 90}}">🎉</text>
        <text wx:if="{{resultSummary.accuracy >= 70 && resultSummary.accuracy < 90}}">💪</text>
        <text wx:if="{{resultSummary.accuracy < 70}}">📚</text>
      </view>
      <text class="result-title" wx:if="{{resultSummary.accuracy >= 90}}">太棒了！</text>
      <text class="result-title" wx:if="{{resultSummary.accuracy >= 70 && resultSummary.accuracy < 90}}">继续加油！</text>
      <text class="result-title" wx:if="{{resultSummary.accuracy < 70}}">多多练习哦！</text>

      <view class="result-stats">
        <view class="stat-item">
          <text class="stat-value">{{resultSummary.total}}</text>
          <text class="stat-label">总题数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value stat-correct">{{resultSummary.correct}}</text>
          <text class="stat-label">答对</text>
        </view>
        <view class="stat-item">
          <text class="stat-value stat-wrong">{{resultSummary.wrong}}</text>
          <text class="stat-label">答错</text>
        </view>
      </view>

      <view class="result-detail">
        <view class="detail-row">
          <text class="detail-label">正确率</text>
          <view class="detail-bar-wrap">
            <view class="detail-bar" style="{{detailBarStyle}}"></view>
          </view>
          <text class="detail-value">{{resultSummary.accuracy}}%</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">模式</text>
          <text class="detail-value">{{resultSummary.mode}}</text>
        </view>
      </view>
    </view>

    <view class="card wrong-card" wx:if="{{wrongList.length > 0}}">
      <text class="card-title">错题回顾</text>
      <view class="wrong-list">
        <view class="wrong-item" wx:for="{{wrongList}}" wx:key="index">
          <text class="wrong-expr">{{item.expression}} =</text>
          <text class="wrong-your">{{item.yourAnswer}}</text>
          <text class="wrong-correct">✓ {{item.correctAnswer}}</text>
        </view>
      </view>
    </view>

    <view class="btn-group">
      <button class="btn-primary btn-green" bindtap="onRetry">再来一轮</button>
      <button class="btn-secondary" bindtap="onBackTable">返回口诀表</button>
    </view>
  </view>
</view>
