.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.tool-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tool-header-fav {
  font-size: 44rpx;
  padding: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  display: block;
}

.mode-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background-color: #f0f0f0;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.mode-btn.mode-active {
  background-color: #45B058;
  color: #fff;
  font-weight: 600;
}

.table-grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.table-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.table-cell {
  padding: 12rpx 8rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  text-align: center;
  min-width: 0;
  flex-shrink: 0;
}

.table-cell.cell-highlight {
  background-color: #45B058;
}

.table-cell.cell-highlight .cell-text {
  color: #fff;
}

.cell-text {
  font-size: 20rpx;
  color: #333;
  white-space: nowrap;
}

.tips-card {
  margin-top: 24rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.status-item {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.status-label {
  font-size: 24rpx;
  color: #999;
}

.status-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #45B058;
  min-width: 48rpx;
  text-align: center;
}

.status-correct {
  color: #27AE60;
}

.status-wrong {
  color: #E74C3C;
}

.time-warning {
  color: #E74C3C;
}

.question-card {
  text-align: center;
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
}

.question-expression {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
}

.question-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #2C3E50;
}

.question-op {
  font-size: 56rpx;
  font-weight: 700;
  color: #45B058;
}

.question-eq {
  font-size: 56rpx;
  font-weight: 700;
  color: #999;
}

.feedback {
  margin-top: 30rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.feedback-correct {
  background-color: rgba(39, 174, 96, 0.1);
  color: #27AE60;
}

.feedback-wrong {
  background-color: rgba(231, 76, 60, 0.1);
  color: #E74C3C;
}

.feedback-icon {
  font-size: 32rpx;
}

.btn-green {
  background-color: #45B058;
}

.answer-area {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  align-items: center;
}

.answer-input {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #ECEFF1;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 36rpx;
  font-weight: 600;
  text-align: center;
  background-color: #fff;
}

.answer-area .btn-primary {
  width: 180rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  margin: 0;
}

.finish-area {
  text-align: center;
}

.btn-finish {
  background: none;
  border: none;
  color: #999;
  font-size: 28rpx;
  padding: 16rpx;
}

.btn-finish::after {
  border: none;
}

.result-emoji {
  text-align: center;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 32rpx;
  display: block;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #2C3E50;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-correct {
  color: #27AE60;
}

.stat-wrong {
  color: #E74C3C;
}

.result-detail {
  padding-top: 24rpx;
  border-top: 1rpx solid #ECEFF1;
}

.detail-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 16rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
}

.detail-bar-wrap {
  flex: 1;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.detail-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  min-width: 80rpx;
  text-align: right;
}

.wrong-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.wrong-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-expr {
  font-size: 28rpx;
  color: #2C3E50;
  flex: 1;
}

.wrong-card {
  margin-top: 24rpx;
}

.wrong-your {
  font-size: 28rpx;
  font-weight: 600;
  color: #E74C3C;
  text-decoration: line-through;
}

.wrong-correct {
  font-size: 28rpx;
  font-weight: 600;
  color: #27AE60;
}

.btn-group {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #f0f0f0;
  color: #666;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-secondary::after {
  border: none;
}
