<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">万年历</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 月份切换 -->
  <view class="card">
    <view class="month-nav">
      <view class="nav-btn" bindtap="onPrevMonth">
        <text class="nav-arrow">◀</text>
      </view>
      <view class="month-title">
        <text class="month-text">{{year}}年{{month}}月</text>
      </view>
      <view class="nav-btn" bindtap="onNextMonth">
        <text class="nav-arrow">▶</text>
      </view>
    </view>
    <view class="today-btn" bindtap="onBackToToday">
      <text style="color: #4ECDC4; font-size: 24rpx;">回到今天</text>
    </view>

    <!-- 日历网格 -->
    <calendar-grid grid="{{grid}}" bind:daytap="onDayTap" />
  </view>

  <!-- 选中日期详情 -->
  <view class="card" wx:if="{{selectedDay}}">
    <view class="detail-row">
      <text class="detail-label">公历</text>
      <text class="detail-value">{{selectedDay.year}}年{{selectedDay.month}}月{{selectedDay.date}}日</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">农历</text>
      <text class="detail-value">{{selectedDay.lunarMonth}}{{selectedDay.lunarDay}}</text>
    </view>
    <view class="detail-row" wx:if="{{selectedDay.zodiac}}">
      <text class="detail-label">生肖</text>
      <text class="detail-value">{{selectedDay.zodiac}}</text>
    </view>
    <view class="detail-row" wx:if="{{selectedDay.ganZhi}}">
      <text class="detail-label">干支</text>
      <text class="detail-value">{{selectedDay.ganZhi}}</text>
    </view>
    <view class="detail-row" wx:if="{{selectedDay.holiday}}">
      <text class="detail-label">节日</text>
      <text class="detail-value" style="color: #E74C3C;">{{selectedDay.holiday}}</text>
    </view>
  </view>
</view>
