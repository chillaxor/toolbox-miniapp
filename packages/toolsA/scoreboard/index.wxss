.page {
  min-height: 100vh;
  background: #f0f2f5;
  padding: 0 0 120rpx 0;
}

/* ========== Header ========== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.btn-add {
  background: #4A90D9;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-weight: 600;
}

.btn-reset {
  background: #fff;
  color: #999;
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid #ddd;
}

.player-count {
  font-size: 24rpx;
  color: #999;
  padding: 0 32rpx 16rpx;
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #666;
  font-weight: 600;
}

.empty-sub {
  font-size: 26rpx;
  color: #aaa;
  margin-top: 12rpx;
}

/* ========== Player Cards ========== */
.player-list {
  padding: 0 24rpx;
}

.player-card {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 32rpx 32rpx 32rpx 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  overflow: hidden;
  transition: box-shadow 0.2s;
}

.player-card.leader {
  border: 3rpx solid #f5a623;
  box-shadow: 0 4rpx 24rpx rgba(245, 166, 35, 0.25);
}

.color-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 12rpx;
  background: var(--player-color, #4A90D9);
  border-radius: 24rpx 0 0 24rpx;
}

.crown {
  position: absolute;
  top: -4rpx;
  right: 16rpx;
  font-size: 40rpx;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.player-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-score {
  font-size: 120rpx;
  font-weight: 800;
  color: var(--player-color, #4A90D9);
  line-height: 1.1;
  text-align: left;
  margin-top: 4rpx;
}

/* ========== Quick +/- Buttons ========== */
.quick-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-left: 20rpx;
}

.btn-plus,
.btn-minus {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.btn-plus {
  background: #50C878;
}

.btn-minus {
  background: #E85D5D;
}

.btn-remove {
  position: absolute;
  top: 8rpx;
  left: 16rpx;
  font-size: 32rpx;
  color: #ccc;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== Modal (Add Player) ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 580rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.modal-hint {
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
  margin-top: 16rpx;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.modal-btn.confirm {
  background: #4A90D9;
  color: #fff;
}

/* ========== Score Popup (Bottom Sheet) ========== */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.popup-sheet {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.popup-header {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
  position: relative;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-right: 16rpx;
}

.popup-score {
  font-size: 28rpx;
  color: #999;
}

.popup-close {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #ccc;
}

.popup-section {
  margin-bottom: 32rpx;
}

.popup-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.popup-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.popup-btn {
  min-width: 100rpx;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.popup-btn.add {
  background: #50C878;
}

.popup-btn.sub {
  background: #E85D5D;
}

.popup-btn.apply {
  background: #4A90D9;
  min-width: 120rpx;
}

.popup-custom {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.popup-input {
  flex: 1;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
}
