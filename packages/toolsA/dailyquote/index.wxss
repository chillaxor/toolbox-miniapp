.container {
  padding: 20rpx 30rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 10rpx;
}

.tool-header-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
}

.tool-header-fav {
  font-size: 40rpx;
}

/* 今日格言 */
.today-card {
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  backdrop-filter: blur(10px);
}

.today-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16rpx;
}

.today-content {
  font-size: 30rpx;
  color: #fff;
  line-height: 1.8;
  font-weight: 500;
}

.today-author {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
}

/* 分类标签 */
.category-bar {
  white-space: nowrap;
  padding: 10rpx 0;
}

.cat-btn {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.15);
}

.cat-active {
  background: #fff;
  color: #764ba2;
  font-weight: bold;
}

/* 名言卡片 */
.quote-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin: 24rpx 0;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
  position: relative;
}

.quote-tag {
  display: inline-block;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.quote-body {
  position: relative;
  padding: 10rpx 0;
}

.quote-mark-left {
  font-size: 80rpx;
  color: #667eea;
  opacity: 0.3;
  position: absolute;
  top: -20rpx;
  left: -10rpx;
  font-family: serif;
}

.quote-content {
  font-size: 34rpx;
  color: #333;
  line-height: 2;
  font-weight: 500;
  display: block;
  padding: 0 20rpx;
}

.quote-mark-right {
  font-size: 80rpx;
  color: #764ba2;
  opacity: 0.3;
  position: absolute;
  bottom: -40rpx;
  right: -10rpx;
  font-family: serif;
}

.quote-author {
  display: block;
  text-align: right;
  font-size: 26rpx;
  color: #999;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
}

/* 操作按钮 */
.quote-actions {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.quote-action {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.action-text {
  font-size: 22rpx;
  color: #999;
}

/* 收藏列表 */
.fav-section {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.fav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fav-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.fav-toggle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.fav-list {
  margin-top: 16rpx;
}

.fav-item {
  display: flex;
  align-items: flex-start;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.fav-item-body {
  flex: 1;
}

.fav-item-content {
  font-size: 26rpx;
  color: #fff;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fav-item-author {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 6rpx;
  display: block;
}

.fav-item-del {
  color: rgba(255,255,255,0.5);
  font-size: 28rpx;
  padding: 0 10rpx;
  margin-left: 16rpx;
}

/* 统计 */
.info-bar {
  text-align: center;
  margin-top: 30rpx;
  padding: 16rpx 0;
}

.info-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}
