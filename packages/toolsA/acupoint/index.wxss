.container { padding: 24rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.tool-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.tool-header-title { font-size: 40rpx; font-weight: bold; color: #1a1a1a; }
.tool-header-fav { font-size: 44rpx; padding: 8rpx; }

.search-bar { margin-bottom: 28rpx; }
.search-input { background: #fff; border-radius: 20rpx; padding: 26rpx 28rpx; font-size: 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,.06); line-height: 1.5; }

.parts-bar { white-space: nowrap; margin-bottom: 24rpx; }
.part-btn { display: inline-flex; flex-direction: column; align-items: center; padding: 18rpx 24rpx; background: #fff; border-radius: 18rpx; margin-right: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.05); }
.part-active { background: #45B058; color: #fff; }
.part-icon { font-size: 36rpx; margin-bottom: 6rpx; }
.part-name { font-size: 24rpx; }

.point-list { margin-bottom: 28rpx; }
.point-card { background: #fff; border-radius: 20rpx; margin-bottom: 16rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,.06); }
.point-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 28rpx; }
.point-name-row { display: flex; align-items: center; gap: 14rpx; }
.point-name { font-size: 30rpx; font-weight: bold; color: #1a1a1a; }
.point-code { font-size: 22rpx; color: #45B058; background: #D9F0DC; padding: 4rpx 14rpx; border-radius: 10rpx; }
.point-arrow { font-size: 22rpx; color: #ccc; }

.point-detail { padding: 0 28rpx 28rpx; border-top: 1rpx solid #f0f0f0; }
.detail-row { margin-top: 20rpx; }
.detail-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 6rpx; }
.detail-value { font-size: 27rpx; color: #333; line-height: 1.7; }

.result-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 18rpx; }
.empty-tip { text-align: center; color: #999; font-size: 28rpx; padding: 60rpx 0; }
