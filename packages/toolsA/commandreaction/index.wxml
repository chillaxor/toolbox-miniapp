<view class="page">
  <!-- 收藏 -->
  <view class="fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</view>

  <!-- ===== 开始页 ===== -->
  <block wx:if="{{phase==='setup'}}">
    <view class="hero">
      <view class="hero-emoji">🕹️</view>
      <view class="hero-title">指令反应</view>
      <view class="hero-sub">屏幕出身体动作 · 大家一起跟着做 · 每条 3 秒自动切换</view>
    </view>
    <view class="rules">
      <view class="rule">📣 屏幕出现动作（如「抬手」），大家一起做出来</view>
      <view class="rule">⏱️ 每条指令停留 3 秒，自动切换下一条，无需点击</view>
      <view class="rule">🔁 想结束时点「结束」返回</view>
    </view>
    <view class="btn-primary" bindtap="startGame">开始游戏 🕹️</view>
  </block>

  <!-- ===== 游戏页（自动出指令，无需点击） ===== -->
  <block wx:if="{{phase==='playing'}}">
    <view class="hud">
      <view class="hud-item">第 {{round}} 个</view>
    </view>

    <view class="cmd-card">
      <view class="cmd-emoji">{{cmdEmoji}}</view>
      <view class="cmd-text">{{cmdText}}</view>
      <view class="cmd-hint">一起做动作～</view>

      <!-- 倒计时条：仅视觉提示，告诉还有多久切换下一条 -->
      <view class="time-bar">
        <view class="time-bar-fill" style="width:{{progress}}%"></view>
      </view>
    </view>

    <view class="btn-ghost" bindtap="stopGame">结束</view>
  </block>
</view>
