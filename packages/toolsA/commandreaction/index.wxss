.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 36rpx 60rpx;
  background: linear-gradient(160deg, #2b1055 0%, #5b1d8a 55%, #7597de 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

/* 收藏 */
.fav {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 44rpx;
  z-index: 5;
  filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.3));
}

/* ===== 开始页 ===== */
.hero {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hero-emoji { font-size: 120rpx; }
.hero-title {
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}
.hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 12rpx;
  text-align: center;
}
.rules {
  margin-top: 56rpx;
  width: 100%;
  background: rgba(255,255,255,0.12);
  border-radius: 28rpx;
  padding: 32rpx 30rpx;
  box-sizing: border-box;
}
.rule {
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.95;
  margin: 10rpx 0;
}

/* 主按钮 */
.btn-primary {
  margin-top: 48rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(90deg, #FF6B9D, #FFC371);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(255,107,157,0.4);
}
.btn-ghost {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: rgba(255,255,255,0.16);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 游戏页 ===== */
.hud {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
  padding: 18rpx 10rpx;
  box-sizing: border-box;
}
.hud-item {
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255,255,255,0.14);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
}

.cmd-card {
  margin-top: 80rpx;
  width: 100%;
  min-height: 440rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 50rpx 30rpx;
  box-sizing: border-box;
  color: #2b1055;
  position: relative;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3);
}
.cmd-emoji { font-size: 150rpx; line-height: 1; }
.cmd-text {
  font-size: 76rpx;
  font-weight: 800;
  margin-top: 24rpx;
  letter-spacing: 6rpx;
}
.cmd-hint {
  font-size: 26rpx;
  margin-top: 26rpx;
  opacity: 0.7;
}

/* 切换倒计时条（纯视觉提示，无需点击） */
.time-bar {
  margin-top: 40rpx;
  width: 80%;
  height: 20rpx;
  background: rgba(43,16,85,0.15);
  border-radius: 12rpx;
  overflow: hidden;
}
.time-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #FFC371);
  border-radius: 12rpx;
}
