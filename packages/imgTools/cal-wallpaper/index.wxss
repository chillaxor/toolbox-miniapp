.container {
  padding: 20rpx 24rpx 60rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0 20rpx;
}
.header .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.header .subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 月份切换 */
.month-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  gap: 40rpx;
}
.month-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.month-arrow {
  font-size: 24rpx;
  color: #666;
}
.month-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  min-width: 200rpx;
  text-align: center;
}

/* 预览区域 */
.preview-section {
  padding: 20rpx 0;
}
.preview-frame {
  width: 100%;
  aspect-ratio: 9 / 16;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
}
.preview-bg-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #000;
}
.preview-calendar {
  position: absolute;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 2;
}

/* 日历头部 */
.cal-header {
  margin-bottom: 20rpx;
}
.cal-month {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.3);
  display: block;
}
.cal-year {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
  display: block;
  margin-top: 4rpx;
}

/* 星期行 */
.cal-weekdays {
  display: flex;
  margin-bottom: 8rpx;
}
.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.3);
}
.wd-weekend {
  color: rgba(255,200,200,0.8);
}

/* 日期行 */
.cal-row {
  display: flex;
}
.cal-day {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 0;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.3);
}
.day-other {
  color: rgba(255,255,255,0.3);
}
.day-today {
  color: #FFD700;
  font-weight: bold;
}
.day-weekend {
  color: rgba(255,180,180,0.9);
}

/* 节 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* 背景选项 */
.bg-options {
  display: flex;
  gap: 20rpx;
}
.bg-option {
  flex: 1;
  height: 120rpx;
  border-radius: 12rpx;
  border: 3rpx solid #eee;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.bg-active {
  border-color: #333;
  box-shadow: 0 0 0 2rpx #333;
}
.bg-color-preview {
  width: 50rpx;
  height: 50rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ddd;
}
.bg-add-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-text {
  font-size: 28rpx;
  color: #666;
}
.bg-label {
  font-size: 22rpx;
  color: #999;
}

/* 颜色网格 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.color-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
}
.color-active {
  border-color: #333;
  box-shadow: 0 0 0 3rpx rgba(51,51,51,0.3);
}

/* 滑块 */
.slider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.slider-label {
  font-size: 24rpx;
  color: #999;
  min-width: 40rpx;
  text-align: center;
}
.opacity-slider {
  flex: 1;
}

/* 日历颜色 */
.cal-colors {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}
.cal-color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
}
.cal-color-active {
  border-color: #333;
  background: #f8f8f8;
}
.cal-color-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.1);
}
.cal-color-name {
  font-size: 22rpx;
  color: #666;
}

/* 位置选项 */
.pos-options {
  display: flex;
  gap: 16rpx;
}
.pos-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
}
.pos-active {
  border-color: #333;
  color: #333;
  background: #f0f0f0;
  font-weight: bold;
}

/* 生成按钮 */
.action-section {
  padding: 30rpx 0 10rpx;
}
.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(102,126,234,0.4);
}
.save-btn::after {
  border: none;
}
.btn-disabled {
  opacity: 0.6;
}
.btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 提示 */
.tip-card {
  display: flex;
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
  gap: 12rpx;
}
.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.tip-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.tip-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}
.tip-text {
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
}

/* 隐藏 Canvas */
.offscreen-canvas {
  position: fixed;
  left: -2000px;
  top: -2000px;
  width: 750px;
  height: 1334px;
}
