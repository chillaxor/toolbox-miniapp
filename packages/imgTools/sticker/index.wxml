<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">表情包制作</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 预览区（所见即所得） -->
  <view class="preview-wrap">
    <!-- 底图 -->
    <view class="preview-box" style="width:{{previewW}}px;height:{{previewH}}px;">
      <!-- 纯色底图 -->
      <view wx:if="{{bgType === 'color'}}" class="preview-bg" style="background-color:{{bgColor}};width:{{previewW}}px;height:{{previewH}}px;"></view>
      <!-- 图片底图 -->
      <image wx:if="{{bgType === 'image'}}" class="preview-bg" src="{{bgImage}}" mode="scaleToFill" style="width:{{previewW}}px;height:{{previewH}}px;"></image>

      <!-- 叠加文字层 -->
      <block wx:for="{{textLayers}}" wx:key="id">
        <view class="text-layer {{item.pos}}" style="color:{{item.color}};font-size:{{item.size}}px;-webkit-text-stroke:1px {{item.strokeColor}};text-shadow:1px 1px 2px {{item.shadowColor}};">
          <text>{{item.content}}</text>
        </view>
      </block>

      <!-- 叠加表情层 -->
      <block wx:for="{{emojiLayers}}" wx:key="id">
        <view class="emoji-layer pos-{{item.pos}}" style="font-size:{{item.size}}px;">
          <text>{{item.content}}</text>
        </view>
      </block>
    </view>

    <!-- 空状态 -->
    <view class="preview-empty" wx:if="{{!bgType}}">
      <text class="empty-icon">🖼️</text>
      <text class="empty-tip">从下方选择底图开始制作</text>
    </view>
  </view>

  <!-- 底图选择 -->
  <view class="card">
    <view class="section-title">
      <text class="section-icon">📷</text>
      <text>选择底图</text>
    </view>
    <view class="bg-options">
      <view class="bg-btn" bindtap="onChooseImage">
        <text class="bg-btn-icon">🖼️</text>
        <text class="bg-btn-label">从相册选择</text>
      </view>
      <view class="bg-btn" bindtap="onCameraCapture">
        <text class="bg-btn-icon">📸</text>
        <text class="bg-btn-label">拍照</text>
      </view>
    </view>

    <!-- 纯色底图 -->
    <view class="sub-title mt-md">🎨 纯色底图</view>
    <view class="pure-bg-options">
      <view class="pure-bg-item {{bgType==='color' && bgColor===item ? 'pure-bg-active' : ''}}" wx:for="{{pureBgColors}}" wx:key="*this" data-color="{{item}}" bindtap="onPureBgSelect">
        <view class="pure-bg-preview" style="background-color:{{item}};"></view>
      </view>
    </view>
  </view>

  <!-- 添加文字 -->
  <view class="card" wx:if="{{bgType}}">
    <view class="section-title">
      <text class="section-icon">✏️</text>
      <text>添加文字</text>
    </view>

    <input class="input-field" placeholder="输入文字内容（最多20字）" value="{{textInput}}" bindinput="onTextInput" maxlength="20" />

    <view class="option-row">
      <view class="option-group">
        <text class="option-label">字号</text>
        <view class="chips">
          <view class="chip {{fontSize===item ? 'chip-active' : ''}}" wx:for="{{fontSizeOptions}}" wx:key="*this" data-val="{{item}}" bindtap="onFontSizeSelect">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="option-row">
      <view class="option-group">
        <text class="option-label">颜色</text>
        <view class="color-row">
          <view class="color-dot {{textColor===item ? 'color-dot-active' : ''}}" wx:for="{{textColors}}" wx:key="*this" data-val="{{item}}" bindtap="onTextColorSelect" style="background-color:{{item}};"></view>
        </view>
      </view>
    </view>

    <view class="option-row">
      <view class="option-group">
        <text class="option-label">位置</text>
        <view class="chips">
          <view class="chip {{textPos===item.id ? 'chip-active' : ''}}" wx:for="{{posOptions}}" wx:key="id" data-val="{{item.id}}" bindtap="onTextPosSelect">{{item.icon}}{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="btn-row">
      <view class="add-btn" bindtap="onAddText">＋ 添加文字</view>
    </view>
  </view>

  <!-- 添加表情 -->
  <view class="card" wx:if="{{bgType}}">
    <view class="section-title">
      <text class="section-icon">😀</text>
      <text>添加表情贴纸</text>
    </view>

    <view class="emoji-grid">
      <view class="emoji-item {{selectedEmoji===item ? 'emoji-active' : ''}}" wx:for="{{emojiList}}" wx:key="*this" data-emoji="{{item}}" bindtap="onEmojiTap">
        <text>{{item}}</text>
      </view>
    </view>

    <view class="option-row">
      <view class="option-group">
        <text class="option-label">大小</text>
        <view class="chips">
          <view class="chip {{emojiSize===item ? 'chip-active' : ''}}" wx:for="{{emojiSizeOptions}}" wx:key="*this" data-val="{{item}}" bindtap="onEmojiSizeSelect">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="option-row">
      <view class="option-group">
        <text class="option-label">位置</text>
        <view class="chips">
          <view class="chip {{emojiPos===item.id ? 'chip-active' : ''}}" wx:for="{{emojiPosOptions}}" wx:key="id" data-val="{{item.id}}" bindtap="onEmojiPosSelect">{{item.icon}}{{item.name}}</view>
        </view>
      </view>
    </view>

    <view class="btn-row">
      <view class="add-btn" bindtap="onAddEmoji">＋ 添加表情</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar" wx:if="{{bgType}}">
    <view class="act-btn act-btn-undo" bindtap="onUndo">↩️ 撤销</view>
    <view class="act-btn act-btn-clear" bindtap="onClearAll">🗑️ 清空</view>
    <view class="act-btn act-btn-save" bindtap="onSave">💾 保存到相册</view>
  </view>

  <!-- 隐藏的合成 canvas（不显示，仅用于导出） -->
  <canvas canvas-id="exportCanvas" class="export-canvas" style="width:{{exportW}}px;height:{{exportH}}px;"></canvas>
</view>
