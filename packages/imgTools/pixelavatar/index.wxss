/* packages/imgTools/pixelavatar/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
  position: relative;
}

/* 收藏按钮 */
.fav-btn {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  z-index: 10;
}

/* 预览区域 */
.preview-area {
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  justify-content: center;
}

.preview-box {
  width: 400rpx;
  height: 400rpx;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-canvas {
  width: 360rpx;
  height: 360rpx;
}

/* 区块 */
.section {
  padding: 0 30rpx;
  margin-bottom: 28rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.hint-text {
  font-weight: 400;
  color: #999;
  font-size: 24rpx;
}

/* 种子输入 */
.seed-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.seed-input {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.random-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 36rpx;
  background: #fff !important;
  border-radius: 16rpx;
  padding: 0;
  border: 2rpx solid #e0e0e0;
}

.random-btn::after {
  border: none;
}

/* 风格选择 */
.style-scroll,
.palette-scroll {
  white-space: nowrap;
}

.style-list,
.palette-list {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.style-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 120rpx;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
}

.style-item.active {
  border-color: #333;
  background: #f0f0f0;
}

.style-icon {
  font-size: 40rpx;
}

.style-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.style-item.active .style-name {
  color: #333;
  font-weight: 600;
}

/* 调色板选择 */
.palette-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  border: 3rpx solid transparent;
  border-radius: 16rpx;
  overflow: hidden;
}

.palette-item.active {
  border-color: #333;
}

.palette-colors {
  display: flex;
  width: 120rpx;
  height: 60rpx;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 0 10rpx;
}

.palette-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.palette-name {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 0;
  background: #fff;
  width: 100%;
  text-align: center;
}

.palette-item.active .palette-name {
  color: #333;
  font-weight: 600;
}

/* 批量变体 */
.batch-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.batch-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 1;
}

.batch-canvas {
  width: 100%;
  height: 100%;
}

/* 保存按钮 */
.btn-row {
  padding: 10rpx 30rpx 40rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  color: #fff !important;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.save-btn::after {
  border: none;
}

/* 隐藏画布 */
.offscreen-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 540px;
  height: 540px;
}
