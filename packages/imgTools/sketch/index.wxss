.canvas-wrapper {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.sketch-canvas {
  width: 100%;
  height: 600rpx;
  background: #fff;
}

.toolbar {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.color-bar {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  padding-bottom: 20rpx;
}

.color-item {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 3rpx solid transparent;
}

.color-active {
  border-color: #333;
  background: #F0F0F0;
}

.color-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.15);
}

/* 白色画笔加边框 */
.color-item:last-child .color-dot {
  border: 1rpx solid #E5E5E5;
}

.width-bar {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  align-items: center;
}

.width-item {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 3rpx solid transparent;
}

.width-active {
  border-color: #9B59B6;
  background: #EFD9F7;
}

.width-dot {
  background: #333;
  border-radius: 50%;
}

.action-bar {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-label {
  font-size: 20rpx;
  color: #999;
}

.eraser-active {
  background: #EFD9F7;
  border-radius: 12rpx;
  padding: 4rpx 12rpx;
}
