/* 渐变壁纸生成器 */

.container {
  padding: 24rpx;
  padding-bottom: 60rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

/* 标题区 */
.header {
  padding: 16rpx 8rpx 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #2D3436;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 预览区 */
.preview-section {
  margin-bottom: 24rpx;
}

.preview-box {
  width: 100%;
  height: 0;
  padding-bottom: 177.8%; /* 9:16 比例 */
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
}

.preview-label {
  position: absolute;
  bottom: 24rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 通用 section */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 预设渐变 */
.preset-scroll {
  white-space: nowrap;
  width: 100%;
}

.preset-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 8rpx 0;
}

.preset-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.preset-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.preset-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 颜色槽位 */
.color-slots {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.color-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.slot-active {
  border-color: #6C5CE7;
  background: rgba(108, 92, 231, 0.06);
}

.slot-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid #fff;
}

.slot-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 调色板 */
.palette {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #F0F0F0;
}

.palette-item {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid rgba(0, 0, 0, 0.05);
}

/* 方向选择 */
.direction-bar {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.dir-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #F5F6FA;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.dir-active {
  background: #6C5CE7;
  border-color: #6C5CE7;
}

.dir-active .dir-icon {
  color: #fff;
}

.dir-icon {
  font-size: 36rpx;
  color: #555;
}

/* 生成按钮 */
.action-section {
  margin: 32rpx 0 24rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
}

.save-btn::after {
  border: none;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  position: relative;
  z-index: 1;
}

.btn-disabled {
  opacity: 0.6;
}

/* 提示卡片 */
.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
}

.tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.tip-text {
  display: block;
  font-size: 22rpx;
  color: #888;
  line-height: 1.8;
}

/* 隐藏 Canvas */
.offscreen-canvas {
  width: 750px;
  height: 1334px;
  position: fixed;
  left: -9999px;
  top: -9999px;
}
