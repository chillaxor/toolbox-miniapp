.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

/* 上传区 */
.photo-area {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 500rpx;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 500rpx;
  height: 500rpx;
  border: 4rpx dashed #ccc;
  border-radius: 30rpx;
  background: #fff;
}

.upload-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 30rpx; color: #333; font-weight: bold; }
.upload-hint { font-size: 24rpx; color: #999; margin-top: 10rpx; }

/* 预览 */
.preview-area {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.photo-frame {
  position: relative;
  width: 650rpx;
  background: #000;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 650rpx;
  height: 650rpx;
}

.watermark-overlay {
  position: absolute;
  padding: 20rpx 24rpx;
}

.watermark-bottom-left { bottom: 0; left: 0; }
.watermark-bottom-right { bottom: 0; right: 0; text-align: right; }
.watermark-top-left { top: 0; left: 0; }
.watermark-top-right { top: 0; right: 0; text-align: right; }

.watermark-block {
  background: rgba(0, 0, 0, 0.4);
  border-radius: 10rpx;
  padding: 12rpx 20rpx;
  display: inline-block;
}

.wm-datetime {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
}

.wm-location {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.wm-custom {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
  font-style: italic;
}

/* 设置 */
.settings {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.setting-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0 16rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-label {
  font-size: 28rpx;
  color: #666;
}

.custom-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  padding-left: 10rpx;
}

.position-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.pos-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f0f0f5;
  font-size: 26rpx;
  color: #666;
}

.pos-active {
  background: #667eea;
  color: #fff;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-save {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-rechoose {
  width: 200rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #f0f0f5;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}