.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; padding-bottom: 200rpx; }
.preview-area { width: 100%; min-height: 300rpx; border-radius: 20rpx; overflow: hidden; background: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.preview-area canvas { margin: 20rpx auto; }
.empty-box { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-hint { font-size: 32rpx; color: #666; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #aaa; }
.frame-list { white-space: nowrap; margin-top: 24rpx; padding: 16rpx 0; }
.frame-item { display: inline-block; width: 120rpx; height: 120rpx; border-radius: 12rpx; overflow: hidden; position: relative; margin-right: 16rpx; border: 4rpx solid transparent; transition: border-color .2s; }
.frame-item.active { border-color: #9B59B6; }
.frame-thumb { width: 100%; height: 100%; }
.frame-idx { position: absolute; left: 4rpx; bottom: 4rpx; background: rgba(0,0,0,0.4); color: #fff; font-size: 18rpx; padding: 0 8rpx; border-radius: 6rpx; }
.frame-del { position: absolute; right: 4rpx; top: 4rpx; background: rgba(0,0,0,0.5); color: #fff; width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; }
.frame-add { display: inline-flex; width: 120rpx; height: 120rpx; border-radius: 12rpx; border: 3rpx dashed #ccc; align-items: center; justify-content: center; vertical-align: top; background: #fafafa; }
.add-icon { font-size: 48rpx; color: #999; }
.panel { background: #fff; border-radius: 20rpx; margin-top: 24rpx; padding: 28rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.ctrl-row { display: flex; justify-content: center; margin-bottom: 20rpx; }
.btn-sm { background: #9B59B6; color: #fff; border: none; border-radius: 40rpx; font-size: 28rpx; padding: 0 48rpx; height: 72rpx; line-height: 72rpx; }
.slider-row { margin-bottom: 24rpx; }
.slider-label { font-size: 28rpx; color: #555; font-weight: 600; margin-bottom: 10rpx; display: block; }
.slider-val { font-size: 24rpx; color: #999; text-align: center; display: block; margin-top: 8rpx; }
.size-row { margin-bottom: 8rpx; }
.size-btns { display: flex; gap: 16rpx; margin-top: 12rpx; flex-wrap: wrap; }
.size-btn { background: #f0f0f0; border-radius: 12rpx; padding: 12rpx 24rpx; font-size: 26rpx; color: #666; }
.size-btn.active { background: #9B59B6; color: #fff; }
.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06); }
.btn-export { background: linear-gradient(135deg, #9B59B6, #8E44AD); color: #fff; border: none; border-radius: 16rpx; height: 96rpx; line-height: 96rpx; font-size: 32rpx; font-weight: 600; }
.btn-export.disabled { opacity: 0.6; }
.tips { text-align: center; margin-top: 40rpx; }
.tip-text { font-size: 26rpx; color: #999; }
