<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">去水印</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 额度提示 -->
  <view class="card quota-card" style="background:linear-gradient(135deg,#E67E22 0%,#D35400 100%);" wx:if="{{cloudReady && dailyRemaining <= 0}}">
    <!-- <view class="quota-info">
      <text class="quota-label">今日剩余</text>
      <text class="quota-value">{{dailyRemaining}} / {{dailyLimit}} 次</text>
    </view>
    <view class="quota-bar-bg">
      <view class="quota-bar-fill" style="width:{{(dailyRemaining / dailyLimit) * 100}}%;"></view>
    </view>
    <view class="quota-info" style="margin-top:16rpx;">
      <text class="quota-label">本月总额</text>
      <text class="quota-value">{{monthlyRemaining}} / {{monthlyLimit}} 次</text>
    </view>
    <view class="quota-bar-bg">
      <view class="quota-bar-fill" style="width:{{(monthlyRemaining / monthlyLimit) * 100}}%;"></view>
    </view> -->
    <text class="quota-hint" wx:if="{{dailyRemaining <= 0}}">今日次数已用完，明天再来</text>
    <!--<text class="quota-hint" wx:if="{{monthlyRemaining <= 0}}">本月总额度已用完，下月自动恢复</text> -->
  </view>

  <!-- 云服务不可用提示 -->
  <view class="card cloud-error-card" wx:if="{{!cloudReady && !isLoading && !imageSrc}}">
    <text class="cloud-error-icon">⚠️</text>
    <text class="cloud-error-title">云服务暂不可用</text>
    <text class="cloud-error-desc">AI去水印需要云服务支持，你仍可使用手动涂抹模式</text>
    <button class="btn-retry" bindtap="checkCloudReady">重新检测</button>
  </view>

  <!-- 选图 -->
  <view class="card" wx:if="{{!imageSrc && !showResult}}">
    <view class="image-picker" bindtap="onChooseImage">
      <text class="picker-icon">🧽</text>
      <text class="picker-title">选择含水印的图片</text>
      <text class="picker-desc">从相册选择或拍照，支持常见图片格式</text>
    </view>
  </view>

  <!-- 已选图 → 框选水印区域 -->
  <view wx:if="{{imageSrc && selectMode && !isLoading}}" class="edit-area">
    <view class="toolbar-fixed">
      <view class="tool-group">
        <view class="tool-btn" bindtap="onClearRects" wx:if="{{rectCount > 0}}">
          <text class="tool-icon">🗑️</text>
          <text class="tool-label">清除框选</text>
        </view>
        <view class="tool-btn" bindtap="onChooseImage">
          <text class="tool-icon">🖼️</text>
          <text class="tool-label">换图</text>
        </view>
        <view class="tool-btn" bindtap="onExitSelect">
          <text class="tool-icon">✖️</text>
          <text class="tool-label">退出</text>
        </view>
      </view>
      <view class="action-hint">
        <text class="hint-text" wx:if="{{rectCount === 0}}">👆 在图片上框选水印所在区域（可框选多个）</text>
        <text class="hint-text" wx:else>✅ 已框选 {{rectCount}} 个区域，可继续框选或点击下方按钮处理</text>
      </view>
    </view>

    <view class="canvas-wrapper">
      <canvas
        id="selectCanvas"
        type="2d"
        class="draw-canvas"
        style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;"
        bindtouchstart="onSelectStart"
        bindtouchmove="onSelectMove"
        bindtouchend="onSelectEnd"
        disable-scroll
      ></canvas>
    </view>

    <view class="export-bar">
      <button class="btn-primary btn-export" style="background:linear-gradient(135deg,#E67E22 0%,#D35400 100%);" bindtap="onStartAI" disabled="{{rectCount === 0 || !cloudReady || dailyRemaining <= 0 || monthlyRemaining <= 0}}">
        🧽 AI去水印（{{rectCount}}个区域）
      </button>
      <view class="sub-row" style="margin-top:16rpx;">
        <button class="btn-text" bindtap="onEnterManual">✏️ 跳过AI，直接手动涂抹</button>
      </view>
    </view>
  </view>

  <!-- AI处理中 -->
  <view class="card" wx:if="{{isLoading}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
      <text class="loading-sub">AI正在识别并去除水印</text>
    </view>
  </view>

  <!-- AI处理结果 → 对比 + 选择 -->
  <view class="card result-card" wx:if="{{showResult && !editMode && !selectMode}}">
    <view class="compare-section">
      <view class="compare-item">
        <text class="compare-label">原图</text>
        <image class="compare-img" src="{{imageSrc}}" mode="aspectFit"></image>
      </view>
      <view class="compare-divider">
        <text class="divider-icon">→</text>
      </view>
      <view class="compare-item">
        <text class="compare-label">去水印后</text>
        <image class="compare-img" src="{{resultSrc}}" mode="aspectFit"></image>
      </view>
    </view>
    <view class="result-actions">
      <button class="btn-primary btn-save" style="background:linear-gradient(135deg,#E67E22 0%,#D35400 100%);" bindtap="onSaveResult">
        💾 保存到相册
      </button>
      <button class="btn-secondary" bindtap="onEnterManualEdit">✏️ 手动修补</button>
    </view>
    <view class="sub-row">
      <button class="btn-text" bindtap="onReset">处理另一张</button>
    </view>
  </view>

  <!-- 手动涂抹编辑区 -->
  <view wx:if="{{editMode}}" class="edit-area">
    <view class="toolbar-fixed">
      <view class="tool-group">
        <view class="tool-btn {{drawMode === 'brush' ? 'active' : ''}}" data-mode="brush" bindtap="onDrawModeChange">
          <text class="tool-icon">✏️</text>
          <text class="tool-label">涂抹</text>
        </view>
        <view class="tool-btn {{drawMode === 'rect' ? 'active' : ''}}" data-mode="rect" bindtap="onDrawModeChange">
          <text class="tool-icon">⬜</text>
          <text class="tool-label">矩形</text>
        </view>
        <view class="tool-btn" bindtap="onUndo">
          <text class="tool-icon">↩️</text>
          <text class="tool-label">撤销</text>
        </view>
        <view class="tool-btn" bindtap="onExitEdit">
          <text class="tool-icon">✖️</text>
          <text class="tool-label">退出</text>
        </view>
      </view>
      <view class="brush-size-row" wx:if="{{drawMode === 'brush'}}">
        <text class="size-label">粗细</text>
        <slider class="size-slider" min="5" max="60" value="{{brushSize}}" activeColor="#E67E22" bindchange="onBrushSizeChange" show-value/>
      </view>
      <view class="action-hint">
        <text class="hint-text">👆 在水印残留区域涂抹，自动用周围颜色修复</text>
      </view>
    </view>

    <view class="canvas-wrapper">
      <canvas
        id="drawCanvas"
        type="2d"
        class="draw-canvas"
        style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;"
        bindtouchstart="onDrawStart"
        bindtouchmove="onDrawMove"
        bindtouchend="onDrawEnd"
        disable-scroll
      ></canvas>
    </view>

    <view class="export-bar">
      <button class="btn-primary btn-export" style="background:linear-gradient(135deg,#E67E22 0%,#D35400 100%);" bindtap="onExport">
        💾 导出并保存到相册
      </button>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="card">
    <text class="section-title">📖 使用说明</text>
    <view class="step-list">
      <view class="step-item">
        <view class="step-num">1</view>
        <view class="step-content">
          <text class="step-title">选择图片</text>
          <text class="step-desc">从相册或拍照选择含水印的图片</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">2</view>
        <view class="step-content">
          <text class="step-title">框选水印区域</text>
          <text class="step-desc">在图片上画矩形框住水印位置，可框选多个区域</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">3</view>
        <view class="step-content">
          <text class="step-title">AI智能去除</text>
          <text class="step-desc">AI根据框选区域智能修复水印，效果自然</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">4</view>
        <view class="step-content">
          <text class="step-title">手动修补残留</text>
          <text class="step-desc">对残留痕迹手动涂抹修补，智能采样周围颜色</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="card tips-card">
    <text class="section-title">💡 温馨提示</text>
    <view wx:for="{{tips}}" wx:key="index" class="tip-item">
      <text class="tip-dot">•</text>
      <text class="tip-text">{{item}}</text>
    </view>
  </view>
</view>
