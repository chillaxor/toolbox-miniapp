.container {
  min-height: 100vh;
  background: #1a1a2e;
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

/* 显示屏 */
.display-area {
  background: linear-gradient(145deg, #16213e, #0f0f23);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  min-height: 200rpx;
}

.display-mode-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.mode-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.mode-active {
  color: #667eea;
  background: rgba(102, 126, 234, 0.2);
}

.display-expression {
  font-size: 44rpx;
  color: #fff;
  text-align: right;
  word-break: break-all;
  min-height: 60rpx;
  line-height: 1.3;
}

.display-result {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: right;
  margin-top: 10rpx;
}

/* 科学函数行 */
.func-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.func-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
  font-size: 26rpx;
  border-radius: 12rpx;
  font-weight: bold;
}

.func-btn-del {
  color: #f44336;
  background: rgba(244, 67, 54, 0.15);
}

/* 数字行 */
.num-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.num-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  font-size: 36rpx;
  border-radius: 12rpx;
}

.op-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 152, 0, 0.2);
  color: #FF9800;
  font-size: 36rpx;
  border-radius: 12rpx;
  font-weight: bold;
}

.op-clear, .op-clear2 {
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
  font-size: 30rpx;
}

.op-equal {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* 历史记录 */
.history-toggle {
  text-align: center;
  color: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
  padding: 20rpx 0 10rpx;
}

.history-list {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 20rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.history-expr {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.history-result {
  font-size: 26rpx;
  color: #667eea;
}

.history-empty {
  text-align: center;
  color: rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
  padding: 20rpx;
}

.history-clear {
  text-align: center;
  color: #f44336;
  font-size: 24rpx;
  padding: 16rpx 0;
}