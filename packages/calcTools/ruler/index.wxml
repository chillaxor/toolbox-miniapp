<view class="container">
  <!-- 尺子铺满整个屏幕 -->
  <canvas type="2d" id="ruler" class="ruler"
    disable-scroll="true"
    bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
  </canvas>

  <!-- 悬浮操作面板 -->
  <view class="float-panel" style="top: {{statusBarHeight + 10}}px;">
    <!-- 收起/展开按钮 -->
    <view class="float-toggle" bindtap="togglePanel">
      <text class="toggle-icon">{{panelOpen ? '▼' : '▲'}}</text>
    </view>

    <view class="float-body {{panelOpen ? 'show' : 'hide'}}">
      <!-- 方向切换 -->
      <view class="float-row">
        <view class="fbtn {{direction === 'h' ? 'active' : ''}}" bindtap="switchDir" data-dir="h">↔</view>
        <view class="fbtn {{direction === 'v' ? 'active' : ''}}" bindtap="switchDir" data-dir="v">↕</view>
        <view class="fbtn {{unit === 'cm' ? 'active' : ''}}" bindtap="switchUnit" data-unit="cm">cm</view>
        <view class="fbtn {{unit === 'inch' ? 'active' : ''}}" bindtap="switchUnit" data-unit="inch">inch</view>
      </view>

      <!-- 校准 -->
      <view class="float-row">
        <text class="fbtn" bindtap="decreaseCal">-</text>
        <text class="cal-text">{{cal}}%</text>
        <text class="fbtn" bindtap="increaseCal">+</text>
      </view>
    </view>
  </view>

  <!-- 返回按钮 -->
  <view class="back-btn" style="top: {{statusBarHeight + 6}}px;" bindtap="goBack">
    <text class="back-icon">←</text>
  </view>
</view>
