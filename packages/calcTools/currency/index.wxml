<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">汇率转换</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <view class="card">
    <view class="form-group">
      <text class="form-label">金额</text>
      <input class="input-field" type="digit" placeholder="请输入金额" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <view class="form-group">
      <text class="form-label">从</text>
      <picker mode="selector" range="{{currencyNames}}" value="{{fromIndex}}" bindchange="onFromChange">
        <view class="picker-field">
          <text>{{currencyNames[fromIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="swap-btn" bindtap="onSwap">
      <text>⇅ 互换</text>
    </view>

    <view class="form-group">
      <text class="form-label">到</text>
      <picker mode="selector" range="{{currencyNames}}" value="{{toIndex}}" bindchange="onToChange">
        <view class="picker-field">
          <text>{{currencyNames[toIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <button class="btn-primary" style="background-color: #FF6B35;" bindtap="onConvert">换算</button>
  </view>

  <view class="result-box" wx:if="{{result !== null}}">
    <text class="result-title">换算结果</text>
    <text class="result-value">{{result}}</text>
    <view class="result-detail">
      <text>汇率：1 {{currencyCodes[fromIndex]}} = {{rate}} {{currencyCodes[toIndex]}}</text>
    </view>
  </view>
</view>
