.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.header-icon { font-size: 80rpx; margin-bottom: 10rpx; }
.header-title { font-size: 36rpx; font-weight: bold; color: #333; }
.header-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; }

.input-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0 16rpx;
}

.section-title:first-child { margin-top: 0; }

.input-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.input-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #666;
}

.input-field {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.input-unit {
  width: 60rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.btn-calc {
  margin-top: 30rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.result-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.result-card {
  background: #f9f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #667eea;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.result-label {
  font-size: 26rpx;
  color: #666;
}

.result-value {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.result-value.highlight {
  color: #667eea;
  font-size: 36rpx;
}

.result-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  line-height: 1.4;
}

/* 示意图 */
.diagram {
  margin-top: 20rpx;
  background: #f0f0f5;
  border-radius: 16rpx;
  padding: 20rpx;
}

.diagram-wall {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: #e8e8f0;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
}

.diagram-nail {
  position: absolute;
  font-size: 32rpx;
  transform: translateX(-50%);
  z-index: 3;
}

.diagram-frame {
  position: absolute;
  background: rgba(102, 126, 234, 0.3);
  border: 3rpx solid #667eea;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.diagram-frame-text {
  font-size: 22rpx;
  color: #667eea;
}

.diagram-furniture {
  position: absolute;
  bottom: 0;
  left: 5%;
  width: 90%;
  background: rgba(139, 69, 19, 0.3);
  border: 2rpx solid #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
}

.diagram-furniture-text {
  font-size: 22rpx;
  color: #8B4513;
}

.diagram-center-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(233, 30, 99, 0.5);
  border-top: 2rpx dashed #E91E63;
}

.diagram-line-text {
  position: absolute;
  right: 10rpx;
  top: -30rpx;
  font-size: 18rpx;
  color: #E91E63;
}