.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 80rpx;
  background-color: var(--color-card);
  border-radius: 40rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: var(--color-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-hint);
  padding: 8rpx;
  flex-shrink: 0;
}

/* 工具网格 */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.tool-grid-item {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

/* 搜索结果 */
.search-results {
  margin-top: 16rpx;
}

/* 搜索无结果 */
.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.search-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.search-empty-text {
  font-size: 28rpx;
  color: var(--color-hint);
}
