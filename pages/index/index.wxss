/* ============================================================
   拾光工具屋 · 首页统一样式
   设计语言：圆润规整 · 柔和阴影 · 和谐暖色品牌渐变
   ============================================================ */

.container {
  min-height: 100vh;
  /* 品牌渐变（珊瑚→粉），Hero 与精选位共用，保证整页风格一致 */
  --brand: linear-gradient(135deg, #FF8E6B 0%, #FF6B9D 100%);
  --radius-lg: 32rpx;
  --radius-md: 24rpx;
  --radius-sm: 20rpx;
  --shadow-soft: 0 8rpx 24rpx rgba(31, 38, 89, 0.07);
  --shadow-brand: 0 16rpx 40rpx rgba(255, 107, 157, 0.28);
  --text-strong: #2a2e3d;
  --text-muted: #9aa0ad;
  background-color: #F6F7FB;
}

/* ========== 搜索栏（吸顶悬浮胶囊） ========== */
.search-wrap {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #F6F7FB;
  padding: calc(env(safe-area-inset-top) + 16rpx) 28rpx 16rpx;
}

.search-pill {
  display: flex;
  align-items: center;
  height: 88rpx;
  background-color: #ffffff;
  border-radius: 44rpx;
  padding: 0 30rpx;
  box-shadow: var(--shadow-soft);
}

.search-ico {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--text-strong);
}

.search-clear {
  font-size: 30rpx;
  color: var(--text-muted);
  padding: 8rpx;
  flex-shrink: 0;
}

/* ========== 品牌头区（悬浮圆角卡片 + 装饰光斑） ========== */
.hero {
  position: relative;
  overflow: hidden;
  margin: 8rpx 28rpx 0;
  padding: 30rpx 32rpx 32rpx;
  border-radius: var(--radius-lg);
  background: var(--brand);
  box-shadow: var(--shadow-brand);
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
}

.hero-blob-1 {
  width: 220rpx;
  height: 220rpx;
  top: -70rpx;
  right: -50rpx;
}

.hero-blob-2 {
  width: 170rpx;
  height: 170rpx;
  bottom: -60rpx;
  left: -40rpx;
  background: rgba(255, 255, 255, 0.12);
}

.hero-top {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-brand {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.hero-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-sub {
  position: relative;
  display: flex;
  flex-direction: column;
  margin-top: 14rpx;
}

.hero-sub-line {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 1rpx;
  line-height: 1.6;
}

.hero-sub-en {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

/* ========== 通用区块 ========== */
.section {
  padding: 32rpx 28rpx 0;
}

.sec-head {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  min-height: 48rpx;
}

.sec-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-strong);
  letter-spacing: 1rpx;
}

.sec-count {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--text-muted);
  background: #eef0f6;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.cat-dot {
  width: 10rpx;
  height: 32rpx;
  border-radius: 6rpx;
  margin-right: 14rpx;
}

/* ========== 最近使用 ========== */
.recent-scroll {
  white-space: nowrap;
}

.recent-row {
  display: inline-flex;
  gap: 18rpx;
  padding: 6rpx 2rpx;
}

.recent-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 150rpx;
  padding: 24rpx 0;
  background: #ffffff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
}

.recent-chip-hover {
  transform: scale(0.95);
}

.recent-ico {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.recent-name {
  font-size: 24rpx;
  color: var(--text-strong);
  max-width: 132rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 今日精选（与 Hero 同一品牌渐变，风格统一） ========== */
.feat-scroll {
  white-space: nowrap;
}

.feat-row {
  display: inline-flex;
  gap: 18rpx;
  padding: 6rpx 2rpx;
}

.feat-card {
  display: inline-flex;
  align-items: center;
  width: 320rpx;
  height: 156rpx;
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  background: var(--brand);
  box-shadow: var(--shadow-brand);
  color: #ffffff;
}

.feat-card-hover {
  transform: scale(0.97);
}

.feat-emoji {
  font-size: 56rpx;
  margin-right: 18rpx;
}

.feat-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.feat-title {
  font-size: 28rpx;
  font-weight: 800;
}

.feat-sub {
  margin-top: 6rpx;
  font-size: 21rpx;
  opacity: 0.92;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feat-go {
  border: 2rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 30rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

/* ========== 全部分类（浅柔彩底 + 同色系图标块） ========== */
.cat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.cat-card {
  display: flex;
  align-items: center;
  width: calc((100% - 20rpx) / 2);
  height: 152rpx;
  border-radius: var(--radius-lg);
  padding: 0 26rpx;
  box-shadow: var(--shadow-soft);
  color: var(--text-strong);
  box-sizing: border-box;
}

.cat-card-hover {
  transform: scale(0.97);
}

.cat-emoji {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  color: #ffffff;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.cat-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-strong);
}

.cat-count {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7a8090;
}

/* ========== 分类工具列表 ========== */
/* 点击分类滚动定位到此 section 时，避开吸顶搜索栏的遮挡 */
#toolList {
  scroll-margin-top: 120rpx;
}

.tool-list {
  background: #ffffff;
  border-radius: var(--radius-lg);
  padding: 8rpx 28rpx;
  box-shadow: var(--shadow-soft);
}

.tool-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f2f6;
}

.tool-row:last-child {
  border-bottom: none;
}

.tool-row-hover {
  background: #fafbff;
}

.tool-ico {
  width: 84rpx;
  height: 84rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  flex-shrink: 0;
}

.tool-text {
  flex: 1;
  margin-left: 22rpx;
  min-width: 0;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-strong);
}

.tool-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.tool-arrow {
  font-size: 36rpx;
  color: #c8ccd6;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 底部留白：需覆盖固定自定义 tabBar（100rpx + safe-area），否则工具列表最后一项被遮挡显示不全 */
.bottom-space {
  height: calc(130rpx + env(safe-area-inset-bottom));
}

/* ========== 搜索结果 ========== */
.search-results {
  padding: 24rpx 20rpx 0;
}

.search-result-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.search-result-item {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.search-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.search-empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}
