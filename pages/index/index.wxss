.container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ========== 搜索栏（吸顶） ========== */
.search-wrap {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: calc(env(safe-area-inset-top) + 20rpx) 32rpx 20rpx;
}

.search-pill {
  display: flex;
  align-items: center;
  height: 84rpx;
  background-color: #f3f4f8;
  border-radius: 42rpx;
  padding: 0 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.search-ico {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  color: var(--color-primary);
}

.search-clear {
  font-size: 30rpx;
  color: var(--color-hint);
  padding: 8rpx;
  flex-shrink: 0;
}

/* ========== 品牌头区（渐变） ========== */
.hero {
  background: linear-gradient(120deg, #7C5CFF 0%, #FF6B35 100%);
  padding: 40rpx 36rpx 56rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-brand {
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.hero-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}

/* ========== 通用区块 ========== */
.section {
  padding: 36rpx 32rpx 0;
}

.sec-head {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  min-height: 44rpx;
}

.sec-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.sec-count {
  margin-left: auto;
  font-size: 24rpx;
  color: var(--color-hint);
}

.cat-dot {
  width: 12rpx;
  height: 32rpx;
  border-radius: 6rpx;
  margin-right: 14rpx;
}

/* ========== 最近使用 ========== */
.recent-scroll {
  white-space: nowrap;
}

.recent-row {
  display: inline-flex;
  gap: 20rpx;
  padding: 4rpx 2rpx;
}

.recent-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 148rpx;
  padding: 22rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.recent-chip-hover {
  transform: scale(0.94);
}

.recent-ico {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.recent-name {
  font-size: 24rpx;
  color: var(--color-primary);
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 今日精选 ========== */
.feat-scroll {
  white-space: nowrap;
}

.feat-row {
  display: inline-flex;
  gap: 20rpx;
  padding: 4rpx 2rpx;
}

.feat-card {
  display: inline-flex;
  align-items: center;
  width: 520rpx;
  height: 184rpx;
  border-radius: 28rpx;
  padding: 0 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.12);
  color: #ffffff;
}

.feat-card-hover {
  transform: scale(0.97);
}

.feat-emoji {
  font-size: 72rpx;
  margin-right: 22rpx;
}

.feat-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feat-title {
  font-size: 34rpx;
  font-weight: 800;
}

.feat-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.92;
}

.feat-go {
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 30rpx;
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* ========== 全部分类 ========== */
.cat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.cat-card {
  display: flex;
  align-items: center;
  width: calc((100% - 20rpx) / 2);
  height: 150rpx;
  border-radius: 26rpx;
  padding: 0 26rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  color: #ffffff;
  box-sizing: border-box;
}

.cat-card-hover {
  transform: scale(0.96);
}

.cat-emoji {
  font-size: 56rpx;
  margin-right: 18rpx;
}

.cat-meta {
  display: flex;
  flex-direction: column;
}

.cat-name {
  font-size: 30rpx;
  font-weight: 700;
}

.cat-count {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.9;
}

/* ========== 分类工具列表 ========== */
/* 点击分类滚动定位到此 section 时，避开吸顶搜索栏的遮挡 */
#toolList {
  scroll-margin-top: 110rpx;
}

.tool-list {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 4rpx 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tool-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f2f2f5;
}

.tool-row:last-child {
  border-bottom: none;
}

.tool-row-hover {
  background: #fafafa;
}

.tool-ico {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  flex-shrink: 0;
}

.tool-text {
  flex: 1;
  margin-left: 22rpx;
  min-width: 0;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.tool-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--color-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.tool-arrow {
  font-size: 40rpx;
  color: #c8c8cc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 底部留白：需覆盖固定自定义 tabBar（100rpx + safe-area），否则工具列表最后一项被遮挡显示不全 */
.bottom-space {
  height: calc(130rpx + env(safe-area-inset-bottom));
}

/* ========== 搜索结果 ========== */
.search-results {
  padding: 24rpx 24rpx 0;
}

.search-result-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.search-result-item {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.search-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.search-empty-text {
  font-size: 28rpx;
  color: var(--color-hint);
}
