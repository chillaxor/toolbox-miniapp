.container {
  padding: 0 24rpx 24rpx;
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 搜索栏 */
.search-bar {
  padding: 24rpx 0 20rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  height: 80rpx;
  background-color: var(--color-card);
  border-radius: 40rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: var(--color-primary);
}

.search-clear {
  font-size: 28rpx;
  color: var(--color-hint);
  padding: 8rpx;
  flex-shrink: 0;
}

/* ========== 标签栏（吸顶） ========== */
.tabs-wrapper {
  position: sticky;
  top: 0;
  z-index: 50;
  background-color: var(--color-bg);
  padding: 24rpx 0 32rpx;
}

.category-tabs {
  white-space: nowrap;
}

.tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 36rpx;
  background-color: var(--color-card);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.25s ease;
}

.category-tab.active {
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.2);
  transform: scale(1.03);
}

.tab-icon {
  font-size: 30rpx;
  margin-right: 8rpx;
  font-family: 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', sans-serif;
}

.tab-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.category-tab.active .tab-name {
  color: #fff;
}

/* ========== 工具宫格 ========== */
.tool-grid-container {
  padding-top: 8rpx;
}

.tool-grid {
  display: flex;
  flex-wrap: wrap;
}

.tool-grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.tool-grid-item-hover {
  transform: scale(0.92);
  opacity: 0.75;
}

.tool-icon-wrap {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.07);
}

.tool-icon {
  font-size: 48rpx;
  font-family: 'Segoe UI Emoji', 'Apple Color Emoji', 'Noto Color Emoji', sans-serif;
}

.tool-name {
  font-size: 22rpx;
  color: var(--color-primary);
  text-align: center;
  line-height: 1.4;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 搜索结果 ========== */
.search-results {
  margin-top: 16rpx;
}

.search-result-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.search-result-item {
  width: 50%;
  padding: 8rpx;
  box-sizing: border-box;
}

.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.search-empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.search-empty-text {
  font-size: 28rpx;
  color: var(--color-hint);
}
