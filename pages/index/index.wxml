<view class="container">

  <!-- 搜索栏：始终可见，吸顶 -->
  <view class="search-wrap">
    <view class="search-pill">
      <text class="search-ico">🔍</text>
      <input
        class="search-input"
        placeholder="搜索99+个工具"
        value="{{searchText}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text wx:if="{{searchText}}" class="search-clear" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <block wx:if="{{searchText}}">
    <view wx:if="{{searchResults.length > 0}}" class="search-results">
      <view class="search-result-grid">
        <view class="search-result-item" wx:for="{{searchResults}}" wx:key="id">
          <tool-card
            toolId="{{item.id}}"
            name="{{item.name}}"
            icon="{{item.icon}}"
            description="{{item.description}}"
            color="{{item.categoryColor}}"
            bgColor="{{item.categoryBgColor}}"
            path="{{item.path}}"
          />
        </view>
      </view>
    </view>
    <view wx:else class="search-empty">
      <text class="search-empty-icon">🔍</text>
      <text class="search-empty-text">没有找到匹配的工具</text>
    </view>
  </block>

  <!-- 首页主体 -->
  <block wx:else>

    <!-- 品牌头区（活力渐变） -->
    <view class="hero">
      <view class="hero-top">
        <view class="hero-brand">拾光工具屋</view>
        <view class="hero-avatar">我</view>
      </view>
      <view class="hero-sub">99+个小工具 · 随时待命</view>
    </view>

    <!-- 最近使用 -->
    <view wx:if="{{recentTools.length > 0}}" class="section">
      <view class="sec-head">
        <text class="sec-title">最近使用</text>
      </view>
      <scroll-view class="recent-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view class="recent-row">
          <view
            class="recent-chip"
            wx:for="{{recentTools}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onToolTap"
            hover-class="recent-chip-hover"
          >
            <view class="recent-ico" style="background:{{item.bgColor}}">{{item.icon}}</view>
            <text class="recent-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 今日精选 -->
    <view class="section">
      <view class="sec-head">
        <text class="sec-title">今日精选</text>
      </view>
      <scroll-view class="feat-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view class="feat-row">
          <view
            class="feat-card"
            wx:for="{{featuredList}}"
            wx:key="id"
            style="background:{{item.gradient}}"
            data-id="{{item.id}}"
            data-path="{{item.path}}"
            bindtap="onFeaturedTap"
            hover-class="feat-card-hover"
          >
            <text class="feat-emoji">{{item.icon}}</text>
            <view class="feat-info">
              <text class="feat-title">{{item.title}}</text>
              <text class="feat-sub">{{item.subtitle}}</text>
            </view>
            <view class="feat-go">打开</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 全部分类 -->
    <view class="section">
      <view class="sec-head">
        <text class="sec-title">全部分类</text>
      </view>
      <view class="cat-grid">
        <view
          class="cat-card"
          wx:for="{{categoryList}}"
          wx:key="id"
          style="background:{{item.gradient}}"
          data-index="{{index}}"
          bindtap="onCategoryTap"
          hover-class="cat-card-hover"
        >
          <text class="cat-emoji">{{item.icon}}</text>
          <view class="cat-meta">
            <text class="cat-name">{{item.name}}</text>
            <text class="cat-count">{{item.count}} 个工具</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 分类工具列表 -->
    <view id="toolList" class="section">
      <view class="sec-head">
        <view class="cat-dot" style="background:{{activeColor}}"></view>
        <text class="sec-title">{{activeCategoryName}}</text>
        <text class="sec-count">{{currentTools.length}} 个</text>
      </view>
      <view class="tool-list">
        <view
          class="tool-row"
          wx:for="{{currentTools}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onToolTap"
          hover-class="tool-row-hover"
        >
          <view class="tool-ico" style="background:{{item.bgColor}}">{{item.icon}}</view>
          <view class="tool-text">
            <text class="tool-name">{{item.name}}</text>
            <text class="tool-desc">{{item.description}}</text>
          </view>
          <text class="tool-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </block>
</view>
