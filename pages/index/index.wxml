<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索工具..."
        value="{{searchText}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text class="search-clear" wx:if="{{searchText}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{searchText && searchResults.length > 0}}" class="search-results">
    <view class="search-result-grid">
      <view class="search-result-item" wx:for="{{searchResults}}" wx:key="id">
        <tool-card
          toolId="{{item.id}}"
          name="{{item.name}}"
          icon="{{item.icon}}"
          description="{{item.description}}"
          color="{{item.categoryColor}}"
          bgColor="{{item.categoryBgColor}}"
          path="{{item.path}}"
        />
      </view>
    </view>
  </view>

  <!-- 搜索无结果 -->
  <view wx:if="{{searchText && searchResults.length === 0}}" class="search-empty">
    <text class="search-empty-icon">🔍</text>
    <text class="search-empty-text">没有找到匹配的工具</text>
  </view>

  <!-- 分类标签栏 + 工具宫格 -->
  <view wx:if="{{!searchText}}" class="main-content">
    <!-- 分类标签栏 -->
    <view class="tabs-wrapper">
      <scroll-view class="category-tabs" scroll-x="true" enhanced="true" show-scrollbar="false">
        <view class="tabs-inner">
          <view
            class="category-tab {{activeCategoryIndex === index ? 'active' : ''}}"
            wx:for="{{categoryList}}"
            wx:key="id"
            data-index="{{index}}"
            bindtap="onCategoryTap"
            style="{{activeCategoryIndex === index ? 'background-color: ' + item.color + ';' : ''}}"
          >
            <text class="tab-icon">{{item.icon}}</text>
            <text class="tab-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 工具图标宫格 -->
    <view class="tool-grid-container">
      <view class="tool-grid">
        <view
          class="tool-grid-item"
          wx:for="{{currentTools}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onToolTap"
          hover-class="tool-grid-item-hover"
        >
          <view class="tool-icon-wrap" style="background-color: {{item.bgColor}}">
            <text class="tool-icon">{{item.icon}}</text>
          </view>
          <text class="tool-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
