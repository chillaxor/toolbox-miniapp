<view class="page" style="background-color:{{bgColor}}">
  <!-- 背景图：有图时显示（来自 Gitee）；无图时由页面纯色兜底 -->
  <image wx:if="{{bgUrl}}" class="bg" src="{{bgUrl}}" mode="aspectFill"></image>

  <!-- 顶部统计 -->
  <view class="stats">
    <view class="stat-card">
      <text class="stat-num">{{totalInsert}}</text>
      <text class="stat-label">总插香</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{todayInsert}}</text>
      <text class="stat-label">今日插香</text>
    </view>
    <view class="stat-card">
      <text class="stat-num gold">{{totalMerit}}</text>
      <text class="stat-label">功德总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num gold">{{todayMerit}}</text>
      <text class="stat-label">今日功德</text>
    </view>
  </view>

  <!-- 香炉场景 -->
  <view class="censer-scene">
    <!-- 左蜡烛 -->
    <view class="candle-wrap candle-wrap-left">
      <view class="flame" wx:if="{{candleLeftLoaded}}">
        <view class="flame-inner"></view>
        <view class="flame-glow"></view>
      </view>
      <image class="candle" src="{{candleLeftUrl}}" mode="aspectFit" bindload="onCandleLeftLoad" />
    </view>
    <!-- 右蜡烛 -->
    <view class="candle-wrap candle-wrap-right">
      <view class="flame" wx:if="{{candleRightLoaded}}">
        <view class="flame-inner"></view>
        <view class="flame-glow"></view>
      </view>
      <image class="candle" src="{{candleRightUrl}}" mode="aspectFit" bindload="onCandleRightLoad" />
    </view>

    <!-- 香烟（燃烧时显示） -->
    <view class="smoke-zone" wx:if="{{isBurning}}">
      <view class="smoke" style="left: calc(50% - 64rpx);"></view>
      <view class="smoke" style="left: 50%;"></view>
      <view class="smoke" style="left: calc(50% + 64rpx);"></view>
    </view>

    <!-- 香炉：空状态淡显 / 燃烧状态亮起 -->
    <view class="censer-image-wrapper">
      <image wx:if="{{isBurning}}" class="censer-image burning" src="{{burningImage}}" mode="aspectFit" />
      <image wx:else class="censer-image empty" src="{{burnerImage}}" mode="aspectFit" />
    </view>
  </view>


  <!-- 木鱼 -->
  <view class="woodfish-area">
    <view class="merit-floats">
      <block wx:for="{{meritFloats}}" wx:key="id">
        <text class="merit-float" style="left:{{item.left}}%">+1</text>
      </block>
    </view>
    <view class="woodfish-wrap {{meritStrike ? 'striking' : ''}}" bindtap="tapWoodfish">
      <image class="woodfish" src="../../assets/blessing/fish_round.png" mode="aspectFit"></image>
    </view>
    <image class="mallet" src="../../assets/blessing/mallet_red.png" mode="aspectFit" bindtap="tapWoodfish"></image>
    <text class="woodfish-tip">轻敲木鱼 · 功德 +1</text>
  </view>
  <!-- 燃烧倒计时（独立显示，不在香上） -->
  <view class="burn-countdown" wx:if="{{isBurning}}">
    <text class="burn-countdown-text">🔥 香燃烧中 · 剩余 {{burnRemainText}}</text>
  </view>

  <!-- 插香按钮 -->
  <view class="insert-wrap">
    <view class="btn-group">
      <view class="insert-btn {{isBurning ? 'disabled' : ''}}" bindtap="openIncensePicker">
        <text class="insert-icon">{{isBurning ? '🔥' : '🕯'}}</text>
        <text class="insert-text">{{isBurning ? '香燃烧中' : '插香祈福'}}</text>
      </view>
    </view>
    <text class="insert-hint">{{isBurning ? '香烧完即可再次插香' : '选择香型，虔诚供奉'}}</text>
  </view>
  <!-- 佛祖签悬浮按钮（保留原悬浮位置） -->
  <view class="lingqian-fab" bindtap="openLingqian">
    <view class="lingqian-fab-inner">🎋</view>
    <text class="lingqian-fab-text">佛祖签</text>
  </view>

  <!-- 更换背景悬浮小图标（位于佛祖签下方） -->
  <view class="bg-fab" bindtap="openBgPicker">
    <view class="bg-fab-inner">🖼</view>
    <text class="bg-fab-text">背景</text>
  </view>

  <!-- 莲花灯悬浮按钮（左下，与佛祖签 FAB 对称；图片走云函数，同蜡烛） -->
  <view class="lotus-lamp {{lampLit ? 'lit' : ''}}" bindtap="tapLotusLamp">
    <view class="lotus-lamp-slot {{lotusLampUrl ? 'has-img' : ''}}">
      <image wx:if="{{lotusLampUrl}}" class="lotus-lamp-img" src="{{lotusLampUrl}}" mode="aspectFit" />
    </view>
    <text class="lotus-lamp-text">{{lampLit ? '心灯明' : '点灯'}}</text>
  </view>

  <!-- 插香选择器 -->
  <view class="mask {{showIncensePicker ? 'show' : ''}}" bindtap="closeIncensePicker">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">请选择香型</view>
      <scroll-view scroll-y class="incense-options">
        <view class="incense-grid">
          <view class="incense-cell {{selectedType === index ? 'active' : ''}}" wx:for="{{incenseTypes}}" wx:key="id" data-index="{{index}}" bindtap="selectIncense">
            <image class="opt-img" src="{{item.image}}" mode="aspectFit"></image>
          </view>
        </view>
      </scroll-view>
      <view class="sheet-cancel" bindtap="closeIncensePicker">取消</view>
    </view>
  </view>

  <!-- 背景图选择器 -->
  <view class="mask {{showBgPicker ? 'show' : ''}}" bindtap="closeBgPicker">
    <view class="sheet" catchtap="noop">
      <view class="sheet-title">选择背景</view>
      <scroll-view scroll-y class="bg-options">
        <view class="bg-grid">
          <view class="bg-cell {{selectedBg === index ? 'active' : ''}}" wx:for="{{bgList}}" wx:key="id" data-index="{{index}}" bindtap="selectBg">
            <view wx:if="{{item.color}}" class="bg-thumb" style="background:{{item.color}}"></view>
            <image wx:else class="bg-thumb" src="{{item.image}}" mode="aspectFill"></image>
          </view>
        </view>
      </scroll-view>
      <view class="sheet-cancel" bindtap="closeBgPicker">取消</view>
    </view>
  </view>

  <!-- 佛祖签弹窗 -->
  <view class="mask qian-mask {{showLingqian ? 'show' : ''}}" bindtap="closeLingqian">
    <view class="qian-panel" catchtap="noop">
      <view class="qian-close" bindtap="closeLingqian">✕</view>

      <block wx:if="{{!selectedQian}}">
        <view class="qian-title">佛祖灵签 · 共 {{lingqianList.length}} 签</view>
        <scroll-view scroll-y class="qian-list">
          <view class="qian-item" wx:for="{{lingqianList}}" wx:key="id" data-id="{{item.id}}" bindtap="selectQian">
            <text class="qian-index">{{item.id}}</text>
            <text class="qian-story">{{item.story}}</text>
            <text class="qian-level {{item.levelClass}}">{{item.level}}</text>
          </view>
        </scroll-view>
      </block>

      <block wx:else>
        <view class="qian-detail">
          <view class="qian-detail-head">
            <text class="qian-detail-id">第 {{selectedQian.id}} 签</text>
            <text class="qian-detail-level {{selectedQian.levelClass}}">{{selectedQian.level}}</text>
          </view>
          <view class="qian-detail-story">{{selectedQian.story}}</view>
          <image wx:if="{{selectedQian.img}}" class="qian-detail-img" src="{{selectedQian.img}}" mode="aspectFit"></image>
          <view class="qian-detail-poem">
            <text class="label">签诗</text>
            <text class="poem-text">{{selectedQian.qianShi}}</text>
          </view>
          <view class="qian-detail-jie">
            <text class="label">诗解</text>
            <text class="jie-text">{{selectedQian.shiJie}}</text>
          </view>
          <scroll-view scroll-y class="jie-scroll">
            <view class="jie-block" wx:for="{{selectedQian.jieQian}}" wx:key="title" wx:for-item="jq">
              <text class="jie-block-title">{{jq.title}}</text>
              <text class="jie-block-content">{{jq.content}}</text>
            </view>
          </scroll-view>
          <view class="qian-back" bindtap="backToQianList">← 返回签列表</view>
        </view>
      </block>
    </view>
  </view>
</view>
