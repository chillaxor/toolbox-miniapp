/* ===== 基础 ===== */
.page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: #1a120b;
}

.bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 无遮罩：背景图最清晰透出 */
.stats, .censer-scene, .insert-wrap, .woodfish-area, .lingqian-fab, .mask {
  position: relative;
  z-index: 2;
}

/* ===== 顶部统计 ===== */
.stats {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 40rpx 40rpx 10rpx;
  box-sizing: border-box;
}

.stat-card {
  width: 48%;
  margin-bottom: 24rpx;
  padding: 26rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(232, 200, 122, 0.25);
  border-radius: 20rpx;
  backdrop-filter: blur(8rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.3);
}

.stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #f3e3c3;
  line-height: 1.2;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.stat-num.gold {
  color: #e8c87a;
  text-shadow: 0 0 16rpx rgba(232, 200, 122, 0.6);
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(243, 227, 195, 0.7);
  letter-spacing: 2rpx;
}

/* ===== 香炉场景 ===== */
.censer-scene {
  position: relative;
  width: 100%;
  height: 480rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-top: 6rpx;
}

/* 蜡烛（使用原素材 left.png / right.png） */
.candle {
  position: absolute;
  bottom: 8rpx;
  width: 132rpx;
  height: 360rpx;
  opacity: 0.96;
  z-index: 3;
  filter: drop-shadow(0 6rpx 14rpx rgba(0, 0, 0, 0.45));
}

.candle-left {
  left: 36rpx;
  animation: candleSwayLeft 5s ease-in-out infinite;
}

.candle-right {
  right: 36rpx;
  animation: candleSway 5s ease-in-out infinite;
}

@keyframes candleSway {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-4rpx) rotate(0.6deg); }
  75% { transform: translateY(2rpx) rotate(-0.6deg); }
}

@keyframes candleSwayLeft {
  0%, 100% { transform: scaleX(-1) translateY(0) rotate(0deg); }
  25% { transform: scaleX(-1) translateY(-4rpx) rotate(0.6deg); }
  75% { transform: scaleX(-1) translateY(2rpx) rotate(-0.6deg); }
}

/* 香炉图片 */
.censer-image-wrapper {
  position: relative;
  width: 320rpx;
  height: 360rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 4;
}

.censer-image {
  width: 320rpx;
  height: 360rpx;
  transition: opacity 0.3s ease, filter 0.3s ease;
  filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.5));
}

/* 空状态：淡淡显示香炉轮廓 */
.censer-image.empty {
  opacity: 0.16;
  filter: grayscale(80%) brightness(0.7) drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

/* 燃烧状态：亮起并轻微发光 */
.censer-image.burning {
  opacity: 1;
  animation: glowPulse 2s ease-in-out infinite;
}

@keyframes glowPulse {
  0% { filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.5)) brightness(1); }
  50% { filter: drop-shadow(0 8rpx 30rpx rgba(232, 200, 122, 0.35)) brightness(1.08); }
  100% { filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.5)) brightness(1); }
}

/* 燃烧倒计时（独立于香炉下方显示） */
.burn-countdown {
  display: flex;
  justify-content: center;
  margin-top: 18rpx;
}

.burn-countdown-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8c87a;
  letter-spacing: 1rpx;
  background: rgba(36, 24, 14, 0.7);
  border: 1rpx solid rgba(232, 200, 122, 0.45);
  border-radius: 40rpx;
  padding: 12rpx 30rpx;
  text-shadow: 0 2rpx 8rpx rgba(232, 200, 122, 0.3);
  font-variant-numeric: tabular-nums;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.3);
}

/* 香烟 */
.smoke-zone {
  position: absolute;
  bottom: 300rpx;
  left: 0;
  right: 0;
  height: 220rpx;
  pointer-events: none;
  z-index: 5;
  overflow: visible;
}

.smoke {
  position: absolute;
  bottom: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(235, 235, 235, 0.55) 0%, rgba(210, 210, 210, 0.25) 50%, rgba(200, 200, 200, 0) 100%);
  opacity: 0;
  animation: smokeRise 3.2s ease-out infinite;
}

@keyframes smokeRise {
  0% { transform: translate(-50%, 0) scale(0.4); opacity: 0; }
  12% { opacity: 0.75; }
  50% { transform: translate(calc(-50% + 18rpx), -90rpx) scale(2.2); opacity: 0.4; }
  100% { transform: translate(calc(-50% - 28rpx), -210rpx) scale(4.5); opacity: 0; }
}

/* ===== 插香按钮 ===== */
.insert-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 30rpx;
}

.insert-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 360rpx;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #c9a84c, #e8c87a);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(201, 168, 76, 0.4), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.4);
  transition: transform 0.15s ease, opacity 0.2s ease;
}

.insert-btn:active {
  transform: scale(0.96);
}

.insert-btn.disabled {
  background: linear-gradient(135deg, #8a6d3b, #5c4626);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.3);
}

.insert-icon {
  font-size: 34rpx;
  margin-right: 12rpx;
}

.insert-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #3a2c18;
  letter-spacing: 4rpx;
}

.insert-btn.disabled .insert-text {
  color: #f3e3c3;
}

.insert-hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(243, 227, 195, 0.5);
  letter-spacing: 2rpx;
}

/* ===== 木鱼 ===== */
.woodfish-area {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 30rpx;
  padding-bottom: 60rpx;
}

.merit-floats {
  position: absolute;
  top: -40rpx;
  left: 0;
  right: 0;
  height: 120rpx;
  pointer-events: none;
}

.merit-float {
  position: absolute;
  font-size: 44rpx;
  font-weight: 700;
  color: #e8c87a;
  text-shadow: 0 0 12rpx rgba(232, 200, 122, 0.8);
  animation: meritFloat 1s ease-out forwards;
}

@keyframes meritFloat {
  0% { transform: translateY(0); opacity: 0; }
  20% { opacity: 1; }
  100% { transform: translateY(-110rpx); opacity: 0; }
}

.woodfish-wrap {
  width: 260rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.12s ease;
}

.woodfish-wrap.striking {
  transform: scale(0.9) rotate(-3deg);
}

.woodfish {
  width: 240rpx;
  height: 190rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.5));
}

.mallet {
  position: absolute;
  top: -10rpx;
  right: 150rpx;
  width: 150rpx;
  height: 150rpx;
  transform-origin: 80% 80%;
  transition: transform 0.12s ease;
  filter: drop-shadow(0 4rpx 10rpx rgba(0, 0, 0, 0.5));
}

.woodfish-wrap.striking ~ .mallet {
  transform: rotate(22deg);
}

.woodfish-tip {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(243, 227, 195, 0.6);
  letter-spacing: 2rpx;
}

/* ===== 佛祖签悬浮按钮（保留原位置：右下，木鱼上方）===== */
.lingqian-fab {
  position: fixed;
  right: 30rpx;
  bottom: 240rpx;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: rgba(201, 168, 76, 0.18);
  border: 1rpx solid rgba(232, 200, 122, 0.5);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.4);
}

.lingqian-fab-inner {
  font-size: 44rpx;
  line-height: 1;
}

.lingqian-fab-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #e8c87a;
  letter-spacing: 1rpx;
}

/* ===== 弹窗通用 ===== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 50;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
}

.mask.show {
  opacity: 1;
  visibility: visible;
}

/* 插香选择器（底部滑入）*/
.sheet {
  width: 100%;
  background: linear-gradient(180deg, #2a1d14, #1c1410);
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 40rpx 50rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  border-top: 1rpx solid rgba(232, 200, 122, 0.3);
}

.mask.show .sheet {
  transform: translateY(0);
}

.sheet-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #e8c87a;
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
}

.incense-options {
  display: flex;
  flex-direction: column;
}

.incense-option {
  display: flex;
  align-items: center;
  padding: 22rpx 16rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(232, 200, 122, 0.2);
  border-radius: 20rpx;
}

.opt-img {
  width: 72rpx;
  height: 82rpx;
}

.opt-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 20rpx;
}

.opt-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #f3e3c3;
}

.opt-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(243, 227, 195, 0.6);
}

.opt-arrow {
  font-size: 44rpx;
  color: rgba(232, 200, 122, 0.6);
}

.sheet-cancel {
  margin-top: 14rpx;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: rgba(243, 227, 195, 0.7);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
}

/* 佛祖签弹窗（居中面板）*/
.qian-panel {
  position: relative;
  width: 86%;
  max-height: 82vh;
  background: linear-gradient(180deg, #2a1d14, #1c1410);
  border: 1rpx solid rgba(232, 200, 122, 0.3);
  border-radius: 28rpx;
  padding: 60rpx 30rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.6);
}

.mask.show .qian-panel {
  animation: panelPop 0.3s ease;
}

@keyframes panelPop {
  0% { transform: scale(0.9); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.qian-close {
  position: absolute;
  top: 18rpx;
  right: 24rpx;
  font-size: 38rpx;
  color: rgba(243, 227, 195, 0.6);
  z-index: 2;
}

.qian-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #e8c87a;
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
}

.qian-list {
  flex: 1;
  max-height: 70vh;
}

.qian-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border-left: 6rpx solid rgba(232, 200, 122, 0.4);
}

.qian-index {
  width: 56rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #e8c87a;
  text-align: center;
}

.qian-story {
  flex: 1;
  margin: 0 16rpx;
  font-size: 28rpx;
  color: #f3e3c3;
}

.qian-level {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  color: #fff;
}

/* 签等级配色 */
.level-great { background: linear-gradient(135deg, #e8b84c, #c98a2c); color: #3a2c18 !important; }
.level-good { background: #d98c3f; }
.level-mid { background: #6b8e5a; }
.level-low { background: #7a8aa0; }
.level-bad { background: #a05a5a; }

/* 签详情 */
.qian-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
}

.qian-detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.qian-detail-id {
  font-size: 30rpx;
  font-weight: 600;
  color: #f3e3c3;
}

.qian-detail-level {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.qian-detail-story {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #e8c87a;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 0 14rpx rgba(232, 200, 122, 0.5);
}

.qian-detail-img {
  width: 200rpx;
  height: 200rpx;
  align-self: center;
  margin-bottom: 16rpx;
}

.qian-detail-poem, .qian-detail-jie {
  margin-bottom: 14rpx;
}

.label {
  display: inline-block;
  font-size: 24rpx;
  color: #e8c87a;
  border: 1rpx solid rgba(232, 200, 122, 0.5);
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
  margin-bottom: 10rpx;
}

.poem-text, .jie-text {
  display: block;
  font-size: 27rpx;
  line-height: 1.7;
  color: #f3e3c3;
}

.jie-scroll {
  flex: 1;
  min-height: 120rpx;
  margin-top: 8rpx;
}

.jie-block {
  padding: 16rpx;
  margin-bottom: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 14rpx;
}

.jie-block-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #e8c87a;
  margin-bottom: 8rpx;
}

.jie-block-content {
  display: block;
  font-size: 25rpx;
  line-height: 1.7;
  color: rgba(243, 227, 195, 0.85);
}

.qian-back {
  margin-top: 16rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #e8c87a;
  background: rgba(232, 200, 122, 0.12);
  border-radius: 16rpx;
  border: 1rpx solid rgba(232, 200, 122, 0.3);
}
