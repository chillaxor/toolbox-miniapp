.clear-btn { text-align: right; padding: 16rpx 0; }
.date-header { padding: 16rpx 0 8rpx; }
.date-text { font-size: 26rpx; color: #999; font-weight: 600; }
.history-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 2rpx solid #F0F0F0; }
.history-item:last-child { border-bottom: none; }
.history-left { flex: 1; }
.history-name { font-size: 28rpx; font-weight: 500; color: #333; display: block; }
.history-summary { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 480rpx; }
.history-time { font-size: 22rpx; color: #ccc; margin-left: 16rpx; }
.empty-box { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
