/* ========== 页面整体 ========== */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #2C1810 0%, #3D2817 40%, #1A0F08 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 80rpx;
  overflow-x: hidden;
}

/* ========== 顶部背景图 ========== */
.bg-wrapper {
  position: relative;
  width: 100%;
  height: 500rpx;
  overflow: hidden;
}

.bg-image {
  width: 100%;
  height: 100%;
  opacity: 1;
}

.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(44, 24, 16, 0.3) 0%, rgba(44, 24, 16, 0.7) 70%, rgba(44, 24, 16, 0.95) 100%);
}

.count-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.count-label {
  font-size: 26rpx;
  color: rgba(245, 222, 179, 0.7);
  letter-spacing: 4rpx;
}

.count-number {
  font-size: 88rpx;
  font-weight: bold;
  color: #F5DEB3;
  text-shadow: 0 4rpx 20rpx rgba(255, 215, 0, 0.3);
  line-height: 1.2;
  margin: 4rpx 0;
}

.count-today {
  font-size: 24rpx;
  color: rgba(245, 222, 179, 0.6);
}

/* ========== 香炉区域 ========== */
.censer-area {
  position: relative;
  width: 100%;
  height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 40rpx;
  margin-top: -20rpx;
  overflow: visible;
}

/* ========== 烟雾区域 ========== */
.smoke-zone {
  position: absolute;
  bottom: 410rpx;
  left: 0;
  right: 0;
  height: 240rpx;
  overflow: visible;
  pointer-events: none;
  z-index: 5;
}

.smoke {
  position: absolute;
  bottom: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(235, 235, 235, 0.55) 0%, rgba(210, 210, 210, 0.25) 50%, rgba(200, 200, 200, 0) 100%);
  opacity: 0;
  animation: smokeRise 3.2s ease-out infinite;
}

@keyframes smokeRise {
  0% {
    transform: translate(-50%, 0) scale(0.4);
    opacity: 0;
  }
  12% {
    opacity: 0.75;
  }
  50% {
    transform: translate(calc(-50% + 18rpx), -90rpx) scale(2.2);
    opacity: 0.4;
  }
  100% {
    transform: translate(calc(-50% - 28rpx), -210rpx) scale(4.5);
    opacity: 0;
  }
}

/* ========== 香炉图片 ========== */
.censer-image-wrapper {
  position: relative;
  width: 340rpx;
  height: 370rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 4;
}

.censer-image {
  width: 340rpx;
  height: 370rpx;
  transition: all 0.3s ease;
  filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.5));
}

.censer-image.empty {
  opacity: 0.15;
  filter: grayscale(80%) brightness(0.6) drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

.censer-image.burning {
  opacity: 1;
  animation: glowPulse 2s ease-in-out infinite;
}

@keyframes glowPulse {
  0% { filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.5)) brightness(1); }
  50% { filter: drop-shadow(0 8rpx 30rpx rgba(201, 168, 76, 0.3)) brightness(1.08); }
  100% { filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.5)) brightness(1); }
}

/* 燃烧倒计时徽章 */
.burn-badge {
  position: absolute;
  top: 10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(44, 24, 16, 0.85);
  border: 2rpx solid rgba(201, 168, 76, 0.4);
  border-radius: 16rpx;
  padding: 10rpx 24rpx;
  z-index: 6;
}

.burn-badge-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #C9A84C;
  letter-spacing: 3rpx;
  text-shadow: 0 2rpx 8rpx rgba(201, 168, 76, 0.3);
}

/* ========== 插香按钮 ========== */
.insert-btn-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
}

.insert-btn {
  width: 280rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #C9A84C 0%, #A08020 50%, #8B6914 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 105, 20, 0.4), inset 0 2rpx 6rpx rgba(255, 220, 150, 0.3);
  transition: all 0.2s ease;
}

.insert-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(139, 105, 20, 0.3), inset 0 2rpx 6rpx rgba(255, 220, 150, 0.2);
}

.insert-btn.burning-state {
  background: linear-gradient(135deg, #8B4513 0%, #6B3410 50%, #4A2810 100%);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.3);
}

.insert-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFF8E7;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.insert-hint {
  font-size: 22rpx;
  color: rgba(245, 222, 179, 0.4);
  margin-top: 16rpx;
}

/* ========== 香型选择器 ========== */
.type-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.type-picker-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.type-picker {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #3D2817 0%, #2C1810 100%);
  border-top: 2rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.type-picker.show {
  transform: translateY(0);
}

.picker-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #F5DEB3;
  text-align: center;
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}

.picker-scroll {
  width: 100%;
  max-height: 480rpx;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
}

.picker-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 10rpx;
  margin: 8rpx;
  background: rgba(60, 40, 25, 0.5);
  border: 1rpx solid rgba(201, 168, 76, 0.2);
  border-radius: 16rpx;
  width: calc((100% - 96rpx) / 4);
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.picker-item:active {
  transform: scale(0.95);
  background: rgba(201, 168, 76, 0.15);
  border-color: rgba(201, 168, 76, 0.5);
}

.picker-item-image {
  width: 90rpx;
  height: 100rpx;
}

.picker-item-name {
  font-size: 22rpx;
  color: #C9A84C;
  letter-spacing: 2rpx;
  text-align: center;
}

.picker-cancel {
  font-size: 28rpx;
  color: rgba(245, 222, 179, 0.6);
  text-align: center;
  margin-top: 28rpx;
  padding: 16rpx;
}

/* ========== 祝福语卡片 ========== */
.blessing-card {
  width: 620rpx;
  margin: 36rpx auto 0;
  padding: 32rpx 40rpx;
  background: rgba(60, 40, 25, 0.6);
  border: 1rpx solid rgba(201, 168, 76, 0.25);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.5s ease;
}

.blessing-card.show {
  opacity: 1;
  transform: translateY(0);
}

.blessing-icon {
  font-size: 40rpx;
}

.blessing-text {
  font-size: 30rpx;
  color: #F5DEB3;
  line-height: 1.6;
  letter-spacing: 2rpx;
  flex: 1;
}

/* ========== 等级卡片 ========== */
.level-card {
  width: 620rpx;
  margin: 28rpx auto 0;
  padding: 28rpx 36rpx;
  background: rgba(60, 40, 25, 0.5);
  border: 1rpx solid rgba(201, 168, 76, 0.2);
  border-radius: 20rpx;
}

.level-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.level-icon {
  font-size: 36rpx;
}

.level-card-title {
  font-size: 28rpx;
  color: rgba(245, 222, 179, 0.8);
  font-weight: bold;
}

.level-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.level-name-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #C9A84C;
  text-shadow: 0 2rpx 8rpx rgba(201, 168, 76, 0.3);
}

.level-bar-wrapper {
  width: 100%;
}

.level-bar-bg {
  width: 100%;
  height: 12rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 6rpx;
  overflow: hidden;
}

.level-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6914 0%, #C9A84C 50%, #F5DEB3 100%);
  border-radius: 6rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 8rpx rgba(201, 168, 76, 0.4);
}

.level-detail {
  font-size: 24rpx;
  color: rgba(245, 222, 179, 0.5);
}

/* ========== 佛祖签悬浮icon ========== */
.lingqian-fab {
  position: fixed;
  right: 30rpx;
  bottom: 160rpx;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #C9A84C 0%, #A08020 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(139, 105, 20, 0.5);
  z-index: 50;
  transition: transform 0.2s ease;
}

.lingqian-fab:active {
  transform: scale(0.9);
}

.lingqian-fab-icon {
  font-size: 36rpx;
}

/* ========== 签列表弹窗 ========== */
.lingqian-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.lingqian-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.lingqian-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #3D2817 0%, #2C1810 100%);
  border-top: 2rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.lingqian-panel.show {
  transform: translateY(0);
}

.lingqian-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #F5DEB3;
  text-align: center;
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
}

.lingqian-scroll {
  width: 100%;
  max-height: 500rpx;
}

.lingqian-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  background: rgba(60, 40, 25, 0.5);
  border: 1rpx solid rgba(201, 168, 76, 0.15);
  border-radius: 16rpx;
  gap: 16rpx;
  transition: all 0.2s ease;
}

.lingqian-item:active {
  background: rgba(201, 168, 76, 0.15);
  border-color: rgba(201, 168, 76, 0.4);
}

.lingqian-item-num {
  font-size: 26rpx;
  font-weight: bold;
  color: #C9A84C;
  min-width: 80rpx;
}

.lingqian-item-story {
  font-size: 26rpx;
  color: #F5DEB3;
  flex: 1;
}

.lingqian-item-level {
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.lingqian-item-level.level-great {
  color: #FF6B00;
  background: rgba(255, 107, 0, 0.15);
}

.lingqian-item-level.level-good {
  color: #C9A84C;
  background: rgba(201, 168, 76, 0.15);
}

.lingqian-item-level.level-mid {
  color: #F5DEB3;
  background: rgba(245, 222, 179, 0.1);
}

.lingqian-item-level.level-low {
  color: #8B6914;
  background: rgba(139, 105, 20, 0.1);
}

.lingqian-item-level.level-bad {
  color: #7A6A5A;
  background: rgba(122, 106, 90, 0.1);
}

.lingqian-cancel {
  font-size: 28rpx;
  color: rgba(245, 222, 179, 0.6);
  text-align: center;
  margin-top: 24rpx;
  padding: 16rpx;
}

/* ========== 签详情弹窗 ========== */
.lingqian-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.lingqian-detail-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.lingqian-detail {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 640rpx;
  max-height: 85vh;
  background: linear-gradient(180deg, #3D2817 0%, #2C1810 100%);
  border: 2rpx solid rgba(201, 168, 76, 0.3);
  border-radius: 24rpx;
  padding: 36rpx;
  z-index: 201;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.lingqian-detail.show {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, -50%) scale(1);
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(201, 168, 76, 0.2);
}

.detail-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(201, 168, 76, 0.2);
}

.detail-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #C9A84C;
}

.detail-story {
  font-size: 30rpx;
  color: #F5DEB3;
  font-weight: bold;
}

.detail-level {
  font-size: 24rpx;
  font-weight: bold;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.detail-level.level-great {
  color: #FF6B00;
  background: rgba(255, 107, 0, 0.15);
}

.detail-level.level-good {
  color: #C9A84C;
  background: rgba(201, 168, 76, 0.15);
}

.detail-level.level-mid {
  color: #F5DEB3;
  background: rgba(245, 222, 179, 0.1);
}

.detail-level.level-low {
  color: #8B6914;
  background: rgba(139, 105, 20, 0.1);
}

.detail-level.level-bad {
  color: #7A6A5A;
  background: rgba(122, 106, 90, 0.1);
}

.detail-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-section {
  padding: 16rpx 0;
}

.detail-section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #C9A84C;
  margin-bottom: 8rpx;
  display: block;
}

.detail-section-content {
  font-size: 24rpx;
  color: rgba(245, 222, 179, 0.8);
  line-height: 1.7;
  display: block;
}

.detail-jie-scroll {
  width: 100%;
  max-height: 300rpx;
  margin-top: 12rpx;
}

.detail-close {
  font-size: 28rpx;
  color: rgba(245, 222, 179, 0.6);
  text-align: center;
  margin-top: 20rpx;
  padding: 16rpx;
}
