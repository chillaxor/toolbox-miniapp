.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
  background: linear-gradient(160deg, #2a2140 0%, #1c1730 100%);
  color: #eee;
}

.fav {
  text-align: right;
  font-size: 26rpx;
  color: #ffd479;
  padding: 6rpx 4rpx 18rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  text-align: center;
  margin-top: 10rpx;
}
.sub {
  font-size: 24rpx;
  color: #b9aed6;
  text-align: center;
  margin: 12rpx 0 30rpx;
}

.sec-label {
  font-size: 28rpx;
  color: #cdbff0;
  margin: 24rpx 4rpx 12rpx;
}
.chip-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.chip {
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ddd;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}
.chip-on {
  background: #7A5AA8;
  color: #fff;
  border-color: #b79be0;
  font-weight: 700;
}

.btn-primary {
  margin-top: 36rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #8a63c8, #6d46b0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(122, 90, 168, 0.45);
}
.btn-disabled {
  opacity: 0.45;
  box-shadow: none;
}
.btn-ghost {
  margin-top: 18rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #7A5AA8;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #E6DCF5;
}
.tip {
  font-size: 22rpx;
  color: #9a8fc0;
  text-align: center;
  margin-top: 18rpx;
  line-height: 1.5;
}

/* ---------- play ---------- */
.topbar {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 18rpx;
}
.round-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffd479;
}
.score-now {
  font-size: 24rpx;
  color: #cdbff0;
  margin-top: 6rpx;
}

.clue-box {
  background: rgba(0, 0, 0, 0.22);
  border-radius: 18rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 18rpx;
  min-height: 70rpx;
}
.clue-empty {
  font-size: 24rpx;
  color: #8a7fb0;
  text-align: center;
  padding: 14rpx 0;
}
.clue-item {
  font-size: 28rpx;
  color: #fff;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}
.clue-item:last-child { border-bottom: none; }

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  margin: 8rpx 0 14rpx;
}
.cell {
  width: 62rpx;
  height: 62rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.25s ease;
}
.cell.on {
  background: #7A5AA8;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(122, 90, 168, 0.4);
}
.cell.off {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.25);
}
.cell.right {
  background: #2ecc71 !important;
  color: #fff !important;
  transform: scale(1.12);
  box-shadow: 0 0 0 4rpx #2ecc71;
}
.cell.wrong {
  background: #e74c3c !important;
  color: #fff !important;
}

.play-tip {
  font-size: 22rpx;
  color: #9a8fc0;
  text-align: center;
  margin: 6rpx 0 4rpx;
}

.reveal {
  margin-top: 20rpx;
  border-radius: 18rpx;
  padding: 22rpx;
  text-align: center;
}
.reveal-win { background: rgba(46, 204, 113, 0.18); }
.reveal-lose { background: rgba(231, 76, 60, 0.18); }
.reveal-title { font-size: 36rpx; font-weight: 800; }
.reveal-win .reveal-title { color: #6ef0a8; }
.reveal-lose .reveal-title { color: #ff8a7a; }
.reveal-sub { font-size: 26rpx; color: #d9d0ee; margin-top: 8rpx; }

/* ---------- result ---------- */
.vs {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 30rpx 0 16rpx;
}
.vs-side {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
}
.vs-side.win {
  background: rgba(255, 212, 121, 0.18);
  box-shadow: 0 0 0 3rpx #ffd479;
}
.vs-name { font-size: 28rpx; color: #cdbff0; }
.vs-score { font-size: 56rpx; font-weight: 800; color: #fff; margin-top: 8rpx; }
.vs-mid { padding: 0 18rpx; font-size: 28rpx; color: #8a7fb0; font-weight: 700; }

.winner {
  text-align: center;
  font-size: 38rpx;
  font-weight: 800;
  color: #ffd479;
  margin: 10rpx 0;
}
.best-line {
  text-align: center;
  font-size: 24rpx;
  color: #9a8fc0;
  margin-bottom: 24rpx;
}

.detail {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 10rpx 16rpx;
  margin-bottom: 24rpx;
}
.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 4rpx;
  font-size: 26rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.07);
}
.detail-row:last-child { border-bottom: none; }
.detail-head { color: #b9aed6; font-size: 24rpx; }
.detail-row .ok { color: #6ef0a8; font-weight: 700; }
.detail-row .no { color: #ff8a7a; }
