<view class="page">
  <view class="fav" bindtap="toggleFavorite">{{isFavorite ? '★ 已收藏' : '☆ 收藏'}}</view>

  <!-- ============ SETUP ============ -->
  <block wx:if="{{phase==='setup'}}">
    <view class="title">🔎 线索缩圈猜编号</view>
    <view class="sub">系统悄悄选一个编号，线索层层缩小，看谁用最少线索猜中</view>

    <view class="sec-label">编号范围</view>
    <view class="chip-row">
      <view wx:for="{{rangeSel}}" wx:key="*this" class="chip {{rangeN===item?'chip-on':''}}" bindtap="selectRange" data-v="{{item}}">{{item}} 个</view>
    </view>

    <view class="sec-label">每人关卡数</view>
    <view class="chip-row">
      <view wx:for="{{roundsSel}}" wx:key="*this" class="chip {{roundsEach===item?'chip-on':''}}" bindtap="selectRounds" data-v="{{item}}">{{item}} 关</view>
    </view>

    <view class="btn-primary" bindtap="onStart">开始对战 🎮</view>
    <view class="tip">双人对战：轮流各玩 {{roundsEach}} 关，各自独立谜底，比谁总分高</view>
  </block>

  <!-- ============ PLAY ============ -->
  <block wx:if="{{phase==='play'}}">
    <view class="topbar">
      <view class="round-label">{{roundLabel}}</view>
      <view class="score-now">{{curPlayerIdx===0 ? players[0].name : players[1].name}} 当前：{{curPlayerIdx===0 ? players[0].score : players[1].score}} 分</view>
    </view>

    <view class="clue-box">
      <view wx:if="{{clues.length===0}}" class="clue-empty">点「下一条线索」开始缩小范围</view>
      <view wx:for="{{clues}}" wx:key="text" class="clue-item">{{item.text}}</view>
    </view>

    <view class="grid">
      <view wx:for="{{cells}}" wx:key="num"
            class="cell {{item.candidate ? 'on' : 'off'}} {{revealed && item.num===answerNum ? 'right' : ''}} {{revealed && !win && item.num===guessNum ? 'wrong' : ''}}"
            bindtap="onCellTap" data-num="{{item.num}}">{{item.num}}</view>
    </view>

    <view class="play-tip">亮着的编号 = 还可能的答案，点它提交你的猜测</view>

    <block wx:if="{{!revealed}}">
      <view class="btn-primary {{canNextClue ? '' : 'btn-disabled'}}" bindtap="nextClue">下一条线索（{{usedClues}}/{{maxClues}}）</view>
    </block>

    <block wx:if="{{revealed}}">
      <view class="reveal {{win ? 'reveal-win' : 'reveal-lose'}}">
        <view class="reveal-title">{{win ? '🎉 猜中啦！' : '💥 猜错了'}}</view>
        <view class="reveal-sub">{{win ? ('+' + roundGain + ' 分（用了 ' + usedClues + ' 条线索）') : ('答案是 ' + answerNum + '，本关 0 分')}}</view>
      </view>
      <view class="btn-primary" bindtap="nextRound">{{roundSeq>=totalRounds ? '查看战绩' : '下一关 →'}}</view>
    </block>
  </block>

  <!-- ============ RESULT ============ -->
  <block wx:if="{{phase==='result'}}">
    <view class="title">🏁 对战结果</view>
    <view class="vs">
      <view class="vs-side {{p0win ? 'win' : ''}}">
        <view class="vs-name">{{players[0].name}}</view>
        <view class="vs-score">{{players[0].score}}</view>
      </view>
      <view class="vs-mid">VS</view>
      <view class="vs-side {{p1win ? 'win' : ''}}">
        <view class="vs-name">{{players[1].name}}</view>
        <view class="vs-score">{{players[1].score}}</view>
      </view>
    </view>

    <view class="winner">{{winnerText}}</view>
    <view class="best-line">历史最高总分：{{best}}</view>

    <view class="detail">
      <view class="detail-row detail-head">
        <view>关卡</view><view>{{players[0].name}}</view><view>{{players[1].name}}</view>
      </view>
      <view wx:for="{{players[0].details}}" wx:key="index" class="detail-row">
        <view>第 {{index+1}} 关</view>
        <view class="{{item.win ? 'ok' : 'no'}}">{{item.win ? ('+' + item.gain + ' / ' + item.clues + '条') : '✗'}}</view>
        <view class="{{players[1].details[index].win ? 'ok' : 'no'}}">{{players[1].details[index].win ? ('+' + players[1].details[index].gain + ' / ' + players[1].details[index].clues + '条') : '✗'}}</view>
      </view>
    </view>

    <view class="btn-primary" bindtap="replay">再来一局（交换先手）</view>
    <view class="btn-ghost" bindtap="onBackSetup">返回设置</view>
  </block>
</view>
