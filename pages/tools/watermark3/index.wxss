.image-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  border-radius: 12rpx;
  background-color: #F8F9FA;
  padding: 48rpx;
}

.picker-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.picker-desc {
  font-size: 24rpx;
  color: var(--color-hint);
}

/* 编辑区域 */
.edit-area {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
}

.toolbar-fixed {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 12rpx;
}

.tool-group {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  min-width: 72rpx;
}

.tool-icon {
  font-size: 32rpx;
  margin-bottom: 2rpx;
}

.tool-label {
  font-size: 22rpx;
  color: var(--color-secondary);
}

.action-hint {
  text-align: center;
  padding: 6rpx 0;
  margin-top: 4rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #E67E22;
  font-weight: 500;
}

.canvas-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-border);
  background: #F8F9FA;
  overflow: hidden;
}

.draw-canvas {
  border-radius: 8rpx;
  touch-action: none;
}

/* 参数卡片 */
.params-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-top: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.param-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.param-label {
  font-size: 26rpx;
  color: var(--color-secondary);
  width: 120rpx;
  flex-shrink: 0;
}

.param-slider {
  flex: 1;
}

.export-bar {
  margin-top: 12rpx;
}

.btn-export {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 加载动画 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E8E8E8;
  border-top-color: #E67E22;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.loading-sub {
  font-size: 24rpx;
  color: var(--color-hint);
}

/* 对比展示 */
.compare-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
}

.compare-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compare-label {
  font-size: 24rpx;
  color: var(--color-secondary);
  margin-bottom: 12rpx;
  font-weight: 600;
}

.compare-img {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-border);
}

.compare-divider {
  display: flex;
  align-items: center;
  padding: 0 4rpx;
}

.divider-icon {
  font-size: 36rpx;
  color: #E67E22;
  font-weight: 700;
}

.result-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.result-actions .btn-primary {
  flex: 1;
}

.sub-row {
  margin-top: 16rpx;
}

.btn-text {
  background: none;
  border: none;
  color: var(--color-hint);
  font-size: 26rpx;
  padding: 8rpx 0;
  line-height: 1.5;
}

.btn-text::after {
  border: none;
}

/* 调试信息 */
.debug-text {
  font-size: 24rpx;
  color: var(--color-secondary);
  line-height: 1.6;
  word-break: break-all;
  white-space: pre-wrap;
}

/* 通用 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  margin-bottom: 20rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E67E22 0%, #D35400 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-content {
  margin-left: 20rpx;
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.step-desc {
  font-size: 24rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 4rpx;
}
