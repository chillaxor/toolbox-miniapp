.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

/* Tab切换 */
.tab-bar {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 60rpx;
}

.tab-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 50rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
}

.tab-truth-active {
  background: linear-gradient(135deg, #E91E63, #F06292);
  box-shadow: 0 8rpx 30rpx rgba(233, 30, 99, 0.4);
}

.tab-truth-active .tab-text {
  color: #fff;
}

.tab-dare-active {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  box-shadow: 0 8rpx 30rpx rgba(255, 152, 0, 0.4);
}

.tab-dare-active .tab-text {
  color: #fff;
}

/* 卡片区域 */
.card-area {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 500rpx;
  margin-bottom: 60rpx;
}

.card {
  width: 600rpx;
  min-height: 460rpx;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.3s ease;
}

.card-flip {
  animation: flipCard 0.4s ease;
}

@keyframes flipCard {
  0% { transform: rotateY(0deg) scale(1); }
  50% { transform: rotateY(90deg) scale(0.9); }
  100% { transform: rotateY(0deg) scale(1); }
}

.card-truth {
  background: linear-gradient(145deg, #E91E63, #AD1457);
  box-shadow: 0 20rpx 60rpx rgba(233, 30, 99, 0.3);
}

.card-dare {
  background: linear-gradient(145deg, #FF9800, #E65100);
  box-shadow: 0 20rpx 60rpx rgba(255, 152, 0, 0.3);
}

.card-badge {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.card-number {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 30rpx;
}

.card-text {
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  line-height: 1.6;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.card-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部操作 */
.action-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.btn-next {
  width: 500rpx;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  border: none;
}

.btn-truth {
  background: linear-gradient(135deg, #E91E63, #F06292);
  box-shadow: 0 8rpx 30rpx rgba(233, 30, 99, 0.4);
}

.btn-dare {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  box-shadow: 0 8rpx 30rpx rgba(255, 152, 0, 0.4);
}

.btn-shuffle {
  width: 300rpx;
  height: 70rpx;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.1);
}

/* 进度 */
.progress-info {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}