<view class="container">
  <!-- 顶部tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'truth' ? 'tab-truth-active' : ''}}" bindtap="switchTab" data-tab="truth">
      <text class="tab-icon">💕</text>
      <text class="tab-text">真心话</text>
    </view>
    <view class="tab-item {{activeTab === 'dare' ? 'tab-dare-active' : ''}}" bindtap="switchTab" data-tab="dare">
      <text class="tab-icon">🔥</text>
      <text class="tab-text">大冒险</text>
    </view>
  </view>

  <!-- 题目卡片 -->
  <view class="card-area" bindtap="nextQuestion">
    <view class="card {{flipping ? 'card-flip' : ''}} {{activeTab === 'truth' ? 'card-truth' : 'card-dare'}}">
      <view class="card-badge">{{activeTab === 'truth' ? '💕 真心话' : '🔥 大冒险'}}</view>
      <view class="card-number">第 {{questionIndex + 1}} 题</view>
      <view class="card-text">{{currentQuestion}}</view>
      <view class="card-hint">点击卡片换一题</view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="action-bar">
    <view class="btn-next {{activeTab === 'truth' ? 'btn-truth' : 'btn-dare'}}" bindtap="nextQuestion">
      换一题 🎲
    </view>
    <view class="btn-shuffle" bindtap="shuffleAll">
      重新洗牌 🔀
    </view>
  </view>

  <!-- 已用题数 -->
  <view class="progress-info">
    已出 {{usedCount}} / {{totalCount}} 题
  </view>
</view>