.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0d0221 0%, #150535 40%, #2a0845 100%);
  padding: 30rpx;
  position: relative;
  overflow: hidden;
}

/* 星空背景 */
.sky-bg {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}

.star {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 50%;
  animation: twinkle 2s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* 许愿区 */
.wishing-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.lantern {
  font-size: 120rpx;
  animation: lanternSway 3s ease-in-out infinite;
}

.lantern-float {
  animation: lanternRise 2s ease-out forwards;
}

@keyframes lanternSway {
  0%, 100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}

@keyframes lanternRise {
  0% { transform: translateY(0) scale(1); opacity: 1; }
  100% { transform: translateY(-300rpx) scale(0.5); opacity: 0; }
}

.wishing-hint {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-top: 30rpx;
}

/* 弹窗 */
.wish-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  width: 600rpx;
  background: linear-gradient(145deg, #2a0845, #1a0530);
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.3);
}

.modal-title {
  text-align: center;
  color: #FFD700;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.wish-input {
  width: 100%;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  color: rgba(255, 255, 255, 0.4);
  font-size: 22rpx;
  margin-top: 10rpx;
}

.modal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 20rpx 0 30rpx;
}

.tag-item {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.tag-active {
  color: #FFD700;
  background: rgba(255, 215, 0, 0.15);
  border-color: #FFD700;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
}

.btn-confirm {
  background: linear-gradient(135deg, #FFD700, #FFA000);
  color: #1a0530;
  font-weight: bold;
}

/* 愿望墙 */
.wish-wall {
  margin-top: 40rpx;
}

.wall-title {
  color: #FFD700;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.wish-empty {
  text-align: center;
  color: rgba(255, 255, 255, 0.4);
  padding: 80rpx 0;
  font-size: 28rpx;
}

.wish-card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.15);
}

.wish-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 215, 0, 0.2);
  color: #FFD700;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.wish-content {
  color: #fff;
  font-size: 30rpx;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.wish-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.wish-time {
  color: rgba(255, 255, 255, 0.3);
  font-size: 22rpx;
}

.wish-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.wish-action {
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
}

.wish-lights {
  color: #FFD700;
  font-size: 22rpx;
}

.wish-del {
  color: rgba(255, 100, 100, 0.5);
}