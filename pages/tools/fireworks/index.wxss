.page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #000;
}

.page.fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
}

.fireworks-canvas {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

/* 顶部栏 */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 12rpx);
}

.fav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.fav-btn text {
  font-size: 36rpx;
  color: #ccc;
}

.fav-btn.active text {
  color: #FFD700;
}

.panel-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.panel-toggle text {
  font-size: 36rpx;
  color: #fff;
}

/* 控制面板 */
.control-panel {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 580rpx;
  z-index: 20;
  background: rgba(10, 10, 20, 0.92);
  backdrop-filter: blur(20px);
  transform: translateX(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.control-panel.show {
  transform: translateX(0);
}

.control-panel.hide {
  transform: translateX(100%);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.panel-actions {
  display: flex;
  gap: 12rpx;
}

.panel-btn {
  padding: 8rpx 20rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 20rpx;
}

.panel-btn text {
  font-size: 22rpx;
  color: #aaa;
}

.panel-scroll {
  flex: 1;
  padding: 16rpx 24rpx;
}

/* 配置组 */
.config-group {
  margin-bottom: 28rpx;
}

.config-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

/* 烟花类型网格 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.type-item {
  width: calc(33.33% - 8rpx);
  padding: 14rpx 8rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-item.active {
  background: rgba(255, 200, 50, 0.15);
  border-color: #FFD700;
}

.type-name {
  display: block;
  font-size: 24rpx;
  color: #fff;
  margin-bottom: 4rpx;
}

.type-en {
  display: block;
  font-size: 18rpx;
  color: #666;
}

.type-item.active .type-name {
  color: #FFD700;
}

/* 选项行 */
.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.option-chip {
  padding: 10rpx 24rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.option-chip text {
  font-size: 24rpx;
  color: #ccc;
}

.option-chip.active {
  background: rgba(255, 200, 50, 0.15);
  border-color: #FFD700;
}

.option-chip.active text {
  color: #FFD700;
}

/* 开关列表 */
.switch-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 12rpx;
}

.switch-text {
  font-size: 26rpx;
  color: #ddd;
}

.switch-indicator {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.15);
  position: relative;
  transition: background 0.2s;
}

.switch-indicator.on {
  background: #FFD700;
}

.switch-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: transform 0.2s;
}

.switch-indicator.on .switch-dot {
  transform: translateX(36rpx);
}

/* 全屏退出按钮 */
.fullscreen-exit {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  z-index: 30;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.fullscreen-exit text {
  font-size: 36rpx;
  color: #fff;
}

/* 底部寄语 */
.footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 5;
  text-align: center;
  padding: 30rpx 40rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 30rpx);
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}

.footer-copy {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.35);
}
