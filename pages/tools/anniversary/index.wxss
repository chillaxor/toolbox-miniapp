.empty-box {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: var(--color-hint);
}

.list {
  margin-bottom: 24rpx;
}

.item {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-today {
  border-left: 8rpx solid #FF6B35;
}

.item-left {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.item-date {
  display: block;
  font-size: 24rpx;
  color: var(--color-hint);
}

.item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-days {
  font-size: 28rpx;
  font-weight: 700;
}

.item-days.future {
  color: #FF6B35;
}

.item-days.past {
  color: var(--color-hint);
}

.item-del {
  font-size: 36rpx;
  color: var(--color-hint);
  padding: 8rpx;
}

.add-btn {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  border: 2rpx dashed var(--color-border);
}

.add-btn-text {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 600;
}

.card-title {
  font-size: 28rpx;
  color: var(--color-secondary);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-secondary);
  margin-bottom: 8rpx;
}

.form-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #F5F5F5;
  color: var(--color-secondary);
  font-size: 28rpx;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: var(--color-text);
  color: #fff;
  font-size: 28rpx;
  border: none;
}

.btn-confirm::after {
  border: none;
}
