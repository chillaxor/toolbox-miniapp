.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding: 16rpx;
  background: #F5F5F5;
}

.topbar {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.title { font-size: 32rpx; font-weight: 600; color: #333; }
.topbtns { display: flex; gap: 12rpx; }
.btn {
  padding: 10rpx 22rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #fff;
}
.btn.run { background: #639922; }
.btn.run.disabled { opacity: 0.5; }
.btn.reset { background: #888780; }
.btn.clear { background: #D85A30; }

.map-wrap { flex: 0 0 auto; display: flex; justify-content: center; margin-bottom: 12rpx; }
.map {
  position: relative;
  background-color: #fff;
  background-image:
    linear-gradient(to right, #e3e3e3 1rpx, transparent 1rpx),
    linear-gradient(to bottom, #e3e3e3 1rpx, transparent 1rpx);
  border: 2rpx solid #d0d0d0;
  border-radius: 12rpx;
  overflow: hidden;
}
.target {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}
.char {
  position: absolute;
  top: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  transition: transform 0.3s ease;
  will-change: transform;
}

.palette { flex: 0 0 auto; margin-bottom: 12rpx; }
.sec-title { font-size: 24rpx; color: #888; display: block; margin-bottom: 10rpx; }
.palette-row { display: flex; gap: 14rpx; }
.block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.12);
}
.b-icon { font-size: 40rpx; line-height: 1; }
.b-label { font-size: 24rpx; margin-top: 6rpx; }

.program {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 14rpx;
  padding: 14rpx;
  min-height: 0;
}
.empty { color: #bbb; font-size: 26rpx; padding: 30rpx 10rpx; }
.prog-list { flex: 1; min-height: 0; }
.prog-wrap { display: flex; flex-wrap: wrap; align-content: flex-start; }
.prog-block {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  margin: 8rpx 10rpx 8rpx 0;
  border: 2rpx solid #ccc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  vertical-align: top;
}
.p-label { font-weight: 500; }
.times { display: inline-flex; align-items: center; gap: 8rpx; margin-left: 6rpx; }
.tbtn { width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center; border-radius: 50%; background: rgba(0,0,0,0.08); font-size: 30rpx; }
.tnum { min-width: 28rpx; text-align: center; }
.p-del { margin-left: 6rpx; color: #D85A30; font-size: 34rpx; padding: 0 6rpx; }

.drag-float {
  position: fixed;
  z-index: 999;
  transform: translate(-50%, -50%);
  padding: 16rpx 24rpx;
  border-radius: 14rpx;
  color: #fff;
  font-size: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.25);
  pointer-events: none;
}
