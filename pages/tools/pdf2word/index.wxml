<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">PDF转Word</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 选择PDF -->
  <view class="card">
    <view class="pdf-picker" bindtap="onChoosePDF">
      <view wx:if="{{!filePath}}" class="picker-placeholder">
        <text class="picker-icon">📝</text>
        <text class="picker-title">点击选择PDF文件</text>
        <text class="picker-desc">支持从聊天记录或手机文件选择</text>
      </view>
      <view wx:else class="file-info">
        <view class="file-icon-wrap">
          <text class="file-icon">📄</text>
        </view>
        <view class="file-detail">
          <text class="file-name">{{fileName}}</text>
          <text class="file-size">{{fileSize}}</text>
        </view>
        <text class="file-change" bindtap="onChoosePDF">更换</text>
      </view>
    </view>
    <view wx:if="{{!filePath}}" class="source-row">
      <view class="source-btn" bindtap="onChooseFromMessage">
        <text class="source-icon">💬</text>
        <text class="source-text">聊天记录</text>
      </view>
      <view class="source-btn" bindtap="onChooseFromAlbum">
        <text class="source-icon">📱</text>
        <text class="source-text">手机文件</text>
      </view>
    </view>
  </view>

  <!-- 云端AI转换（推荐） -->
  <view class="card cloud-card" wx:if="{{cloudReady && youdaoAvailable}}">
    <view class="cloud-header">
      <view class="cloud-badge">
        <text class="cloud-badge-text">🤖 有道智云 AI</text>
      </view>
      <view class="cloud-quota">
        <text class="quota-text">个人：{{dailyUserUsed}}/{{dailyUserLimit}} · 全局：{{dailyTotalUsed}}/{{dailyTotalLimit}}</text>
      </view>
    </view>
    <text class="cloud-desc">高质量云端转换·保留原排版·适合扫描件和复杂文档</text>
    <view class="cloud-quota-bar">
      <view class="quota-bar-label">今日个人剩余</view>
      <view class="quota-bar-bg">
        <view class="quota-bar-fill" style="width:{{(dailyUserRemaining / dailyUserLimit) * 100}}%;"></view>
      </view>
      <view class="quota-bar-value">{{dailyUserRemaining}} 次</view>
    </view>
    <button class="btn-cloud" bindtap="onCloudConvert" disabled="{{isCloudConverting || dailyUserRemaining <= 0}}">
      {{isCloudConverting ? '转换中...' : '☁️ 云端AI转Word'}}
    </button>
    <text wx:if="{{dailyUserRemaining <= 0}}" class="cloud-warn">今日个人次数已用完，明天再来</text>
    <text wx:elif="{{dailyTotalRemaining <= 0}}" class="cloud-warn">今日全局总量已用完，明天再来</text>
  </view>

  <!-- 云服务未配置提示 -->
  <view class="card cloud-error-card" wx:if="{{cloudReady && !youdaoAvailable}}">
    <text class="cloud-error-icon">⚙️</text>
    <text class="cloud-error-title">云服务未配置</text>
    <text class="cloud-error-desc">需在云函数环境变量中设置 YOUDAO_APP_KEY 和 YOUDAO_APP_SECRET。\n当前可使用本地提取模式。</text>
  </view>

  <!-- 云服务异常 -->
  <view class="card cloud-error-card" wx:if="{{!cloudReady}}">
    <text class="cloud-error-icon">⚠️</text>
    <text class="cloud-error-title">云服务暂不可用</text>
    <text class="cloud-error-desc">网络异常或云函数未部署。可使用下方本地提取模式。</text>
    <button class="btn-retry" bindtap="checkCloudQuota">重新检测</button>
  </view>

  <!-- 云端转换中 -->
  <view class="card" wx:if="{{isCloudConverting}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">云端AI转换中</text>
      <text class="loading-sub">{{loadingText || '正在处理PDF...'}}</text>
      <text class="loading-hint">大文件可能需要1-2分钟，请耐心等待</text>
    </view>
  </view>

  <!-- 转换格式选择 -->
  <view class="card" wx:if="{{filePath}}">
    <text class="section-title">📋 输出格式（本地提取模式）</text>
    <view class="format-row">
      <view class="format-option {{outputFormat === 'docx' ? 'format-active' : ''}}" data-format="docx" bindtap="onFormatChange">
        <text class="format-icon">📘</text>
        <text class="format-name">Word(.docx)</text>
        <text class="format-desc">降级为RTF</text>
      </view>
      <view class="format-option {{outputFormat === 'rtf' ? 'format-active' : ''}}" data-format="rtf" bindtap="onFormatChange">
        <text class="format-icon">📗</text>
        <text class="format-name">RTF(.rtf)</text>
        <text class="format-desc">富文本格式</text>
      </view>
      <view class="format-option {{outputFormat === 'txt' ? 'format-active' : ''}}" data-format="txt" bindtap="onFormatChange">
        <text class="format-icon">📄</text>
        <text class="format-name">纯文本(.txt)</text>
        <text class="format-desc">纯文字内容</text>
      </view>
    </view>
  </view>

  <!-- 本地转换操作 -->
  <view class="card" wx:if="{{filePath}}">
    <text class="section-title">⚙️ 本地转换操作</text>
    <view class="action-list">
      <view class="action-item" bindtap="onExtractText">
        <view class="action-left">
          <text class="action-icon">📝</text>
          <view class="action-text-wrap">
            <text class="action-title">提取并生成{{formatLabel}}</text>
            <text class="action-desc">纯本地解析PDF·无需联网·不传文件</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-item" bindtap="onShareToApp">
        <view class="action-left">
          <text class="action-icon">📲</text>
          <view class="action-text-wrap">
            <text class="action-title">分享到WPS/Word</text>
            <text class="action-desc">调用其他App完成专业转换</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-item" bindtap="onPreviewPDF">
        <view class="action-left">
          <text class="action-icon">👁️</text>
          <view class="action-text-wrap">
            <text class="action-title">预览PDF内容</text>
            <text class="action-desc">打开文档查看原始内容</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-item" bindtap="onShowTips">
        <view class="action-left">
          <text class="action-icon">💡</text>
          <view class="action-text-wrap">
            <text class="action-title">转换方法指南</text>
            <text class="action-desc">查看多种PDF转Word的实用方法</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>
    <button class="btn-clear" bindtap="onClear">清除文件</button>
  </view>

  <!-- 提取结果（本地提取） -->
  <view class="card" wx:if="{{resultText}}">
    <text class="section-title">📄 本地提取结果预览（前 800 字）</text>
    <view class="result-text-box">
      <text class="result-text" user-select="true">{{resultText}}</text>
    </view>
    <view class="result-info">
      <text class="result-info-item">共 {{resultCharCount}} 字符</text>
      <text class="result-info-item">输出 {{formatLabel}} 文件</text>
    </view>
    <view class="result-actions">
      <button class="btn-primary" bindtap="onOpenResult">📂 打开{{formatLabel}}文件</button>
      <button class="btn-secondary" bindtap="onCopyExtracted">📋 复制全部文字</button>
    </view>
  </view>

  <!-- 云端转换结果 -->
  <view class="card" wx:if="{{resultPath && !resultText}}">
    <text class="section-title">📄 云端转换结果</text>
    <view class="result-info">
      <text class="result-info-item">文件名：{{cloudResultName}}</text>
    </view>
    <view class="result-actions">
      <button class="btn-primary" bindtap="onOpenResult">📂 用Word/WPS打开</button>
      <button class="btn-secondary" bindtap="onShareToApp">📲 分享到其他App</button>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="card">
    <text class="section-title">📖 使用说明</text>
    <view class="step-list">
      <view class="step-item">
        <view class="step-num">1</view>
        <view class="step-content">
          <text class="step-title">选择PDF文件</text>
          <text class="step-desc">从微信聊天记录中选择需要转换的PDF文件</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">2</view>
        <view class="step-content">
          <text class="step-title">选择输出格式</text>
          <text class="step-desc">可选Word(.docx)、RTF或纯文本</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">3</view>
        <view class="step-content">
          <text class="step-title">一键提取</text>
          <text class="step-desc">纯本地解析PDF生成对应格式文件</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 多种转换方法 -->
  <view class="card">
    <text class="section-title">🔧 推荐转换方法</text>
    <view class="method-list">
      <view class="method-item">
        <view class="method-tag">方法一</view>
        <view class="method-content">
          <text class="method-title">电脑端Word打开</text>
          <text class="method-desc">用「文件传输助手」把PDF发到电脑，右键PDF选择「打开方式→Word」，Word会自动转换</text>
        </view>
      </view>
      <view class="method-item">
        <view class="method-tag">方法二</view>
        <view class="method-content">
          <text class="method-title">在线工具转换</text>
          <text class="method-desc">搜索"PDF转Word在线"，上传文件即可转换。推荐：smallpdf、ilovepdf、迅捷PDF转换器</text>
        </view>
      </view>
      <view class="method-item">
        <view class="method-tag">方法三</view>
        <view class="method-content">
          <text class="method-title">WPS Office</text>
          <text class="method-desc">手机安装WPS Office，打开PDF后点击「输出为Word」即可转换</text>
        </view>
      </view>
      <view class="method-item">
        <view class="method-tag">方法四</view>
        <view class="method-content">
          <text class="method-title">专业软件</text>
          <text class="method-desc">使用Adobe Acrobat、Foxit、福昕等PDF编辑器，转换效果更精准</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="card tips-card">
    <text class="section-title">💡 温馨提示</text>
    <view wx:for="{{tips}}" wx:key="index" class="tip-item">
      <text class="tip-dot">•</text>
      <text class="tip-text">{{item}}</text>
    </view>
  </view>
</view>
