<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">PDF转Word</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 选择PDF -->
  <view class="card">
    <view class="pdf-picker" bindtap="onChoosePDF">
      <view wx:if="{{!filePath}}" class="picker-placeholder">
        <text class="picker-icon">📝</text>
        <text class="picker-title">点击选择PDF文件</text>
        <text class="picker-desc">从微信聊天记录中选择PDF文件</text>
      </view>
      <view wx:else class="file-info">
        <view class="file-icon-wrap">
          <text class="file-icon">📄</text>
        </view>
        <view class="file-detail">
          <text class="file-name">{{fileName}}</text>
          <text class="file-size">{{fileSize}}</text>
        </view>
        <text class="file-change" bindtap="onChoosePDF">更换</text>
      </view>
    </view>
  </view>

  <!-- 云端转换 -->
  <view class="card" wx:if="{{filePath}}">
    <view class="quota-info" wx:if="{{cloudReady}}">
      <text class="quota-text">今日剩余：{{dailyUserRemaining}}/{{dailyUserLimit}}次（全局{{dailyTotalRemaining}}/{{dailyTotalLimit}}）</text>
    </view>
    <button class="btn-cloud" bindtap="onCloudConvert" disabled="{{isConverting || dailyUserRemaining <= 0}}">
      {{isConverting ? '转换中...' : '☁️ 云端转换PDF为Word'}}
    </button>
    <text class="cloud-desc">提取PDF文字生成真实 .docx · 纯本地处理不上传第三方</text>
    <view wx:if="{{!cloudReady}}" class="cloud-error">
      <text class="cloud-error-text">⚠️ 云服务暂不可用，请确认云函数已部署</text>
      <button class="btn-retry" bindtap="checkCloudQuota">重新检测</button>
    </view>
    <button class="btn-clear" bindtap="onClear">清除文件</button>
  </view>

  <!-- 其他操作 -->
  <view class="card" wx:if="{{filePath}}">
    <text class="section-title">其他方式</text>
    <view class="action-list">
      <view class="action-item" bindtap="onShareToApp">
        <view class="action-left">
          <text class="action-icon">📲</text>
          <view class="action-text-wrap">
            <text class="action-title">分享到WPS/Word</text>
            <text class="action-desc">调用其他App完成专业转换</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-item" bindtap="onPreviewPDF">
        <view class="action-left">
          <text class="action-icon">👁️</text>
          <view class="action-text-wrap">
            <text class="action-title">预览PDF内容</text>
            <text class="action-desc">打开文档查看原始内容</text>
          </view>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 转换结果 -->
  <view class="card" wx:if="{{resultPath}}">
    <text class="section-title">🎉 转换结果</text>
    <view class="result-info">
      <text class="result-info-item">文件名：{{cloudResultName}}</text>
    </view>
    <view class="result-actions">
      <button class="btn-primary" bindtap="onOpenResult">📂 用Word/WPS打开</button>
      <button class="btn-secondary" bindtap="onShareToApp">📲 分享到其他App</button>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="card tips-card">
    <text class="section-title">💡 温馨提示</text>
    <view wx:for="{{tips}}" wx:key="index" class="tip-item">
      <text class="tip-dot">•</text>
      <text class="tip-text">{{item}}</text>
    </view>
  </view>
</view>
