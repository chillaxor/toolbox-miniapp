<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">证件照生成器</text>
    <!-- 模式徽章 -->
    <view class="mode-badge mode-{{activeMode}}">
      <text class="mode-badge-text">
        {{activeMode === 'cloud' ? '☁️ 云端AI' : activeMode === 'localai' ? '🤖 本地AI' : '📝 基础模式'}}
      </text>
    </view>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 云端额度提示 -->
  <view class="quota-bar" wx:if="{{cloudQuotaLoaded}}">
    <!--<view class="quota-item" wx:if="{{activeMode === 'cloud'}}">
      <text class="quota-label">☁️ 今日剩余</text>
      <text class="quota-val {{cloudQuota.dailyUserRemaining <= 2 ? 'quota-warn' : ''}}">
        {{cloudQuota.dailyUserRemaining}}/{{cloudQuota.dailyUserLimit}} 次
      </text>
    </view>
    <view class="quota-item" wx:if="{{activeMode === 'cloud'}}">
      <text class="quota-label">📅 本月剩余</text>
      <text class="quota-val {{cloudQuota.remaining <= 50 ? 'quota-warn' : ''}}">
        {{cloudQuota.remaining}}/{{cloudQuota.limit}} 次
      </text>
    </view> -->
    <view class="quota-item quota-fallback" wx:if="{{activeMode !== 'cloud'}}">
      <text class="quota-label">💡 云端额度耗尽，已切换到{{activeMode === 'localai' ? '本地AI' : '基础模式'}}</text>
    </view>
  </view>

  <!-- 选择照片 -->
  <view class="card" bindtap="onChoosePhoto">
    <view class="photo-area" wx:if="{{!photoPath}}">
      <text class="photo-icon">📷</text>
      <text class="photo-hint">点击选择或拍摄照片</text>
    </view>
    <image wx:if="{{photoPath}}" src="{{photoPath}}" mode="aspectFit" class="photo-preview" />
  </view>

  <!-- 证件照规格 -->
  <view class="card">
    <text class="card-title">📐 选择规格</text>
    <picker range="{{sizes}}" range-key="name" value="{{sizeIdx}}" bindchange="onSizeChange">
      <view class="picker-row">
        <text class="picker-label">照片尺寸</text>
        <text class="picker-value">{{sizes[sizeIdx].name}} ({{sizes[sizeIdx].label}})</text>
      </view>
    </picker>
    <picker range="{{layouts}}" range-key="name" value="{{layoutIdx}}" bindchange="onLayoutChange">
      <view class="picker-row">
        <text class="picker-label">排版方式</text>
        <text class="picker-value">{{layouts[layoutIdx].name}}</text>
      </view>
    </picker>
  </view>

  <!-- 背景颜色 -->
  <view class="card">
    <text class="card-title">🎨 背景颜色</text>
    <view class="bg-grid">
      <view class="bg-item {{bgIdx === index ? 'bg-active' : ''}}"
            wx:for="{{bgColors}}" wx:key="index"
            data-idx="{{index}}" bindtap="onBgChange">
        <view class="bg-circle" style="background: {{item.color}};"></view>
        <text class="bg-name">{{item.name}}</text>
      </view>
    </view>
    <text class="bg-tip">
      {{activeMode === 'cloud' ? '✨ 百度云AI精准识别人像，支持复杂背景' :
        activeMode === 'localai' ? '🤖 本地AI推理，精确到发丝边缘' :
        '💡 自动检测背景色替换，纯色背景效果最佳'}}
    </text>
  </view>

  <!-- 生成按钮 -->
  <view class="card" wx:if="{{photoPath}}">
    <view class="btn-generate {{generating ? 'btn-disabled' : ''}}"
          bindtap="{{generating ? '' : 'generatePhoto'}}">
      {{generating ? '生成中...' :
        (activeMode === 'cloud' ? '☁️ 云端AI生成证件照' :
         activeMode === 'localai' ? '🤖 本地AI生成证件照' : '📸 生成证件照')}}
    </view>
  </view>

  <!-- 结果预览 -->
  <view class="card" wx:if="{{resultPath}}">
    <text class="card-title">✅ 生成结果</text>
    <view class="result-frame" style="background: {{bgColors[bgIdx].color}};">
      <image src="{{resultPath}}" mode="aspectFit" class="result-photo" />
    </view>
    <view class="result-actions">
      <view class="btn-save-result" bindtap="saveResult">💾 再次保存</view>
    </view>
    <text class="save-hint">规格: {{sizes[sizeIdx].name}} {{sizes[sizeIdx].label}} | 背景: {{bgColors[bgIdx].name}}</text>
  </view>

  <!-- 常见规格参考 -->
  <view class="card">
    <text class="card-title">📋 常见规格参考</text>
    <view class="ref-table">
      <view class="ref-row ref-header">
        <text class="ref-cell">规格</text>
        <text class="ref-cell">尺寸</text>
        <text class="ref-cell">像素</text>
      </view>
      <view class="ref-row" wx:for="{{sizes}}" wx:key="index">
        <text class="ref-cell">{{item.name}}</text>
        <text class="ref-cell">{{item.label}}</text>
        <text class="ref-cell">{{item.w}}×{{item.h}}</text>
      </view>
    </view>
  </view>

  <!-- 隐藏 canvas -->
  <canvas canvas-id="idphoto-src"    style="position:fixed;left:-9999px;width:800px;height:800px;"></canvas>
  <canvas canvas-id="idphoto-mask"   style="position:fixed;left:-9999px;width:512px;height:512px;"></canvas>
  <canvas canvas-id="idphoto-canvas" style="position:fixed;left:-9999px;width:{{canvasW}}px;height:{{canvasH}}px;"></canvas>
  <canvas canvas-id="idphoto-layout" style="position:fixed;left:-9999px;width:1200px;height:1800px;"></canvas>
</view>
