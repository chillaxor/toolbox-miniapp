.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.tool-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tool-header-fav {
  font-size: 44rpx;
  padding: 8rpx;
}

/* 模式徽章 */
.mode-badge {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

/* 云端AI模式 */
.mode-cloud {
  background: linear-gradient(135deg, #2196f3, #00bcd4);
  color: #fff;
}

/* 本地AI模式 */
.mode-localai {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

/* 基础模式 */
.mode-basic {
  background: #f0f0f0;
  color: #999;
}

.mode-badge-text {
  font-size: 22rpx;
}

.mode-status {
  font-size: 20rpx;
  opacity: 0.85;
}

/* 额度条 */
.quota-bar {
  display: flex;
  gap: 16rpx;
  background: var(--color-bg, #f7f8fa);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.quota-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.quota-label {
  font-size: 22rpx;
  color: var(--color-secondary, #888);
}

.quota-val {
  font-size: 22rpx;
  color: var(--color-primary, #333);
  font-weight: 600;
}

.quota-warn {
  color: #f44336;
}

.quota-fallback .quota-label {
  font-size: 22rpx;
  color: #f57c00;
}

/* 模型状态卡片 */
.model-status-card {
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.model-status-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.model-status-icon {
  font-size: 40rpx;
}

.model-status-text {
  font-size: 26rpx;
  color: var(--color-secondary);
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #e0e0e0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 6rpx;
  transition: width 0.3s;
}

.btn-download {
  height: 64rpx;
  padding: 0 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  display: block;
}

.photo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  border: 4rpx dashed var(--color-border);
  border-radius: 16rpx;
}

.photo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.photo-hint {
  font-size: 28rpx;
  color: var(--color-hint);
}

.photo-preview {
  width: 100%;
  max-height: 500rpx;
  border-radius: 12rpx;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.picker-label {
  font-size: 28rpx;
  color: var(--color-secondary);
}

.picker-value {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.bg-grid {
  display: flex;
  gap: 32rpx;
  justify-content: center;
}

.bg-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.bg-active {
  border-color: var(--color-date);
  background: var(--color-bg);
}

.bg-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  margin-bottom: 8rpx;
}

.bg-name {
  font-size: 24rpx;
  color: var(--color-secondary);
}

.bg-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-hint);
  margin-top: 16rpx;
}

/* AI 抠图按钮 */
.btn-ai-matting {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.ai-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-hint);
  margin-top: 12rpx;
}

/* 抠图预览 */
.matting-preview-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  background-image:
    linear-gradient(45deg, #e0e0e0 25%, transparent 25%),
    linear-gradient(-45deg, #e0e0e0 25%, transparent 25%),
    linear-gradient(45deg, transparent 75%, #e0e0e0 75%),
    linear-gradient(-45deg, transparent 75%, #e0e0e0 75%);
  background-size: 24rpx 24rpx;
  background-position: 0 0, 0 12rpx, 12rpx -12rpx, -12rpx 0rpx;
  border-radius: 12rpx;
  overflow: hidden;
  max-width: 500rpx;
  margin: 0 auto;
}

.matting-preview-img {
  width: 100%;
  max-height: 500rpx;
}

.matting-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.btn-re-matting {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  background: #f0f0f0;
  color: var(--color-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

/* 生成按钮 */
.btn-generate {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-disabled {
  opacity: 0.6;
}

.result-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  overflow: hidden;
  border-radius: 8rpx;
  padding: 8rpx;
  max-width: 500rpx;
}

.result-photo {
  width: 100%;
  max-height: 600rpx;
  border-radius: 8rpx;
}

.result-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.btn-save-result {
  height: 80rpx;
  padding: 0 48rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.save-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-hint);
  margin-top: 16rpx;
}

.ref-table {
  border: 2rpx solid var(--color-border);
  border-radius: 8rpx;
  overflow: hidden;
}

.ref-row {
  display: flex;
  border-bottom: 2rpx solid var(--color-border);
}

.ref-row:last-child {
  border-bottom: none;
}

.ref-header {
  background: var(--color-bg);
}

.ref-cell {
  flex: 1;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: var(--color-secondary);
  text-align: center;
}

.ref-header .ref-cell {
  font-weight: 600;
  color: var(--color-primary);
}
