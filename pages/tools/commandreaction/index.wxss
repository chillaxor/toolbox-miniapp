.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 36rpx 60rpx;
  background: linear-gradient(160deg, #2b1055 0%, #5b1d8a 55%, #7597de 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

/* 收藏 */
.fav {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 44rpx;
  z-index: 5;
  filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.3));
}

/* ===== 开始页 ===== */
.hero {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hero-emoji { font-size: 120rpx; }
.hero-title {
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}
.hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 12rpx;
  text-align: center;
}
.rules {
  margin-top: 56rpx;
  width: 100%;
  background: rgba(255,255,255,0.12);
  border-radius: 28rpx;
  padding: 32rpx 30rpx;
  box-sizing: border-box;
}
.rule {
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.95;
  margin: 10rpx 0;
}
.best {
  margin-top: 36rpx;
  font-size: 30rpx;
  opacity: 0.9;
}

/* 主按钮 */
.btn-primary {
  margin-top: 48rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(90deg, #FF6B9D, #FFC371);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(255,107,157,0.4);
}
.btn-ghost {
  margin-top: 24rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: rgba(255,255,255,0.16);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 游戏页 ===== */
.hud {
  width: 100%;
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 18rpx 10rpx;
  box-sizing: border-box;
}
.hud-item {
  font-size: 26rpx;
  font-weight: 600;
  background: rgba(255,255,255,0.14);
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
}

.cmd-card {
  margin-top: 80rpx;
  width: 100%;
  min-height: 440rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 50rpx 30rpx;
  box-sizing: border-box;
  color: #2b1055;
  position: relative;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3);
}
.cmd-card.cmd-hold {
  background: linear-gradient(160deg, #ffd9d9, #ffb3b3);
  color: #b71c1c;
}
.cmd-emoji { font-size: 150rpx; line-height: 1; }
.cmd-text {
  font-size: 76rpx;
  font-weight: 800;
  margin-top: 24rpx;
  letter-spacing: 6rpx;
}
.cmd-hint {
  font-size: 26rpx;
  margin-top: 26rpx;
  opacity: 0.7;
}

/* 别动倒计时条 */
.hold-bar {
  margin-top: 30rpx;
  width: 80%;
  height: 22rpx;
  background: rgba(183,28,28,0.18);
  border-radius: 12rpx;
  overflow: hidden;
}
.hold-bar-fill {
  height: 100%;
  width: 100%;
  background: #e53935;
  border-radius: 12rpx;
  transform-origin: left center;
  animation-name: holdShrink;
  animation-timing-function: linear;
  animation-fill-mode: forwards;
}
@keyframes holdShrink {
  from { transform: scaleX(1); }
  to   { transform: scaleX(0); }
}

/* 反馈 */
.gain {
  position: absolute;
  top: 30rpx;
  right: 36rpx;
  font-size: 48rpx;
  font-weight: 800;
  color: #2e9e4f;
  animation: pop 0.5s ease;
}
.wrong-tip {
  position: absolute;
  bottom: 26rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #e53935;
}
.flash-ok { animation: okFlash 0.5s ease; }
.flash-bad { animation: badShake 0.5s ease; }
@keyframes pop {
  0% { transform: scale(0.4); opacity: 0; }
  60% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
@keyframes okFlash {
  0% { box-shadow: 0 0 0 0 #4caf50; }
  50% { box-shadow: 0 0 0 16rpx rgba(76,175,80,0.7); }
  100% { box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3); }
}
@keyframes badShake {
  0%,100% { transform: translateX(0); }
  20% { transform: translateX(-18rpx); }
  40% { transform: translateX(18rpx); }
  60% { transform: translateX(-12rpx); }
  80% { transform: translateX(12rpx); }
}

/* 确认按钮 */
.confirm-btn {
  margin-top: 70rpx;
  width: 100%;
  height: 110rpx;
  border-radius: 55rpx;
  background: linear-gradient(90deg, #42e695, #3bb2b8);
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 30rpx rgba(59,178,184,0.45);
}
.confirm-btn.is-locked {
  opacity: 0.45;
  filter: grayscale(0.4);
}

/* ===== 结果页 ===== */
.result-card {
  margin-top: 90rpx;
  width: 100%;
  background: rgba(255,255,255,0.96);
  border-radius: 40rpx;
  padding: 56rpx 40rpx;
  box-sizing: border-box;
  color: #2b1055;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3);
}
.result-emoji { font-size: 110rpx; }
.result-title {
  font-size: 46rpx;
  font-weight: 800;
  margin-top: 10rpx;
}
.result-row {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  margin-top: 26rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid rgba(43,16,85,0.1);
}
.result-row .big { font-size: 56rpx; font-weight: 800; color: #FF6B9D; }
.result-best {
  margin-top: 30rpx;
  font-size: 28rpx;
  opacity: 0.8;
}
