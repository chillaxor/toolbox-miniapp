.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1f3a5f, #2e6b8f);
  padding: 40rpx 40rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ---------- 设置 ---------- */
.hero {
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
  text-align: center;
  margin: 20rpx 0 16rpx;
  text-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.25);
}

.howto {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 25rpx;
  line-height: 1.7;
}

.sec-label {
  color: #fff;
  font-size: 28rpx;
  margin: 30rpx 0 14rpx;
  font-weight: 600;
}

.chip-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.chip {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  transition: .15s;
}

.chip-on {
  background: #fff;
  color: #1f3a5f;
  font-weight: 700;
}

.btn-primary {
  margin-top: 24rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #fff;
  color: #1f3a5f;
  font-size: 33rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.18);
}

.btn-primary.inline {
  margin-top: 0;
  flex: 1;
}

/* ---------- 游戏中 ---------- */
.hud {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.stat {
  background: rgba(0, 0, 0, 0.22);
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 36rpx;
}

.stat .hl {
  font-weight: 800;
  font-size: 32rpx;
  color: #FFE08A;
}

.quit {
  margin-left: auto;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 36rpx;
}

.ready {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 64rpx;
  font-weight: 800;
}

.ready-sub {
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0.85;
  margin-top: 16rpx;
}

.instr-wrap {
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 6rpx 0;
}

.decoy {
  color: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
  text-decoration: line-through;
  margin-bottom: 10rpx;
}

.instr {
  color: #fff;
  font-size: 64rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.2;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.instr.blink {
  animation: instblink 0.5s steps(2, start) infinite;
}

@keyframes instblink {
  50% { opacity: 0.25; }
}

.timebar {
  height: 14rpx;
  background: rgba(0, 0, 0, 0.25);
  border-radius: 10rpx;
  overflow: hidden;
  margin: 10rpx 0 20rpx;
}

.timefill {
  height: 100%;
  background: linear-gradient(90deg, #4be08a, #FFE08A, #ff6b6b);
  border-radius: 10rpx;
  transition: width .1s linear;
}

.targets {
  flex: 1;
  display: flex;
  gap: 24rpx;
}

.targets.two {
  flex-direction: row;
}

.targets.one {
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tgt {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  color: #fff;
  font-size: 48rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  transition: transform .08s;
}

.tgt:active {
  transform: scale(0.95);
}

.zone {
  background: rgba(255, 255, 255, 0.9);
  color: #1f3a5f;
}

.c-red {
  background: #ff5b5b;
}

.c-green {
  background: #36d399;
}

.tf {
  background: rgba(255, 255, 255, 0.92);
  color: #1f3a5f;
}

.word-btn {
  background: linear-gradient(135deg, #ff7a7a, #e23b3b);
  width: 80%;
  padding: 50rpx 0;
  font-size: 44rpx;
}

.act-btn {
  width: 70%;
  aspect-ratio: 1 / 1;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd54a, #f7a000);
  color: #5a3b00;
  font-size: 40rpx;
}

.cnt-btn {
  width: 70%;
  padding: 50rpx 0;
  background: linear-gradient(135deg, #22d3ee, #0e7490);
  font-size: 40rpx;
}

.cnt-num {
  color: #fff;
  font-size: 72rpx;
  font-weight: 800;
  margin-top: 20rpx;
}

/* 反馈闪 */
.flash {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 160rpx;
  font-weight: 800;
  pointer-events: none;
}

.flash.ok {
  color: #4be08a;
  background: rgba(75, 224, 138, 0.18);
  animation: flashin .4s ease;
}

.flash.bad {
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.2);
  font-size: 64rpx;
  animation: flashin .4s ease;
}

@keyframes flashin {
  0% { opacity: 0; transform: scale(0.6); }
  100% { opacity: 1; transform: scale(1); }
}

/* ---------- 结果 ---------- */
.result-emoji {
  text-align: center;
  font-size: 130rpx;
  margin: 50rpx 0 8rpx;
}

.result-title {
  text-align: center;
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
}

.stars {
  text-align: center;
  color: #FFE08A;
  font-size: 56rpx;
  letter-spacing: 8rpx;
  margin: 14rpx 0;
}

.result-line {
  text-align: center;
  color: rgba(255, 255, 255, 0.88);
  font-size: 28rpx;
  margin: 8rpx 30rpx;
}

.master {
  text-align: center;
  color: #FFE08A;
  font-size: 28rpx;
  font-weight: 700;
  margin: 20rpx 30rpx;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 30rpx;
}

.btn-ghost {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 31rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
