.image-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  border-radius: 12rpx;
  background-color: #F8F9FA;
  padding: 48rpx;
}

.picker-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.picker-desc {
  font-size: 24rpx;
  color: var(--color-hint);
}

/* ========== 编辑区域整体布局 ========== */
.edit-area {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
}

/* ========== 工具栏固定在上方 ========== */
.toolbar-fixed {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  margin-bottom: 12rpx;
}

.tool-group {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  min-width: 72rpx;
  transition: background 0.2s;
}

.tool-btn.active {
  background-color: #E8F5E9;
}

.tool-icon {
  font-size: 32rpx;
  margin-bottom: 2rpx;
}

.tool-label {
  font-size: 22rpx;
  color: var(--color-secondary);
}

.tool-btn.active .tool-label {
  color: #45B058;
  font-weight: 600;
}

.brush-size-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  margin-top: 4rpx;
}

.size-label {
  font-size: 24rpx;
  color: var(--color-secondary);
  flex-shrink: 0;
  margin-right: 12rpx;
}

.size-slider {
  flex: 1;
}

/* ========== 操作提示 ========== */
.action-hint {
  text-align: center;
  padding: 6rpx 0;
  margin-top: 4rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #45B058;
  font-weight: 500;
}

/* ========== Canvas 区域 ========== */
.canvas-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-border);
  background: #F8F9FA;
  overflow: hidden;
}

.draw-canvas {
  border-radius: 8rpx;
  touch-action: none;
}

/* ========== 导出按钮固定底部 ========== */
.export-bar {
  margin-top: 12rpx;
  padding: 0;
}

.btn-export {
  margin-bottom: 0;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ========== 使用说明等 ========== */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  margin-bottom: 20rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #45B058 0%, #388E3C 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-content {
  margin-left: 20rpx;
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.step-desc {
  font-size: 24rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 4rpx;
}

.tips-card {
  margin-bottom: 48rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  color: #45B058;
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1.6;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-secondary);
  line-height: 1.6;
}