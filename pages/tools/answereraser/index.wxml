<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">答案遮挡器</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 选择图片 -->
  <view class="card" wx:if="{{!imageSrc}}">
    <view class="image-picker" bindtap="onChooseImage">
      <text class="picker-icon">📷</text>
      <text class="picker-title">点击选择试卷图片</text>
      <text class="picker-desc">从相册选择已填写答案的试卷照片</text>
    </view>
  </view>

  <!-- 编辑区域：固定布局，不滚动 -->
  <view wx:if="{{imageSrc}}" class="edit-area">
    <!-- 工具栏放在Canvas上方，始终可见 -->
    <view class="toolbar-fixed">
      <view class="tool-group">
        <view class="tool-btn {{drawMode === 'brush' ? 'active' : ''}}" data-mode="brush" bindtap="onDrawModeChange">
          <text class="tool-icon">✏️</text>
          <text class="tool-label">涂抹</text>
        </view>
        <view class="tool-btn {{drawMode === 'rect' ? 'active' : ''}}" data-mode="rect" bindtap="onDrawModeChange">
          <text class="tool-icon">⬜</text>
          <text class="tool-label">矩形</text>
        </view>
        <view class="tool-btn" bindtap="onUndo">
          <text class="tool-icon">↩️</text>
          <text class="tool-label">撤销</text>
        </view>
        <view class="tool-btn" bindtap="onReset">
          <text class="tool-icon">🔄</text>
          <text class="tool-label">重置</text>
        </view>
        <view class="tool-btn" bindtap="onChooseImage">
          <text class="tool-icon">🖼️</text>
          <text class="tool-label">换图</text>
        </view>
      </view>

      <view class="brush-size-row" wx:if="{{drawMode === 'brush'}}">
        <text class="size-label">粗细</text>
        <slider class="size-slider" min="5" max="60" value="{{brushSize}}" activeColor="#45B058" bindchange="onBrushSizeChange" show-value/>
      </view>

      <!-- 操作提示 -->
      <view class="action-hint" wx:if="{{isReady && historyCount > 0}}">
        <text class="hint-text">已遮挡✅ 点击下方「保存」导出到相册</text>
      </view>
      <view class="action-hint" wx:if="{{isReady && historyCount === 0}}">
        <text class="hint-text">👆 在图片上滑动涂抹，或用矩形覆盖答案</text>
      </view>
    </view>

    <!-- Canvas 区域：自适应高度 -->
    <view class="canvas-wrapper">
      <canvas
        id="drawCanvas"
        type="2d"
        class="draw-canvas"
        style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;"
        bindtouchstart="onDrawStart"
        bindtouchmove="onDrawMove"
        bindtouchend="onDrawEnd"
        disable-scroll
      ></canvas>
    </view>

    <!-- 导出按钮固定在底部 -->
    <view class="export-bar">
      <button class="btn-primary btn-export" style="background:linear-gradient(135deg,#45B058 0%,#388E3C 100%);" bindtap="onExport">
        💾 导出并保存到相册
      </button>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="card">
    <text class="section-title">📖 使用说明</text>
    <view class="step-list">
      <view class="step-item">
        <view class="step-num">1</view>
        <view class="step-content">
          <text class="step-title">选择试卷照片</text>
          <text class="step-desc">从相册或拍照获取已填写答案的试卷图片</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">2</view>
        <view class="step-content">
          <text class="step-title">涂抹遮挡答案</text>
          <text class="step-desc">用涂抹模式手指滑动遮挡，或矩形模式画白块覆盖</text>
        </view>
      </view>
      <view class="step-item">
        <view class="step-num">3</view>
        <view class="step-content">
          <text class="step-title">导出保存</text>
          <text class="step-desc">点击底部「导出并保存到相册」按钮，遮挡后的图片自动保存</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="card tips-card">
    <text class="section-title">💡 温馨提示</text>
    <view wx:for="{{tips}}" wx:key="index" class="tip-item">
      <text class="tip-dot">•</text>
      <text class="tip-text">{{item}}</text>
    </view>
  </view>
</view>