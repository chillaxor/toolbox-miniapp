.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

/* ===== 上传区 ===== */
.upload-area {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 400rpx;
  background: #fff;
  border: 4rpx dashed #9B59B6;
  border-radius: 24rpx;
  padding: 48rpx;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 32rpx;
  color: #9B59B6;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.6;
}

/* ===== 工具栏 ===== */
.toolbar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn-outline {
  background: #fff;
  color: #9B59B6;
  border: 2rpx solid #9B59B6;
}

.btn-primary {
  background: linear-gradient(135deg, #9B59B6, #8e44ad);
  color: #fff;
}

/* ===== 预览区 ===== */
.preview-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  font-weight: 600;
}

.preview-img {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background: #fff;
}

/* ===== 九宫格 ===== */
.grid-3x3 {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.grid-cell {
  width: calc((100% - 24rpx) / 3);
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #fff;
  overflow: hidden;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.piece-img {
  width: 100%;
  height: 100%;
}

.piece-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EFD9F7, #F5EEF8);
}

.piece-num {
  font-size: 48rpx;
  color: #9B59B6;
  font-weight: bold;
}

.piece-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  line-height: 40rpx;
  background: rgba(0,0,0,0.45);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}

/* ===== Loading ===== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spin {
  font-size: 60rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}
