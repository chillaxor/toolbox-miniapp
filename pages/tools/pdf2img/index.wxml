<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">PDF转图片</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 选择PDF -->
  <view class="card">
    <view class="pdf-picker" bindtap="onChoosePDF">
      <view wx:if="{{!filePath}}" class="picker-placeholder">
        <text style="font-size: 64rpx;">📄</text>
        <text class="picker-title">点击选择PDF文件</text>
        <text class="picker-desc">从微信聊天记录中选择PDF文件</text>
      </view>
      <view wx:else class="file-info">
        <view class="file-icon-wrap">
          <text class="file-icon">📄</text>
        </view>
        <view class="file-detail">
          <text class="file-name">{{fileName}}</text>
          <text class="file-size">{{fileSize}}</text>
        </view>
        <text class="file-change" bindtap="onChoosePDF">更换</text>
      </view>
    </view>
  </view>

  <!-- 格式选择 -->
  <view class="card" wx:if="{{filePath}}">
    <text class="section-title">输出格式</text>
    <view class="format-row">
      <view class="format-option {{selectedFormat === 'png' ? 'active' : ''}}" bindtap="onFormatChange" data-format="png">
        <text>PNG</text>
        <text class="format-desc">无损·清晰</text>
      </view>
      <view class="format-option {{selectedFormat === 'jpg' ? 'active' : ''}}" bindtap="onFormatChange" data-format="jpg">
        <text>JPG</text>
        <text class="format-desc">压缩·小体积</text>
      </view>
    </view>
    <text class="section-title">画质等级</text>
    <view class="format-row">
      <view class="format-option {{selectedQuality === 'high' ? 'active' : ''}}" bindtap="onQualityChange" data-quality="high">
        <text>高清</text>
        <text class="format-desc">300dpi</text>
      </view>
      <view class="format-option {{selectedQuality === 'medium' ? 'active' : ''}}" bindtap="onQualityChange" data-quality="medium">
        <text>标准</text>
        <text class="format-desc">200dpi</text>
      </view>
      <view class="format-option {{selectedQuality === 'low' ? 'active' : ''}}" bindtap="onQualityChange" data-quality="low">
        <text>快速</text>
        <text class="format-desc">150dpi</text>
      </view>
    </view>
  </view>

  <!-- 云端转换按钮 -->
  <view class="card" wx:if="{{filePath}}">
    <view class="quota-info" wx:if="{{cloudReady}}">
      <text class="quota-text">今日剩余：{{dailyUserRemaining}}/{{dailyUserLimit}}次（全局{{dailyTotalRemaining}}/{{dailyTotalLimit}}）</text>
    </view>
    <button class="btn-cloud" bindtap="onCloudConvert" disabled="{{isConverting || dailyUserRemaining <= 0}}">
      {{isConverting ? '转换中...' : '☁️ 云端转换PDF为图片'}}
    </button>
    <text class="cloud-desc">纯本地处理·不上传第三方·保护隐私</text>
    <button class="btn-clear" bindtap="onClear">清除文件</button>
  </view>

  <!-- 转换结果 -->
  <view class="card" wx:if="{{convertedImages.length > 0}}">
    <text class="section-title">转换结果（{{convertedImages.length}}页）</text>
    <button class="btn-save-all" bindtap="onSaveAllImages">保存全部到相册</button>
    <view class="image-grid">
      <view wx:for="{{convertedImages}}" wx:key="page" class="image-item">
        <image src="{{item.tempPath}}" mode="aspectFit" class="result-image" bindtap="onSaveImage" data-path="{{item.tempPath}}"></image>
        <text class="image-page">第{{item.page}}页</text>
        <text class="image-info">{{item.width}}×{{item.height}}</text>
      </view>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="card tips-card">
    <text class="section-title">💡 温馨提示</text>
    <view wx:for="{{tips}}" wx:key="index" class="tip-item">
      <text class="tip-dot">•</text>
      <text class="tip-text">{{item}}</text>
    </view>
  </view>
</view>
