.pdf-picker {
  width: 100%;
  min-height: 240rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #F8F9FA;
}

.picker-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  padding: 32rpx;
}

.picker-title {
  color: var(--color-secondary);
  font-size: 30rpx;
  margin-top: 16rpx;
  font-weight: 600;
}

.picker-desc {
  color: var(--color-hint);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.file-info {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.file-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.file-icon {
  font-size: 48rpx;
}

.file-detail {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.file-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 24rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 8rpx;
}

.file-change {
  font-size: 26rpx;
  color: #9B59B6;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

.action-list {
  margin-bottom: 24rpx;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.action-text-wrap {
  flex: 1;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.action-desc {
  font-size: 24rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 4rpx;
}

.action-arrow {
  font-size: 36rpx;
  color: var(--color-hint);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.btn-clear {
  width: 100%;
  height: 72rpx;
  border-radius: 36rpx;
  border: 2rpx solid var(--color-border);
  background-color: var(--color-card);
  color: var(--color-secondary);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-clear::after {
  border: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  margin-bottom: 20rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-content {
  margin-left: 20rpx;
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.step-desc {
  font-size: 24rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 4rpx;
}

.tips-card {
  margin-bottom: 48rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  color: #9B59B6;
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1.6;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-secondary);
  line-height: 1.6;
}
