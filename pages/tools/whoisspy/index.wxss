.count-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.count-btn {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #666;
  border-radius: 12rpx;
  border: 2rpx solid #E5E5E5;
}

.count-active {
  background: #E74C3C;
  color: #fff;
  border-color: #E74C3C;
}

/* 词语来源切换按钮（文字较长，自适应宽度） */
.count-btn-wide {
  width: auto;
  min-width: 200rpx;
  padding: 0 28rpx;
}

/* 自定义词语输入 */
.word-input {
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #F5F5F5;
  color: #333;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.custom-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  display: block;
}

.start-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  background: #E74C3C;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  border: none;
  margin-top: 40rpx;
}

.viewing-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.viewing-player {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.viewing-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.reveal-area {
  padding: 40rpx 0;
}

.reveal-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.reveal-text {
  font-size: 30rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}

.reveal-btn {
  width: 400rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #E74C3C;
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 50rpx;
  margin: 0 auto;
}

.word-text {
  font-size: 72rpx;
  font-weight: 800;
  color: #E74C3C;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}

.role-text {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 32rpx;
}

.spy-text {
  color: #E74C3C;
}

.civilian-text {
  color: #27AE60;
}

.progress-bar {
  margin: 24rpx 0;
}

.progress-text {
  font-size: 28rpx;
  color: #999;
}

.next-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #E74C3C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-top: 16rpx;
}

.round-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.round-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.discuss-hint {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  display: block;
  margin-bottom: 8rpx;
}

.action-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.primary-btn {
  background: #E74C3C;
  color: #fff;
}

.secondary-btn {
  background: #F5F5F5;
  color: #666;
  border: 2rpx solid #E5E5E5;
}

.vote-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.vote-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vote-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
  border: 2rpx solid #E5E5E5;
}

.vote-player {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.vote-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #E74C3C;
  background: #FDE8E8;
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
}

.result-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #E74C3C;
  display: block;
  margin-bottom: 32rpx;
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
}

.ri-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

.ri-role {
  font-size: 28rpx;
  font-weight: 600;
}

.ri-spy {
  color: #E74C3C;
}

.ri-civilian {
  color: #27AE60;
}

.result-words {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.rw-label {
  font-size: 26rpx;
  color: #999;
}

.rw-word {
  font-size: 32rpx;
  font-weight: 700;
  color: #E74C3C;
}

.showwords-info {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}

.sw-item {
  flex: 1;
  text-align: center;
  padding: 32rpx;
  background: #F9F9F9;
  border-radius: 16rpx;
}

.sw-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.sw-word {
  font-size: 48rpx;
  font-weight: 800;
  color: #E74C3C;
  display: block;
}
