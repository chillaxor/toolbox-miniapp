<view class="container">
  <view class="bg-deco">
    <text class="deco-emoji d1">⭐</text>
    <text class="deco-emoji d2">🎈</text>
    <text class="deco-emoji d3">🌈</text>
    <text class="deco-emoji d4">🍭</text>
    <text class="deco-emoji d5">🎀</text>
  </view>
  <view class="tool-header">
    <text class="tool-header-title">谁是卧底</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 设置阶段 -->
  <view wx:if="{{state === 'setup'}}">
    <view class="card">
      <view class="card-title">👧 玩家人数</view>
      <view class="count-btns">
        <view class="count-btn {{playerCount === item ? 'count-active' : ''}}" wx:for="{{playerCountOptions}}" wx:key="*this" data-count="{{item}}" bindtap="onPlayerCountChange">{{item}}</view>
      </view>
    </view>

    <view class="card" style="margin-top: 24rpx;">
      <view class="card-title">🕵️ 卧底人数</view>
      <view class="count-btns">
        <view class="count-btn {{spyCount === item ? 'count-active' : ''}}" wx:for="{{spyOptions}}" wx:key="*this" data-count="{{item}}" bindtap="onSpyCountChange">{{item}}</view>
        <text wx:if="{{spyOptions.length === 0}}" class="spy-fixed">（3 人局只有 1 名卧底哦）</text>
      </view>
    </view>

    <view class="card" style="margin-top: 24rpx;">
      <view class="card-title">🎲 词语来源</view>
      <view class="count-btns">
        <view class="count-btn count-btn-wide {{!useCustom ? 'count-active' : ''}}" data-on="0" bindtap="onToggleCustom">🎲 随机词库</view>
        <view class="count-btn count-btn-wide {{useCustom ? 'count-active' : ''}}" data-on="1" bindtap="onToggleCustom">✏️ 自己输入</view>
      </view>
    </view>

    <view wx:if="{{useCustom}}" class="card" style="margin-top: 24rpx;">
      <view class="card-title">✏️ 自定义词语</view>
      <input class="word-input" placeholder="输入平民词（如：西瓜）" value="{{customCivilian}}" data-field="civilian" bindinput="onCustomInput" />
      <input class="word-input" placeholder="输入卧底词（如：冬瓜）" value="{{customSpy}}" data-field="spy" bindinput="onCustomInput" />
      <text class="custom-tip">两个词要相似但不同，越像越刺激～</text>
    </view>

    <view class="card rule-card" style="margin-top: 24rpx;">
      <view class="card-title">📖 规则说明</view>
      <text class="rule-text">1. 所有玩家依次查看自己的词语</text>
      <text class="rule-text">2. 平民拿到相同的词，卧底拿到相似的词</text>
      <text class="rule-text">3. 每轮每人用一句话描述自己的词（不能直接说出）</text>
      <text class="rule-text">4. 每轮结束后投票淘汰疑似卧底的人</text>
      <text class="rule-text">5. 卧底全部出局则平民获胜，卧底存活到最后一轮则卧底获胜</text>
    </view>

    <button class="start-btn" bindtap="startGame">🎮 开始挑战</button>
  </view>

  <!-- 查看身份阶段：N 张卡片网格，当前玩家高亮，依次点完递给下一位 -->
  <view wx:if="{{state === 'viewing'}}">
    <view class="card viewing-card">
      <text class="viewing-hint">📱 请将手机递给 玩家 {{players[currentPlayer].id}}</text>
      <view class="viewing-grid">
        <view wx:for="{{players}}" wx:key="id" class="vcard vcard-{{item.status}}">
          <text class="vcard-no">玩家 {{item.id}}</text>
          <block wx:if="{{item.status === 'current'}}">
            <block wx:if="{{item.revealed}}">
              <text class="vcard-word">{{item.word}}</text>
              <text class="vcard-py" wx:if="{{item.pinyin}}">{{item.pinyin}}</text>
              <text class="vcard-role {{item.isSpy ? 'is-spy' : 'is-civ'}}">{{item.isSpy ? '卧底' : '平民'}}</text>
            </block>
            <block wx:else>
              <text class="vcard-q">❓</text>
              <view class="vcard-btn" bindtap="onReveal">👀 点击查看</view>
            </block>
          </block>
          <block wx:else>
            <text class="vcard-q done">✓</text>
            <text class="vcard-done">已查看</text>
          </block>
        </view>
      </view>
      <view class="next-btn" bindtap="onNextPlayer">
        {{allViewed ? '✅ 全部查看完毕，开始讨论' : '➡️ 下一位玩家'}}
      </view>
    </view>
  </view>

  <!-- 讨论阶段 -->
  <view wx:if="{{state === 'playing'}}">
    <view class="card">
      <view class="round-header">
        <text class="round-title">第 {{round}} 轮讨论</text>
      </view>
      <text class="discuss-hint">请每位玩家用一句话描述自己的词语</text>
      <text class="discuss-hint">注意不能直接说出词语！</text>
      <view class="action-btns">
        <view class="action-btn primary-btn" bindtap="onStartVoting">🗳️ 开始投票</view>
        <view class="action-btn secondary-btn" bindtap="onShowWords">👀 揭晓词语</view>
      </view>
    </view>
  </view>

  <!-- 投票阶段 -->
  <view wx:if="{{state === 'voting'}}">
    <view class="card">
      <view class="card-title">🗳️ 投票淘汰</view>
      <text class="vote-hint">点击你认为是卧底的玩家</text>
      <view class="vote-list">
        <view class="vote-item" wx:for="{{players}}" wx:key="id" data-id="{{item.id}}" bindtap="onVote">
          <text class="vote-player">🧒 玩家 {{item.id}}</text>
          <text class="vote-count" wx:if="{{votes[item.id]}}">{{votes[item.id]}} 票</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 结果阶段：对应 N 张卡片，显示每位玩家词与身份 -->
  <view wx:if="{{state === 'result'}}">
    <view class="card result-card">
      <text class="result-title">🎯 玩家 {{votedPlayer}} 被淘汰</text>
      <view class="result-grid">
        <view class="rcard" wx:for="{{players}}" wx:key="id">
          <text class="rc-no">玩家 {{item.id}}</text>
          <text class="rc-word">{{item.word}}</text>
          <text class="rc-py" wx:if="{{item.pinyin}}">{{item.pinyin}}</text>
          <text class="rc-role {{item.isSpy ? 'is-spy' : 'is-civ'}}">{{item.isSpy ? '🕵️ 卧底' : '👥 平民'}}</text>
        </view>
      </view>
      <view class="action-btns" style="margin-top: 32rpx;">
        <view class="action-btn primary-btn" bindtap="onNewRound">🔄 下一轮</view>
        <view class="action-btn secondary-btn" bindtap="onRestart">🏠 重新开始</view>
      </view>
    </view>
  </view>
  <!-- 揭晓词语 -->
  <view wx:if="{{state === 'showwords'}}">
    <view class="card result-card">
      <text class="result-title">🎯 词语揭晓</text>
      <view class="result-grid two-cols">
        <view class="rcard">
          <text class="rc-label">👥 平民词</text>
          <text class="rc-word">{{civilianWord}}</text>
          <text class="rc-py" wx:if="{{civilianPinyin}}">{{civilianPinyin}}</text>
        </view>
        <view class="rcard">
          <text class="rc-label">🕵️ 卧底词</text>
          <text class="rc-word">{{spyWord}}</text>
          <text class="rc-py" wx:if="{{spyPinyin}}">{{spyPinyin}}</text>
        </view>
      </view>
      <view class="action-btns" style="margin-top: 32rpx;">
        <view class="action-btn primary-btn" bindtap="onNewRound">🔄 下一轮</view>
        <view class="action-btn secondary-btn" bindtap="onRestart">🏠 重新开始</view>
      </view>
    </view>
  </view>
</view>
