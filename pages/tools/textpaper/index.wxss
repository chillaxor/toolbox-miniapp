.page-container {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 20rpx;
}

.fav-btn {
  font-size: 36rpx;
  color: #CCCCCC;
  padding: 8rpx 16rpx;
}

.fav-btn.active {
  color: #FF6B35;
}

.share-btn {
  font-size: 26rpx;
  color: #999999;
  padding: 8rpx 16rpx;
}

/* Canvas 预览区 */
.preview-area {
  display: flex;
  justify-content: center;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.paper-canvas {
  border-radius: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

/* 多页翻页 */
.page-nav {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 32rpx;
}

.page-btn {
  padding: 12rpx 28rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #333333;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.page-btn.disabled {
  color: #CCCCCC;
}

.page-info {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

/* 文字输入区 */
.section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.char-count {
  font-size: 24rpx;
  color: #999999;
}

.textarea-wrap {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.text-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.quick-btn {
  padding: 12rpx 28rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.quick-btn:active {
  opacity: 0.7;
}

/* 配置面板 */
.config-panel {
  margin: 0 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.config-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
}

.config-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.config-arrow {
  font-size: 32rpx;
  color: #999999;
  transition: transform 0.3s;
  transform: rotate(90deg);
}

.config-arrow.open {
  transform: rotate(270deg);
}

.config-body {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.config-group {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.config-group:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

/* 选项行 */
.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-item.active {
  background: #333333;
  border-color: #333333;
}

.option-item.active .option-text,
.option-item.active .option-icon {
  color: #FFFFFF;
}

.option-icon {
  font-size: 28rpx;
  color: #666666;
}

.option-text {
  font-size: 24rpx;
  color: #666666;
}

/* 颜色选择 */
.color-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #E5E5E5;
  transition: all 0.2s;
}

.color-dot.active {
  border-color: #333333;
  transform: scale(1.15);
  box-shadow: 0 0 0 3rpx rgba(51,51,51,0.2);
}

/* 滑块行 */
.slider-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.slider-row slider {
  flex: 1;
}

.slider-value {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
  min-width: 80rpx;
  text-align: right;
}

/* 边距输入 */
.margin-grid {
  display: flex;
  gap: 16rpx;
}

.margin-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.margin-label {
  font-size: 22rpx;
  color: #999999;
}

.margin-input {
  width: 100%;
  text-align: center;
  padding: 12rpx 8rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background: #F5F5F5;
  color: #333333;
}

.action-btn.primary {
  background: #333333;
  color: #FFFFFF;
}

.action-btn:active {
  opacity: 0.8;
}
