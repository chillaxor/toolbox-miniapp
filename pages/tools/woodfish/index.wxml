<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">电子木鱼</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 功德显示 -->
  <view class="merit-display">
    <text class="merit-label">功德</text>
    <text class="merit-count">{{meritCount}}</text>
    <text class="merit-unit">功德无量</text>
  </view>

  <!-- 今日功德 -->
  <view class="today-bar">
    <text class="today-text">今日功德：{{todayCount}}</text>
  </view>

  <!-- 木鱼区域 -->
  <view class="fish-area">
    <view class="fish-circle {{isTapping ? 'tapping' : ''}}" bindtap="onTap">
      <text class="fish-emoji">🪵</text>
    </view>
    <!-- 敲击文字动画 -->
    <view class="tap-text {{showText ? 'show' : ''}}" style="left: {{textLeft}}rpx; top: {{textTop}}rpx;">
      <text>+1</text>
    </view>
  </view>

  <!-- 敲击提示 -->
  <text class="tap-hint">敲击木鱼积功德</text>

  <!-- 连击统计 -->
  <view class="combo-bar" wx:if="{{comboCount > 1}}">
    <text class="combo-text">连击 ×{{comboCount}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row">
    <view class="action-btn" bindtap="onReset">
      <text class="action-icon">🔄</text>
      <text class="action-label">重置功德</text>
    </view>
    <view class="action-btn" bindtap="onAutoTap">
      <text class="action-icon">{{isAutoTapping ? '⏸️' : '▶️'}}</text>
      <text class="action-label">{{isAutoTapping ? '停止自动' : '自动敲击'}}</text>
    </view>
    <view class="action-btn" bindtap="onShare">
      <text class="action-icon">📤</text>
      <text class="action-label">分享功德</text>
    </view>
  </view>

  <!-- 木鱼寄语 -->
  <view class="card" style="margin-top: 32rpx;">
    <text class="card-title">🙏 木鱼寄语</text>
    <text class="blessing-text">{{blessing}}</text>
  </view>

  <!-- 功德等级 -->
  <view class="card" style="margin-top: 24rpx;">
    <text class="card-title">🏅 功德等级</text>
    <view class="level-info">
      <text class="level-name">{{levelName}}</text>
      <progress class="level-progress" percent="{{levelProgress}}" stroke-width="8" activeColor="#F5A623" />
      <text class="level-detail">距下一级还需 {{nextLevelRemain}} 功德</text>
    </view>
  </view>
</view>
