.container {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

.tool-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.tool-header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.tool-header-fav {
  font-size: 40rpx;
}

/* 功德显示 */
.merit-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

.merit-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.merit-count {
  font-size: 96rpx;
  font-weight: bold;
  color: #F5A623;
  line-height: 1.2;
}

.merit-unit {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 今日功德 */
.today-bar {
  display: flex;
  justify-content: center;
  padding: 12rpx 0;
  margin-bottom: 20rpx;
}

.today-text {
  font-size: 26rpx;
  color: #E67E22;
  background: #FFF5E6;
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
}

/* 木鱼区域 */
.fish-area {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  height: 420rpx;
}

.fish-circle {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #8B6914, #A0522D);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(139, 105, 20, 0.4), inset 0 -6rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: transform 0.1s ease;
}

.fish-circle.tapping {
  transform: scale(0.92);
}

.fish-emoji {
  font-size: 120rpx;
}

/* 敲击动画文字 */
.tap-text {
  position: absolute;
  font-size: 40rpx;
  font-weight: bold;
  color: #F5A623;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}

.tap-text.show {
  opacity: 1;
  transform: translateY(-40rpx);
  animation: floatUp 0.5s ease forwards;
}

@keyframes floatUp {
  0% {
    opacity: 1;
    transform: translateY(0);
  }
  100% {
    opacity: 0;
    transform: translateY(-60rpx);
  }
}

.tap-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 16rpx;
}

/* 连击 */
.combo-bar {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

.combo-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #E74C3C;
  background: #FDE8E8;
  padding: 8rpx 32rpx;
  border-radius: 30rpx;
  animation: pulse 0.3s ease;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

/* 操作按钮 */
.action-row {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 44rpx;
}

.action-label {
  font-size: 22rpx;
  color: #888;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.blessing-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 等级 */
.level-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #F5A623;
}

.level-progress {
  margin: 8rpx 0;
}

.level-detail {
  font-size: 24rpx;
  color: #999;
}
