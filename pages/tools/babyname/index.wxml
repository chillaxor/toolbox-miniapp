<!-- pages/tools/babyname/index.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-icon">👶</view>
    <view class="header-title">起名神器</view>
    <view class="header-sub">给宝宝起个好名字</view>
  </view>

  <!-- 输入区域 -->
  <view class="form-card">
    <!-- 姓氏输入 -->
    <view class="form-group">
      <view class="form-label">姓氏</view>
      <input class="surname-input" placeholder="输入姓氏" value="{{surname}}" bindinput="inputSurname" />
    </view>

    <!-- 常用姓氏快捷选择 -->
    <view class="surname-tags">
      <view class="surname-tag {{item.selected ? 'surname-active' : ''}}" 
        wx:for="{{surnameList}}" wx:key="index"
        wx:if="{{index < 21}}"
        data-name="{{item.name}}" bindtap="selectSurname">
        {{item.name}}
      </view>
    </view>

    <!-- 性别选择 -->
    <view class="form-group">
      <view class="form-label">性别</view>
      <view class="gender-row">
        <view class="gender-btn {{gender === 'boy' ? 'gender-active' : ''}}" data-gender="boy" bindtap="selectGender">
          <text class="gender-icon">👦</text>
          <text>男宝</text>
        </view>
        <view class="gender-btn {{gender === 'girl' ? 'gender-active' : ''}}" data-gender="girl" bindtap="selectGender">
          <text class="gender-icon">👧</text>
          <text>女宝</text>
        </view>
      </view>
    </view>

    <!-- 五行偏好 -->
    <view class="form-group">
      <view class="form-label">五行偏好 <text class="form-hint">（可选）</text></view>
      <view class="wuxing-row">
        <view class="wuxing-btn {{wuxing === item ? 'wuxing-active' : ''}}"
          wx:for="{{wuxingList}}" wx:key="index"
          data-wx="{{item}}" bindtap="selectWuxing">
          {{item}}
        </view>
      </view>
    </view>

    <!-- 生成按钮 -->
    <button class="generate-btn" bindtap="generateNames">✨ 生成名字</button>
  </view>

  <!-- 结果列表 -->
  <view class="result-section" wx:if="{{showResult}}">
    <view class="result-header">
      <text class="result-title">推荐名字</text>
      <view class="regenerate-btn" bindtap="regenerate">🔄 换一批</view>
    </view>

    <view class="name-card" wx:for="{{generated}}" wx:key="index">
      <view class="name-top">
        <view class="name-main">{{item.name}}</view>
        <view class="name-score">{{item.score}}分</view>
      </view>
      <view class="name-wuxing">五行属{{item.wuxing}}</view>
      <view class="name-meanings">
        <view class="meaning-item" wx:for="{{item.meanings}}" wx:for-item="m" wx:key="index">{{m}}</view>
      </view>
      <view class="name-fav" data-idx="{{index}}" bindtap="favName">❤️ 收藏</view>
    </view>
  </view>

  <!-- 收藏面板 -->
  <view class="fav-toggle" bindtap="toggleFavPanel" wx:if="{{favNames.length > 0}}">
    <text>❤️ 收藏的名字 ({{favNames.length}})</text>
    <text>{{showFavPanel ? '▲' : '▼'}}</text>
  </view>

  <view class="fav-panel" wx:if="{{showFavPanel}}">
    <view class="fav-item" wx:for="{{favNames}}" wx:key="index">
      <view class="fav-name">{{item.name}}</view>
      <view class="fav-score">{{item.score}}分</view>
      <text class="fav-remove" data-idx="{{index}}" catchtap="removeFav">🗑️</text>
    </view>
  </view>
</view>
