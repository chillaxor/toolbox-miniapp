/* pages/tools/babyname/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 0 0 60rpx 0;
  box-sizing: border-box;
}

.header {
  padding: 60rpx 32rpx 40rpx;
  text-align: center;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.form-card {
  background: #fff;
  margin: 0 32rpx;
  border-radius: 28rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.form-hint {
  font-weight: normal;
  color: #999;
  font-size: 24rpx;
}

.surname-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.surname-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.surname-tag {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.surname-tag.surname-active {
  background: #f5576c;
  color: #fff;
}

.gender-row {
  display: flex;
  gap: 20rpx;
}

.gender-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  border: 3rpx solid transparent;
}

.gender-btn.gender-active {
  background: #fff0f3;
  border-color: #f5576c;
  color: #f5576c;
  font-weight: bold;
}

.gender-icon {
  font-size: 36rpx;
}

.wuxing-row {
  display: flex;
  gap: 16rpx;
}

.wuxing-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  border: 3rpx solid transparent;
}

.wuxing-btn.wuxing-active {
  background: #fff0f3;
  border-color: #f5576c;
  color: #f5576c;
  font-weight: bold;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  line-height: 96rpx;
  margin-top: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(245,87,108,0.3);
}

/* 结果 */
.result-section {
  margin: 0 32rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.regenerate-btn {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
}

.name-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.name-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.name-main {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.name-score {
  font-size: 28rpx;
  color: #f5576c;
  font-weight: bold;
  background: #fff0f3;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.name-wuxing {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.name-meanings {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.meaning-item {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.name-fav {
  text-align: right;
  font-size: 26rpx;
  color: #f5576c;
  padding-top: 8rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 收藏 */
.fav-toggle {
  margin: 20rpx 32rpx 0;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.fav-toggle text {
  font-size: 28rpx;
  color: #fff;
}

.fav-panel {
  margin: 16rpx 32rpx 0;
  background: rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 24rpx;
}

.fav-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.fav-item:last-child {
  border-bottom: none;
}

.fav-name {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

.fav-score {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-right: 16rpx;
}

.fav-remove {
  font-size: 28rpx;
}
