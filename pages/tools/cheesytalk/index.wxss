/* pages/tools/cheesytalk/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff6b9d 0%, #c44dff 50%, #6e8efb 100%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* 主卡片 */
.main-card {
  background: rgba(255,255,255,0.95);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
  margin-bottom: 32rpx;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tag-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, #ff6b9d, #c44dff);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.line-text {
  font-size: 38rpx;
  color: #333;
  line-height: 1.8;
  font-weight: 500;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

.line-count {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  min-width: 120rpx;
}

.action-btn:active {
  background: rgba(255,255,255,0.35);
}

.share-btn-reset {
  border: none;
  padding: 20rpx 28rpx;
  margin: 0;
  line-height: normal;
  font-size: inherit;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
}

.share-btn-reset::after {
  border: none;
}

.action-icon {
  font-size: 40rpx;
}

.action-label {
  font-size: 22rpx;
  color: #fff;
}

/* 分类标签 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
  justify-content: center;
}

.tag-item {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
}

.tag-item.tag-active {
  background: #fff;
  color: #c44dff;
  font-weight: bold;
}

/* 收藏面板 */
.fav-toggle {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.fav-toggle text {
  font-size: 28rpx;
  color: #fff;
}

.fav-arrow {
  font-size: 24rpx;
}

.fav-panel {
  background: rgba(255,255,255,0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.fav-empty {
  text-align: center;
  color: rgba(255,255,255,0.6);
  font-size: 26rpx;
  padding: 32rpx 0;
}

.fav-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.fav-item:last-child {
  border-bottom: none;
}

.fav-line {
  flex: 1;
  margin-right: 16rpx;
}

.fav-tag {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  margin-right: 8rpx;
}

.fav-text {
  font-size: 26rpx;
  color: #fff;
  line-height: 1.6;
}

.fav-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.fav-act-btn {
  font-size: 32rpx;
  padding: 8rpx;
}
