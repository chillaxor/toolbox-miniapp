/* ------------------------------------------------------------------ */
/*  Variables & base                                                    */
/* ------------------------------------------------------------------ */

page {
  --bg: #0a0a14;
  --glass-bg: rgba(255, 255, 255, 0.06);
  --glass-border: rgba(255, 255, 255, 0.12);
  --accent: #a78bfa;
  --accent-glow: rgba(167, 139, 250, 0.45);
  --warm: #f59e0b;
  --cool: #3b82f6;
}

/* ------------------------------------------------------------------ */
/*  Page layout                                                        */
/* ------------------------------------------------------------------ */

.page {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.page.fullscreen {
  padding: 0;
  justify-content: center;
}

/* ------------------------------------------------------------------ */
/*  Hidden camera                                                      */
/* ------------------------------------------------------------------ */

.hidden-camera {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 1rpx;
  height: 1rpx;
  opacity: 0.01;
  z-index: -1;
  pointer-events: none;
}

/* ------------------------------------------------------------------ */
/*  Viewport                                                           */
/* ------------------------------------------------------------------ */

.viewport-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.viewport {
  width: 620rpx;
  height: 620rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  background: radial-gradient(circle, #1a1030 0%, #0a0510 100%);
  box-shadow:
    0 0 0 3rpx rgba(167, 139, 250, 0.2),
    0 0 40rpx rgba(167, 139, 250, 0.15),
    0 0 80rpx rgba(167, 139, 250, 0.08);
}

.fullscreen .viewport-wrap {
  width: 100vw;
  height: 100vh;
}

.fullscreen .viewport {
  width: 100vw;
  height: 100vw;
  border-radius: 0;
  box-shadow: none;
}

.kaleido-canvas {
  width: 100%;
  height: 100%;
}

.glow-ring {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(167, 139, 250, 0.15);
  pointer-events: none;
  animation: glowPulse 3s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

/* ------------------------------------------------------------------ */
/*  Info bar                                                           */
/* ------------------------------------------------------------------ */

.info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 0 8rpx;
  margin-bottom: 20rpx;
}

.fps-text {
  font-size: 22rpx;
  color: rgba(167, 139, 250, 0.6);
  font-family: monospace;
}

.seg-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ------------------------------------------------------------------ */
/*  Controls                                                           */
/* ------------------------------------------------------------------ */

.controls {
  width: 100%;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.control-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.control-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  min-width: 60rpx;
  text-align: right;
}

.btn-scroll {
  flex: 1;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.btn-scroll::-webkit-scrollbar {
  display: none;
}

.btn-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: nowrap;
}

.pill-btn {
  min-width: 72rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  white-space: nowrap;
  transition: all 0.2s ease;
}

.pill-btn.active {
  background: linear-gradient(135deg, rgba(167, 139, 250, 0.3), rgba(167, 139, 250, 0.15));
  color: #fff;
  border-color: rgba(167, 139, 250, 0.5);
  box-shadow: 0 0 16rpx rgba(167, 139, 250, 0.2);
}

/* 颜色按钮特殊样式 */
.color-pill[data-color="1"].active {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.3), rgba(245, 158, 11, 0.15));
  border-color: rgba(245, 158, 11, 0.5);
  box-shadow: 0 0 16rpx rgba(245, 158, 11, 0.2);
}

.color-pill[data-color="2"].active {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.3), rgba(59, 130, 246, 0.15));
  border-color: rgba(59, 130, 246, 0.5);
  box-shadow: 0 0 16rpx rgba(59, 130, 246, 0.2);
}

.color-pill[data-color="3"].active {
  background: linear-gradient(135deg, rgba(236, 72, 153, 0.3), rgba(167, 139, 250, 0.15));
  border-color: rgba(236, 72, 153, 0.5);
  box-shadow: 0 0 16rpx rgba(236, 72, 153, 0.2);
}

/* ------------------------------------------------------------------ */
/*  Action buttons                                                     */
/* ------------------------------------------------------------------ */

.action-row {
  display: flex;
  justify-content: space-around;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.action-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.action-icon-wrap:active {
  transform: scale(0.92);
  background: rgba(167, 139, 250, 0.15);
}

.action-icon {
  font-size: 34rpx;
}

.action-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ------------------------------------------------------------------ */
/*  Fullscreen hint                                                    */
/* ------------------------------------------------------------------ */

.fullscreen-hint {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  z-index: 30;
}

.fullscreen-hint text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
