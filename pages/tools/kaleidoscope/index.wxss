/* ------------------------------------------------------------------ */
/*  Variables & base                                                    */
/* ------------------------------------------------------------------ */

page {
  --vp-size: 640rpx;
  --bg: #0a0a14;
  --glass-bg: rgba(255, 255, 255, 0.08);
  --glass-border: rgba(255, 255, 255, 0.15);
  --accent: #a78bfa;
  --accent-glow: rgba(167, 139, 250, 0.45);
}

/* ------------------------------------------------------------------ */
/*  Page layout                                                        */
/* ------------------------------------------------------------------ */

.page {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.page.fullscreen {
  justify-content: center;
}

/* ------------------------------------------------------------------ */
/*  Hidden camera (keeps native camera layer alive)                    */
/* ------------------------------------------------------------------ */

.hidden-camera {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 1rpx;
  height: 1rpx;
  opacity: 0;
  pointer-events: none;
}

/* ------------------------------------------------------------------ */
/*  Kaleidoscope viewport                                              */
/* ------------------------------------------------------------------ */

.viewport {
  width: var(--vp-size);
  height: var(--vp-size);
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  background: #111;
  box-shadow:
    0 0 0 4rpx rgba(255, 255, 255, 0.1),
    0 0 60rpx var(--accent-glow);
  transition: width 0.3s ease, height 0.3s ease;
  will-change: transform;
}

.fullscreen .viewport {
  --vp-size: 100vw;
  border-radius: 0;
  box-shadow: none;
}

/* ------------------------------------------------------------------ */
/*  Segments                                                           */
/* ------------------------------------------------------------------ */

.segment {
  overflow: hidden;
}

.segment-camera {
  /* Each segment-camera fills its segment container.
     Because WeChat's camera component is a native layer, it cannot be
     clipped by CSS clip-path on most devices.  To work around this we
     give each camera the full viewport size and rely on the parent
     segment's clip-path (which IS a regular view and therefore clips
     its children correctly). */
  position: absolute;
  /* Centre the camera feed inside the clipped triangle */
  top: 50%;
  left: 50%;
  width: var(--vp-size);
  height: var(--vp-size);
  transform: translate(-50%, -50%);
}

/* Centre dot */
.centre-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  margin: -6rpx 0 0 -6rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 16rpx var(--accent-glow);
  pointer-events: none;
  z-index: 10;
}

/* ------------------------------------------------------------------ */
/*  Rotation keyframes (used as fallback; JS drives the main rotation) */
/* ------------------------------------------------------------------ */

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ------------------------------------------------------------------ */
/*  Controls                                                           */
/* ------------------------------------------------------------------ */

.controls {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: env(safe-area-inset-bottom, 24rpx);
  padding: 24rpx 20rpx;
  border-radius: 32rpx;
  background: var(--glass-bg);
  border: 1rpx solid var(--glass-border);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  z-index: 20;
}

/* Segment count selector */
.control-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.control-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  min-width: 56rpx;
}

.seg-buttons {
  display: flex;
  gap: 16rpx;
}

.seg-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.seg-btn.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
  box-shadow: 0 0 20rpx var(--accent-glow);
}

/* Action buttons row */
.action-row {
  display: flex;
  justify-content: space-around;
}

.btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.btn-icon {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.btn-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ------------------------------------------------------------------ */
/*  Fullscreen hint                                                    */
/* ------------------------------------------------------------------ */

.fullscreen-hint {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  background: rgba(0, 0, 0, 0.55);
  z-index: 30;
}

.fullscreen-hint text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ------------------------------------------------------------------ */
/*  Offscreen canvas (for screenshot)                                  */
/* ------------------------------------------------------------------ */

.offscreen-canvas {
  position: fixed;
  top: -9999rpx;
  left: -9999rpx;
  width: 600px;
  height: 600px;
}
