/* 额度卡片 */
.quota-card {
  padding: 32rpx;
  border-radius: 16rpx;
  color: #FFFFFF;
  margin-bottom: 24rpx;
}

.quota-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.quota-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.quota-value {
  font-size: 32rpx;
  font-weight: 700;
}

.quota-bar-bg {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.quota-bar-fill {
  height: 100%;
  background: #FFFFFF;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.quota-hint {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
  color: #FFD700;
}

/* 图片选择器 */
.image-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  border-radius: 12rpx;
  background-color: #F8F9FA;
  padding: 48rpx;
}

.picker-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.picker-desc {
  font-size: 24rpx;
  color: var(--color-hint);
}

/* 预览 */
.preview-box {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  min-height: 300rpx;
}

.preview-img {
  max-width: 100%;
  max-height: 600rpx;
  border-radius: 8rpx;
}

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.action-row .btn-primary {
  flex: 2;
}

.action-row .btn-secondary {
  flex: 1;
}

.btn-secondary {
  background: #F0F0F0;
  color: var(--color-secondary);
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 0 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
}

/* 加载动画 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E8E8E8;
  border-top-color: #9B59B6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.loading-sub {
  font-size: 24rpx;
  color: var(--color-hint);
}

/* 对比展示 */
.compare-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
}

.compare-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compare-label {
  font-size: 24rpx;
  color: var(--color-secondary);
  margin-bottom: 12rpx;
  font-weight: 600;
}

.compare-img {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-border);
}

.compare-divider {
  display: flex;
  align-items: center;
  padding: 0 4rpx;
}

.divider-icon {
  font-size: 36rpx;
  color: #9B59B6;
  font-weight: 700;
}

/* 结果操作 */
.result-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.result-actions .btn-primary {
  flex: 2;
}

.result-actions .btn-secondary {
  flex: 1;
}

.btn-clean {
  margin-top: 0;
}

.btn-save {
  margin-top: 0;
}

/* 通用样式 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  margin-bottom: 20rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-content {
  margin-left: 20rpx;
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.step-desc {
  font-size: 24rpx;
  color: var(--color-hint);
  display: block;
  margin-top: 4rpx;
}

.tips-card {
  margin-bottom: 48rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-dot {
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1.6;
}

.tip-text {
  font-size: 24rpx;
  color: var(--color-secondary);
  line-height: 1.6;
}