<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">翻牌配对</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 设置界面 -->
  <view wx:if="{{state === 'setup'}}" class="setup-section">
    <view class="card">
      <text class="card-title">选择难度</text>
      <view class="difficulty-btns">
        <view class="diff-btn {{difficulty === 'easy' ? 'diff-active' : ''}}" bindtap="onDifficultyChange" data-diff="easy">
          <text class="diff-icon">🌟</text>
          <text class="diff-name">简单</text>
          <text class="diff-desc">4×3 · 6对</text>
        </view>
        <view class="diff-btn {{difficulty === 'normal' ? 'diff-active' : ''}}" bindtap="onDifficultyChange" data-diff="normal">
          <text class="diff-icon">⭐</text>
          <text class="diff-name">普通</text>
          <text class="diff-desc">4×4 · 8对</text>
        </view>
        <view class="diff-btn {{difficulty === 'hard' ? 'diff-active' : ''}}" bindtap="onDifficultyChange" data-diff="hard">
          <text class="diff-icon">💫</text>
          <text class="diff-name">困难</text>
          <text class="diff-desc">6×4 · 12对</text>
        </view>
      </view>
    </view>

    <view class="card best-record" wx:if="{{bestRecord}}">
      <text class="card-title">🏆 最佳记录</text>
      <view class="record-info">
        <text class="record-text">用时：{{bestRecord.time}}秒</text>
        <text class="record-text">步数：{{bestRecord.steps}}步</text>
      </view>
    </view>

    <button class="start-btn" bindtap="startGame">🎮 开始游戏</button>
  </view>

  <!-- 游戏界面 -->
  <view wx:if="{{state === 'playing'}}" class="game-section">
    <!-- 顶部信息栏 -->
    <view class="info-bar">
      <view class="info-item">
        <text class="info-label">⏱️ 用时</text>
        <text class="info-value">{{timeDisplay}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">👆 步数</text>
        <text class="info-value">{{steps}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">✅ 配对</text>
        <text class="info-value">{{matchedPairs}}/{{totalPairs}}</text>
      </view>
    </view>

    <!-- 游戏棋盘 -->
    <view class="game-board" style="grid-template-columns: repeat({{cols}}, 1fr);">
      <view 
        class="card-cell {{item.flipped ? 'flipped' : ''}} {{item.matched ? 'matched' : ''}}" 
        wx:for="{{cards}}" 
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCardTap"
      >
        <view class="card-inner">
          <view class="card-front">
            <text class="card-question">?</text>
          </view>
          <view class="card-back">
            <text class="card-emoji">{{item.emoji}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 完成界面 -->
  <view wx:if="{{state === 'complete'}}" class="complete-section">
    <view class="card result-card">
      <text class="result-emoji">🎉</text>
      <text class="result-title">恭喜通关！</text>
      
      <view class="result-stars">
        <text class="star {{stars >= 1 ? 'star-active' : ''}}">⭐</text>
        <text class="star {{stars >= 2 ? 'star-active' : ''}}">⭐</text>
        <text class="star {{stars >= 3 ? 'star-active' : ''}}">⭐</text>
      </view>

      <view class="result-stats">
        <view class="stat-item">
          <text class="stat-value">{{timeDisplay}}</text>
          <text class="stat-label">用时</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{steps}}</text>
          <text class="stat-label">步数</text>
        </view>
      </view>

      <view class="new-record" wx:if="{{isNewRecord}}">
        <text>🏆 新纪录！</text>
      </view>

      <view class="action-btns">
        <view class="action-btn primary-btn" bindtap="onReplay">🔄 再来一局</view>
        <view class="action-btn secondary-btn" bindtap="onBackToSetup">🏠 返回设置</view>
      </view>
    </view>
  </view>
</view>
