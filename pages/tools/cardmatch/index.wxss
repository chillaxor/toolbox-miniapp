.container {
  padding: 20rpx 24rpx;
  padding-bottom: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.tool-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.tool-header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.tool-header-fav {
  font-size: 44rpx;
}

/* 设置界面 */
.setup-section {
  margin-top: 20rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.difficulty-btns {
  display: flex;
  gap: 16rpx;
}

.diff-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.diff-btn.diff-active {
  background: #EDE7F6;
  border-color: #7C4DFF;
}

.diff-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.diff-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.diff-desc {
  font-size: 22rpx;
  color: #999;
}

.best-record {
  margin-top: 24rpx;
}

.record-info {
  display: flex;
  gap: 32rpx;
}

.record-text {
  font-size: 28rpx;
  color: #666;
}

.start-btn {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #7C4DFF, #536DFE) !important;
  color: #fff !important;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0 60rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
}

/* 游戏界面 */
.game-section {
  margin-top: 16rpx;
}

.info-bar {
  display: flex;
  justify-content: space-between;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.info-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 4rpx;
}

/* 游戏棋盘 */
.game-board {
  display: grid;
  gap: 12rpx;
  perspective: 1000rpx;
}

.card-cell {
  aspect-ratio: 1;
  cursor: pointer;
  position: relative;
}

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.4s ease;
}

.card-cell.flipped .card-inner {
  transform: rotateY(180deg);
}

.card-front, .card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-front {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

.card-question {
  font-size: 48rpx;
  color: rgba(255,255,255,0.8);
  font-weight: bold;
}

.card-back {
  background: #fff;
  transform: rotateY(180deg);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.card-emoji {
  font-size: 56rpx;
}

.card-cell.matched .card-back {
  background: #E8F5E9;
  box-shadow: 0 0 16rpx rgba(76,175,80,0.4);
}

.card-cell.matched .card-emoji {
  opacity: 0.6;
}

/* 完成界面 */
.complete-section {
  margin-top: 40rpx;
}

.result-card {
  text-align: center;
}

.result-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.result-stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.star {
  font-size: 56rpx;
  opacity: 0.3;
  transition: opacity 0.3s;
}

.star-active {
  opacity: 1;
}

.result-stats {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #7C4DFF;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.new-record {
  background: linear-gradient(135deg, #FFD700, #FFA000);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 8rpx 32rpx;
  border-radius: 24rpx;
  display: inline-block;
  margin-bottom: 24rpx;
}

.action-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
}

.primary-btn {
  background: linear-gradient(135deg, #7C4DFF, #536DFE);
  color: #fff;
}

.secondary-btn {
  background: #f5f5f5;
  color: #666;
}
