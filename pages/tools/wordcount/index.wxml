<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">字数统计</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <view class="card">
    <textarea class="textarea-field" placeholder="请输入或粘贴文本内容" value="{{text}}" bindinput="onTextInput" auto-height maxlength="-1" />
    <view class="btn-row">
      <view class="btn-small" bindtap="onClear"><text>清空</text></view>
    </view>
  </view>

  <view class="card" wx:if="{{result}}">
    <view class="stat-grid">
      <view class="stat-item">
        <text class="stat-value">{{result.totalChars}}</text>
        <text class="stat-label">总字符</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{result.charNoSpace}}</text>
        <text class="stat-label">不含空格</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{result.chineseChars}}</text>
        <text class="stat-label">汉字</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{result.englishWords}}</text>
        <text class="stat-label">英文单词</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{result.paragraphs}}</text>
        <text class="stat-label">段落数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{result.lines}}</text>
        <text class="stat-label">行数</text>
      </view>
    </view>
  </view>
</view>
