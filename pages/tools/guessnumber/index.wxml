<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">猜数字</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 难度选择 -->
  <view class="card">
    <text class="card-title">选择难度</text>
    <view class="diff-btns">
      <view class="diff-btn {{difficulty === 'easy' ? 'diff-active' : ''}}" data-diff="easy" bindtap="onDifficultyChange">简单</view>
      <view class="diff-btn {{difficulty === 'normal' ? 'diff-active' : ''}}" data-diff="normal" bindtap="onDifficultyChange">普通</view>
      <view class="diff-btn {{difficulty === 'hard' ? 'diff-active' : ''}}" data-diff="hard" bindtap="onDifficultyChange">困难</view>
    </view>
  </view>

  <!-- 最佳记录 -->
  <view class="best-score" wx:if="{{bestScores[difficulty]}}">
    <text class="best-label">🏆 该难度最佳</text>
    <text class="best-value">{{bestScores[difficulty]}} 次</text>
  </view>

  <!-- 提示区域 -->
  <view class="hint-area">
    <text class="hint-text">{{hint}}</text>
    <text class="attempts-text" wx:if="{{attempts > 0}}">已猜 {{attempts}} 次</text>
  </view>

  <!-- 输入区域 -->
  <view class="card input-area" wx:if="{{!gameOver}}">
    <view class="input-row">
      <input class="guess-input" type="number" value="{{guess}}" bindinput="onInput" placeholder="输入你的猜测" bindconfirm="onGuess" />
      <view class="guess-btn" bindtap="onGuess">猜！</view>
    </view>
  </view>

  <!-- 挑战结束 -->
  <view class="card result-card" wx:if="{{gameOver}}">
    <text class="result-emoji">🎉</text>
    <text class="result-title">恭喜猜对！</text>
    <text class="result-detail">答案是 {{target}}</text>
    <text class="result-attempts">用了 {{attempts}} 次</text>
    <view class="restart-btn" bindtap="startGame">再来一局</view>
  </view>

  <!-- 猜测历史 -->
  <view class="card" wx:if="{{history.length > 0}}" style="margin-top: 32rpx;">
    <text class="card-title">猜测记录</text>
    <view class="history-list">
      <view class="history-item" wx:for="{{history}}" wx:key="timestamp">
        <text class="hi-number">{{item.value}}</text>
        <text class="hi-result {{item.result === '小了' ? 'hi-small' : (item.result === '大了' ? 'hi-big' : 'hi-correct')}}">{{item.result}}</text>
      </view>
    </view>
  </view>
</view>
