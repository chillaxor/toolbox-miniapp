.diff-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.diff-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  background: #F5F5F5;
  color: #666;
  border-radius: 12rpx;
  border: 2rpx solid #E5E5E5;
}

.diff-active {
  background: #E74C3C;
  color: #fff;
  border-color: #E74C3C;
}

.best-score {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.best-label {
  font-size: 28rpx;
  color: #999;
}

.best-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #E74C3C;
}

.hint-area {
  text-align: center;
  padding: 40rpx 0;
}

.hint-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.attempts-text {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.input-area {
  margin-top: 0;
}

.input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.guess-input {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  background: #F9F9F9;
}

.guess-btn {
  width: 160rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #E74C3C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

.result-card {
  text-align: center;
  padding: 48rpx 0;
}

.result-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #E74C3C;
  display: block;
  margin-bottom: 12rpx;
}

.result-detail {
  font-size: 32rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.result-attempts {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}

.restart-btn {
  width: 300rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #E74C3C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin: 0 auto;
}

.history-list {
  margin-top: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.history-item:last-child {
  border-bottom: none;
}

.hi-number {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.hi-result {
  font-size: 28rpx;
  font-weight: 600;
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
}

.hi-small {
  color: #3498DB;
  background: #EBF5FB;
}

.hi-big {
  color: #E67E22;
  background: #FEF5E7;
}

.hi-correct {
  color: #27AE60;
  background: #EAFAF1;
}
