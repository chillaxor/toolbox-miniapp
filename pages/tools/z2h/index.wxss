.container {
  padding: 20rpx 30rpx 40rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 30rpx 0 20rpx;
}
.header .title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}
.header .subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 通用区块 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 品类横向滚动 */
.type-scroll {
  white-space: nowrap;
}
.type-list {
  display: flex;
  gap: 20rpx;
}
.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 110rpx;
  padding: 16rpx 10rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  transition: all 0.2s;
  flex-shrink: 0;
}
.type-item.active {
  background: #e74c3c;
  color: #fff;
}
.type-icon {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}
.type-label {
  font-size: 22rpx;
}
.type-item.active .type-label {
  color: #fff;
}

/* 输入区 */
.input-area {
  width: 100%;
  min-height: 120rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 选项行 */
.option-row {
  display: flex;
  gap: 20rpx;
}
.option-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  background: #f8f8f8;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.option-btn.active {
  background: #e74c3c;
  color: #fff;
  font-weight: bold;
}

/* 配置项 */
.config-item {
  margin-bottom: 24rpx;
}
.config-item:last-child {
  margin-bottom: 0;
}
.config-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

/* 开关行 */
.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.switch-label {
  font-size: 28rpx;
  color: #666;
}

/* 颜色选择 */
.color-row {
  display: flex;
  gap: 24rpx;
  margin-top: 8rpx;
}
.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}
.color-dot.active {
  border-color: #e74c3c;
  transform: scale(1.15);
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin: 30rpx 0 20rpx;
}
.btn-generate {
  flex: 1;
  background: #e74c3c;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border-radius: 16rpx;
  text-align: center;
  border: none;
  line-height: 1.5;
}
.btn-generate::after {
  border: none;
}
.btn-primary {
  flex: 1;
  background: #e74c3c;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  text-align: center;
  border: none;
  line-height: 1.5;
}
.btn-primary::after {
  border: none;
}
.btn-secondary {
  flex: 1;
  background: #fff;
  color: #e74c3c;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid #e74c3c;
  line-height: 1.5;
}
.btn-secondary::after {
  border: none;
}

/* Canvas 预览区 */
.preview-section {
  padding-bottom: 40rpx;
}
.canvas-wrapper {
  background: #f0f0f0;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  justify-content: center;
}
.paper-canvas {
  display: block;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  border-radius: 4rpx;
}

/* 快捷模板 */
.template-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.template-item {
  padding: 14rpx 28rpx;
  background: #f8f8f8;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}
.template-item:active {
  background: #e74c3c;
  color: #fff;
}
