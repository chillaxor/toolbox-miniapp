.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFFFFF 20%);
  padding-bottom: 120rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #8D6E63;
  font-weight: bold;
  border-bottom-color: #8D6E63;
}

/* 时间轴 */
.timeline-container {
  position: relative;
  padding: 30rpx 30rpx 30rpx 60rpx;
}

.timeline-line {
  position: absolute;
  left: 48rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #8D6E63, #BCAAA4);
}

.timeline-item {
  position: relative;
  margin-bottom: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: -24rpx;
  top: 30rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #BCAAA4;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 4rpx #BCAAA4;
  z-index: 2;
}

.timeline-dot.active {
  background: #8D6E63;
  box-shadow: 0 0 0 4rpx #8D6E63;
}

.dynasty-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.timeline-item.expanded .dynasty-card {
  box-shadow: 0 8rpx 24rpx rgba(141,110,99,0.15);
}

.dynasty-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dynasty-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.dynasty-period {
  font-size: 24rpx;
  color: #8D6E63;
  background: #FFF3E0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.dynasty-summary {
  display: flex;
  gap: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.dynasty-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #eee;
}

.detail-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #555;
  margin-bottom: 12rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #FFF3E0;
  color: #8D6E63;
}

.tag.figure {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag.culture {
  background: #E3F2FD;
  color: #2196F3;
}

.expand-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 排序互动 */
.game-intro {
  text-align: center;
  padding: 80rpx 40rpx;
}

.intro-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.intro-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.intro-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 40rpx;
}

.start-btn {
  background: linear-gradient(135deg, #8D6E63, #A1887F);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  border: none;
}

.sort-game {
  padding: 20rpx;
}

.sort-progress {
  text-align: center;
  font-size: 28rpx;
  color: #8D6E63;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.sort-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.sort-item {
  width: 100%;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  border: 2rpx solid #eee;
  transition: all 0.2s;
}

.sort-item.selected {
  background: #FFF3E0;
  border-color: #8D6E63;
}

.sort-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.sort-item.selected .sort-index {
  background: #8D6E63;
  color: #fff;
}

.sort-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.sort-period {
  font-size: 24rpx;
  color: #999;
}

.sort-result {
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.sort-result.correct {
  background: #E8F5E9;
}

.sort-result.wrong {
  background: #FFEBEE;
}

.result-text {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.sort-result.correct .result-text {
  color: #4CAF50;
}

.sort-result.wrong .result-text {
  color: #F44336;
}

.result-score {
  font-size: 26rpx;
  color: #666;
}

.sort-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.retry-btn, .next-btn {
  background: linear-gradient(135deg, #8D6E63, #A1887F);
  color: #fff;
  border-radius: 50rpx;
  padding: 16rpx 50rpx;
  font-size: 28rpx;
  border: none;
}

.close-btn {
  background: #f5f5f5;
  color: #666;
  border-radius: 50rpx;
  padding: 16rpx 50rpx;
  font-size: 28rpx;
  border: none;
}

/* 问答模式 */
.quiz-game {
  padding: 20rpx;
}

.quiz-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.quiz-progress {
  font-size: 28rpx;
  color: #8D6E63;
  font-weight: bold;
}

.quiz-score {
  font-size: 28rpx;
  color: #FF9800;
  font-weight: bold;
}

.quiz-question {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.question-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  font-weight: bold;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.quiz-option {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid #eee;
  transition: all 0.2s;
}

.quiz-option.correct {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.quiz-option.wrong {
  background: #FFEBEE;
  border-color: #F44336;
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
}

.quiz-option.correct .option-letter {
  background: #4CAF50;
  color: #fff;
}

.quiz-option.wrong .option-letter {
  background: #F44336;
  color: #fff;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.quiz-feedback {
  text-align: center;
  padding: 20rpx;
}

.feedback-text {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.feedback-text.correct {
  color: #4CAF50;
}

.feedback-text.wrong {
  color: #F44336;
}

.quiz-result {
  text-align: center;
  padding: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-top: 20rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.quiz-result .result-score {
  font-size: 48rpx;
  color: #FF9800;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.result-detail {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
}

/* 收藏按钮 */
.favorite-btn {
  position: fixed;
  right: 30rpx;
  bottom: 160rpx;
  background: #fff;
  border-radius: 50%;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  z-index: 100;
}

.fav-icon {
  font-size: 36rpx;
}

.fav-text {
  font-size: 18rpx;
  color: #999;
}
