.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

/* 标签栏 */
.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  padding: 16rpx 10rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab.active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(1.05);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.tab.active .tab-text {
  color: #fff;
  font-weight: 700;
}

/* 内容区域 */
.content {
  padding: 20rpx 24rpx;
}

.group-section {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 拼音网格 */
.pinyin-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pinyin-cell {
  width: calc((100% - 60rpx) / 6);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.pinyin-cell:active {
  transform: scale(0.92);
}

.pinyin-cell.selected {
  background: rgba(255, 255, 255, 0.45);
  border-color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  transform: scale(1.08);
}

.pinyin-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.whole-cell {
  width: calc((100% - 48rpx) / 5);
}

/* 详情卡片 */
.detail-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.detail-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.detail-pinyin {
  font-size: 64rpx;
  color: #333;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.detail-word {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.speak-btn {
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 60rpx;
  border: none;
  line-height: 1.5;
}

.speak-btn::after {
  border: none;
}

/* 声调学习 */
.tones-section {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 24rpx;
}

.tone-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tone-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  transition: all 0.3s;
}

.tone-item:active {
  transform: scale(0.97);
  background: rgba(255, 255, 255, 0.25);
}

.tone-left {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}

.tone-symbol {
  font-size: 52rpx;
  color: #fff;
  font-weight: 700;
  margin-right: 16rpx;
  width: 60rpx;
  text-align: center;
}

.tone-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
}

.tone-right {
  flex: 1;
}

.tone-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 4rpx;
}

.tone-example {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.tone-play {
  font-size: 36rpx;
  margin-left: 16rpx;
}

.tone-1 .tone-symbol { color: #FFD700; }
.tone-2 .tone-symbol { color: #00FF88; }
.tone-3 .tone-symbol { color: #87CEEB; }
.tone-4 .tone-symbol { color: #FF6B6B; }
.tone-0 .tone-symbol { color: #ccc; }

/* 规则卡片 */
.rule-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.rule-card {
  width: calc(50% - 8rpx);
  background: rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  padding: 20rpx;
}

.rule-title {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.rule-example {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 手势练习 */
.gesture-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.gesture-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
}

.gesture-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
  width: 50rpx;
  text-align: center;
}

.gesture-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 练习模式选择 */
.practice-modes {
  padding: 0;
}

.mode-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mode-card {
  width: calc(50% - 8rpx);
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  transition: all 0.3s;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
}

.mode-card:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.35);
}

.mode-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.mode-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
}

/* 练习区域 */
.practice-area {
  animation: slideUp 0.3s ease;
}

.practice-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.practice-progress {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.practice-score {
  font-size: 26rpx;
  color: #FFD700;
  font-weight: 600;
}

.practice-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFA500);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* 题目区域 */
.question-area {
  text-align: center;
}

.question-pinyin {
  font-size: 96rpx;
  color: #fff;
  font-weight: 700;
  margin: 32rpx 0;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.question-tip {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 32rpx;
}

/* 发音按钮 */
.question-speaker {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 32rpx 0;
}

.speaker-icon {
  font-size: 96rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.speaker-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* 选项网格 */
.options-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.option-item {
  width: calc(50% - 8rpx);
  padding: 28rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.15);
  transition: all 0.3s;
  text-align: center;
}

.option-item:active {
  transform: scale(0.95);
}

.option-item.correct {
  background: rgba(76, 175, 80, 0.5);
  border-color: #4CAF50;
  animation: correctPulse 0.5s ease;
}

@keyframes correctPulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

.option-item.wrong {
  background: rgba(244, 67, 54, 0.5);
  border-color: #F44336;
  animation: wrongShake 0.5s ease;
}

@keyframes wrongShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-10rpx); }
  40% { transform: translateX(10rpx); }
  60% { transform: translateX(-10rpx); }
  80% { transform: translateX(10rpx); }
}

.option-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.option-pinyin {
  font-size: 32rpx;
}

.option-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 声调选项 */
.tone-options .tone-opt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.tone-options .option-text {
  font-size: 56rpx;
}

/* 连线模式 */
.match-area {
  display: flex;
  gap: 32rpx;
  justify-content: center;
  margin-top: 20rpx;
}

.match-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.match-item:active {
  transform: scale(0.95);
}

.match-item.match-selected {
  background: rgba(255, 215, 0, 0.4);
  border-color: #FFD700;
  box-shadow: 0 0 16rpx rgba(255, 215, 0, 0.3);
}

.match-item.match-done {
  background: rgba(76, 175, 80, 0.4);
  border-color: #4CAF50;
  opacity: 0.7;
}

/* 结果反馈 */
.result-feedback {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  text-align: center;
  animation: slideUp 0.3s ease;
}

.result-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.result-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
}

.next-btn {
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 80rpx;
  border: none;
  line-height: 1.5;
}

.next-btn::after {
  border: none;
}

/* 练习结果 */
.practice-result {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-top: 32rpx;
  text-align: center;
  animation: slideUp 0.4s ease;
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  color: #333;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.result-score {
  font-size: 56rpx;
  color: #667eea;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.result-detail {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.result-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.retry-btn {
  background: linear-gradient(135deg, #667eea, #764ba2) !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border: none;
  line-height: 1.5;
}

.retry-btn::after {
  border: none;
}

.back-btn {
  background: rgba(0, 0, 0, 0.05) !important;
  color: #666 !important;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border: none;
  line-height: 1.5;
}

.back-btn::after {
  border: none;
}
