.container {
  padding: 30rpx;
  min-height: 100vh;
  background: var(--color-bg, #f5f5f5);
}

/* 头部 */
.tool-header {
  display: flex;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.header-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text, #333);
}

/* 录音区域 */
.record-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.record-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--color-danger, #e74c3c);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(231, 76, 60, 0.4);
}

.record-btn.recording {
  background: var(--color-danger, #e74c3c);
  animation: pulse-shadow 1.5s infinite;
}

.record-btn-icon {
  font-size: 80rpx;
}

.pulse-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-danger, #e74c3c);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  100% {
    transform: scale(1.6);
    opacity: 0;
  }
}

@keyframes pulse-shadow {
  0%, 100% {
    box-shadow: 0 8rpx 24rpx rgba(231, 76, 60, 0.4);
  }
  50% {
    box-shadow: 0 8rpx 48rpx rgba(231, 76, 60, 0.8);
  }
}

.record-hint {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: var(--color-text-secondary, #888);
}

.recording-timer {
  margin-top: 24rpx;
  font-size: 56rpx;
  font-weight: bold;
  color: var(--color-danger, #e74c3c);
  font-family: 'Courier New', Courier, monospace;
}

.stop-btn {
  margin-top: 30rpx;
  padding: 16rpx 60rpx;
  background: var(--color-danger, #e74c3c);
  border-radius: 40rpx;
  color: #fff;
  font-size: 30rpx;
}

.recording-status {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--color-danger, #e74c3c);
}

/* 列表区域 */
.list-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: var(--color-text-secondary, #888);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #888);
}

/* 录音条目 */
.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-card, #fff);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-item.playing {
  background: #e8f8e8;
  box-shadow: 0 2rpx 12rpx rgba(39, 174, 96, 0.15);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text, #333);
}

.item-date {
  font-size: 24rpx;
  color: var(--color-text-secondary, #999);
  margin-top: 6rpx;
}

.item-duration {
  font-size: 26rpx;
  color: var(--color-primary, #3498db);
  margin-top: 6rpx;
  font-family: 'Courier New', Courier, monospace;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.play-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #27ae60;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

.play-btn.playing {
  background: #f39c12;
}

.delete-btn {
  padding: 10rpx 20rpx;
}

.delete-btn text {
  font-size: 26rpx;
  color: var(--color-danger, #e74c3c);
}
