.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.tool-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.tool-header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.tool-header-fav {
  font-size: 44rpx;
  padding: 8rpx;
}

.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
  display: block;
}

.ready-desc {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ready-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

.count-btns {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.count-btn {
  flex: 1;
  min-width: 140rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.count-active {
  background: rgba(255, 200, 50, 0.2);
  color: #FFC832;
  border-color: #FFC832;
  font-weight: bold;
}

.best-info {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 20rpx;
  background: rgba(255, 200, 50, 0.08);
  border-radius: 16rpx;
}

.best-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.best-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFC832;
}

.start-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFC832, #FF8008);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 128, 8, 0.3);
}

.start-btn::after {
  border: none;
}

/* 游戏信息 */
.game-info {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.info-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.combo-value {
  color: #FFC832;
}

/* 完美提示 */
.perfect-hint {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFC832;
  margin-bottom: 12rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s;
  height: 48rpx;
  line-height: 48rpx;
}

.perfect-hint.show {
  opacity: 1;
  transform: translateY(0);
}

/* 游戏画布 */
.game-canvas {
  width: 100%;
  height: 800rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.tap-hint {
  text-align: center;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 结果 */
.result-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.result-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 24rpx;
}

.result-tower {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tower-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tower-num {
  font-size: 80rpx;
  font-weight: bold;
  color: #FFC832;
  line-height: 1;
}

.tower-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.result-score {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 32rpx;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.new-record {
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFC832;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.05); }
}
