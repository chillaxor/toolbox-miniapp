.container {
  min-height: 100vh;
  background: #f5f0e8;
  padding-bottom: 40rpx;
}

/* 分类栏 */
.category-bar {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.cat-tag {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  margin: 0 8rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  flex-shrink: 0;
  transition: all 0.2s;
}

.cat-tag.active {
  background: linear-gradient(135deg, #FF6B6B, #ee5a24);
}

.cat-icon {
  font-size: 32rpx;
}

.cat-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.cat-tag.active .cat-name {
  color: #fff;
}

/* 模板选择栏 */
.template-bar {
  display: flex;
  white-space: nowrap;
  padding: 16rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tpl-thumb {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  cursor: pointer;
}

.tpl-canvas {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  border: 3rpx solid #e0e0e0;
  background: #f8f8f8;
}

.tpl-thumb.active .tpl-canvas {
  border-color: #FF6B6B;
  box-shadow: 0 0 0 3rpx rgba(255, 107, 107, 0.3);
}

.tpl-name {
  font-size: 20rpx;
  color: #666;
  margin-top: 6rpx;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tpl-thumb.active .tpl-name {
  color: #FF6B6B;
  font-weight: bold;
}

/* 画布区域 */
.canvas-area {
  margin: 20rpx 16rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.canvas-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tpl-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.difficulty {
  font-size: 22rpx;
  color: #FF9F43;
}

.canvas-wrap {
  position: relative;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  margin: 0 auto;
  overflow: hidden;
}

.main-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.svg-region-selected {
  stroke: #FF6B6B !important;
  stroke-width: 1.5 !important;
  stroke-dasharray: 2 1;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 16rpx;
  margin: 0 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.action-btn:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.action-btn.eraser-on {
  background: #e8f5e9;
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 调色板 */
.palette-section {
  margin: 20rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.palette-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  justify-content: center;
}

.color-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid #e0e0e0;
  box-sizing: border-box;
  transition: all 0.15s;
}

.color-dot.active {
  border-color: #333;
  transform: scale(1.2);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.color-dot.small {
  width: 40rpx;
  height: 40rpx;
}

.custom-btn {
  background: conic-gradient(red, yellow, lime, aqua, blue, magenta, red) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.5);
}

.history-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 10rpx;
  justify-content: center;
}

.history-label {
  font-size: 22rpx;
  color: #999;
}

/* 自定义颜色弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.picker-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.picker-popup {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  z-index: 101;
  transition: bottom 0.3s;
}

.picker-popup.show {
  bottom: 0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.picker-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin: 0 auto 30rpx;
  border: 3rpx solid #e0e0e0;
}

.picker-input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.picker-btns {
  display: flex;
  gap: 20rpx;
}

.picker-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.picker-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.picker-btn.confirm {
  background: #FF6B6B;
  color: #fff;
}

/* 作品集弹窗 */
.gallery-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.gallery-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.gallery-popup {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  z-index: 101;
  max-height: 60vh;
  transition: bottom 0.3s;
}

.gallery-popup.show {
  bottom: 0;
}

.gallery-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 24rpx;
}

.gallery-scroll {
  max-height: 45vh;
}

.gallery-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.gallery-name {
  font-size: 28rpx;
  color: #333;
}

.gallery-delete {
  font-size: 28rpx;
  color: #ccc;
  padding: 8rpx 16rpx;
}

.gallery-delete:active {
  color: #e74c3c;
}

.empty-text {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 40rpx 0;
}
