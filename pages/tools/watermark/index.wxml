<view class="container">
  <!-- 拍照/选图 -->
  <view class="photo-area" wx:if="{{!photoPath}}">
    <view class="upload-btn" bindtap="choosePhoto">
      <text class="upload-icon">📸</text>
      <text class="upload-text">拍照或选择照片</text>
      <text class="upload-hint">为照片添加时间水印</text>
    </view>
  </view>

  <!-- 预览+水印叠加 -->
  <view class="preview-area" wx:if="{{photoPath}}">
    <view class="photo-frame">
      <image class="photo-img" src="{{resultPath || photoPath}}" mode="aspectFit" />
      <!-- 水印预览（仅展示，不影响保存） -->
      <view class="watermark-overlay watermark-{{watermarkPosition}}" wx:if="{{!resultPath}}">
        <view class="watermark-block">
          <view class="wm-line" wx:if="{{showDate}}">{{watermarkDate}}</view>
          <view class="wm-line" wx:if="{{showTime}}">{{watermarkTime}}</view>
          <view class="wm-line" wx:if="{{showCustom && customText}}">{{customText}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 水印设置 -->
  <view class="settings" wx:if="{{photoPath}}">
    <view class="setting-title">⚙️ 水印设置</view>

    <view class="setting-row">
      <text class="setting-label">日期</text>
      <switch checked="{{showDate}}" bindchange="toggleSetting" data-key="showDate" color="#667eea" />
    </view>
    <view class="setting-row">
      <text class="setting-label">时间</text>
      <switch checked="{{showTime}}" bindchange="toggleSetting" data-key="showTime" color="#667eea" />
    </view>
    <view class="setting-row">
      <text class="setting-label">自定义文字</text>
      <switch checked="{{showCustom}}" bindchange="toggleSetting" data-key="showCustom" color="#667eea" />
    </view>
    <view class="setting-row" wx:if="{{showCustom}}">
      <input class="custom-input" placeholder="输入自定义水印文字" value="{{customText}}" bindinput="onCustomInput" maxlength="20" />
    </view>

    <!-- 位置选择 -->
    <view class="setting-title">📌 水印位置</view>
    <view class="position-bar">
      <view class="pos-btn {{watermarkPosition === 'top-left' ? 'pos-active' : ''}}" bindtap="setPosition" data-pos="top-left">左上</view>
      <view class="pos-btn {{watermarkPosition === 'top-right' ? 'pos-active' : ''}}" bindtap="setPosition" data-pos="top-right">右上</view>
      <view class="pos-btn {{watermarkPosition === 'bottom-left' ? 'pos-active' : ''}}" bindtap="setPosition" data-pos="bottom-left">左下</view>
      <view class="pos-btn {{watermarkPosition === 'bottom-right' ? 'pos-active' : ''}}" bindtap="setPosition" data-pos="bottom-right">右下</view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <view class="btn-save {{generating ? 'btn-disabled' : ''}}" bindtap="savePhoto">
        {{generating ? '生成中...' : '保存到相册'}}
      </view>
      <view class="btn-rechoose" bindtap="rechoose">重新选图</view>
    </view>
  </view>

  <!-- 隐藏canvas：尺寸跟随图片动态变化 -->
  <canvas canvas-id="watermark-canvas"
    style="position:fixed;left:-9999px;top:-9999px;width:{{canvasW}}px;height:{{canvasH}}px;"></canvas>
</view>
