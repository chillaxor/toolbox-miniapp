/* pages/tools/mbtitest/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* 介绍页 */
.intro {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.intro-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.intro-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.intro-subtitle {
  font-size: 30rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 40rpx;
}

.intro-desc {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.intro-desc text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  line-height: 2;
}

.intro-types {
  display: flex;
  gap: 16rpx;
  margin-bottom: 60rpx;
}

.type-tag {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.start-btn {
  width: 80%;
  height: 96rpx;
  background: #fff;
  color: #764ba2;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  line-height: 96rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
}

/* 历史记录 */
.history-section {
  width: 100%;
  margin-top: 60rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.history-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
}

.history-item:last-child {
  border-bottom: none;
}

.history-emoji {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.history-type {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 12rpx;
}

.history-name {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 测试页 */
.testing {
  padding-top: 20rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 4rpx;
  margin-bottom: 24rpx;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.question-count {
  text-align: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 40rpx;
}

.question-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 60rpx;
  padding: 0 20rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-btn {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  transition: transform 0.15s ease;
}

.option-btn:active {
  transform: scale(0.97);
}

.option-letter {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

/* 结果页 */
.result {
  padding-top: 20rpx;
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.result-type-code {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
  margin-bottom: 8rpx;
}

.result-type-name {
  font-size: 36rpx;
  color: rgba(255,255,255,0.9);
}

.result-desc {
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  padding: 32rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.8;
  margin-bottom: 32rpx;
  text-align: center;
}

.traits-section {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.trait-tag {
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
}

/* 维度分析 */
.dimensions-section {
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.dim-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 28rpx;
  text-align: center;
}

.dim-item {
  margin-bottom: 28rpx;
}

.dim-item:last-child {
  margin-bottom: 0;
}

.dim-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 12rpx;
  text-align: center;
}

.dim-bar-wrap {
  width: 100%;
}

.dim-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.dim-bar-left {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.dim-percent {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

.dim-active {
  color: #fff;
  font-weight: bold;
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 24rpx;
}

.restart-btn, .share-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  line-height: 88rpx;
}

.restart-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.share-btn {
  background: #fff;
  color: #764ba2;
}
