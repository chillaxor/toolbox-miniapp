.cat-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cat-tag {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  background: #F5F5F5;
  color: #666;
  border-radius: 24rpx;
  border: 2rpx solid #E5E5E5;
}

.cat-active {
  background: #FDE8E8;
  color: #E74C3C;
  border-color: #E74C3C;
}

.action-area {
  margin: 32rpx 0;
}

.btn-random {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: none;
}

.btn-random.shaking {
  animation: shake 0.1s infinite;
}

@keyframes shake {
  0% { transform: translateX(-2px); }
  50% { transform: translateX(2px); }
  100% { transform: translateX(-2px); }
}

.btn-random-outline {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  color: #E74C3C;
  font-size: 28rpx;
  background: #fff;
  border: 2rpx solid #E74C3C;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-card {
  text-align: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(231, 76, 60, 0.15);
}

.result-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.result-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.result-cat {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-again {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  color: #999;
  background: #F5F5F5;
  border-radius: 40rpx;
  border: none;
}

.btn-ok {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  color: #fff;
  border-radius: 40rpx;
  border: none;
}

.result-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.result-option {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.result-option:last-of-type {
  border-bottom: none;
}

.ro-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.ro-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.ro-cat {
  font-size: 22rpx;
  color: #999;
}

.btn-again-center {
  width: 60%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  color: #E74C3C;
  background: #FDE8E8;
  border-radius: 36rpx;
  border: none;
  margin: 16rpx auto 0;
}

.custom-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.custom-add-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #E74C3C;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.custom-list {
  margin-top: 8rpx;
}

.custom-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.ci-name {
  font-size: 26rpx;
  color: #333;
}

.ci-del {
  font-size: 28rpx;
  color: #ccc;
  padding: 8rpx;
}
