.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 0 0 120rpx 0;
}

.header {
  padding: 40rpx 32rpx 30rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.remind-setting {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}

.remind-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.remind-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 32rpx;
  margin: 0 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
}

.stats-item {
  text-align: center;
}

.stats-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.list-area {
  padding: 0 24rpx;
}

.cert-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.cert-card.expired {
  border-left: 8rpx solid #e74c3c;
}

.cert-card.warning {
  border-left: 8rpx solid #f39c12;
}

.cert-card.normal {
  border-left: 8rpx solid #27ae60;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.cert-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.cert-info {
  flex: 1;
}

.cert-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3436;
}

.cert-name {
  font-size: 24rpx;
  color: #636e72;
  margin-top: 4rpx;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.status-tag.expired {
  background: #ffeaea;
  color: #e74c3c;
}

.status-tag.warning {
  background: #fff8e1;
  color: #f39c12;
}

.status-tag.normal {
  background: #e8f5e9;
  color: #27ae60;
}

.days-num {
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.days-num.expired {
  color: #e74c3c;
}

.days-num.warning {
  color: #f39c12;
}

.days-num.normal {
  color: #27ae60;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.expire-date {
  font-size: 24rpx;
  color: #b2bec3;
}

.card-actions {
  display: flex;
  gap: 16rpx;
}

.btn-edit,
.btn-del {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.btn-edit {
  background: #edf2ff;
  color: #667eea;
}

.btn-del {
  background: #ffeaea;
  color: #e74c3c;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 20rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

.fab-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.5);
  z-index: 100;
}

.fab-icon {
  font-size: 50rpx;
  color: #fff;
  font-weight: 300;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d3436;
  text-align: center;
  margin-bottom: 30rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 12rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 14rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #edf2ff;
  border-color: #667eea;
}

.type-item-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.type-item-text {
  font-size: 24rpx;
  color: #2d3436;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2d3436;
  box-sizing: border-box;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.date-text {
  font-size: 28rpx;
  color: #2d3436;
}

.date-placeholder {
  font-size: 28rpx;
  color: #b2bec3;
}

.date-arrow {
  font-size: 24rpx;
  color: #b2bec3;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f0f0f0;
  color: #636e72;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.modal-btn.disabled {
  opacity: 0.5;
}

.remark-input {
  font-size: 24rpx;
}
