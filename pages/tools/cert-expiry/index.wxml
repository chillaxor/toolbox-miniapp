<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-title">🪪 证件有效期管理</view>
    <view class="header-sub">证件到期提前提醒，再也不怕忘记续期</view>
    <view class="remind-setting" bindtap="onShowRemindSetting">
      <text class="remind-icon">🔔</text>
      <text class="remind-text">提前{{remindDays}}天提醒</text>
    </view>
  </view>

  <!-- 统计栏 -->
  <view class="stats-bar" wx:if="{{certList.length > 0}}">
    <view class="stats-item">
      <view class="stats-num">{{stats.total}}</view>
      <view class="stats-label">全部证件</view>
    </view>
    <view class="stats-item">
      <view class="stats-num" style="color: #ff6b6b">{{stats.expired}}</view>
      <view class="stats-label">已过期</view>
    </view>
    <view class="stats-item">
      <view class="stats-num" style="color: #ffd93d">{{stats.warning}}</view>
      <view class="stats-label">即将过期</view>
    </view>
    <view class="stats-item">
      <view class="stats-num" style="color: #a8e6cf">{{stats.normal}}</view>
      <view class="stats-label">正常</view>
    </view>
  </view>

  <!-- 证件列表 -->
  <view class="list-area">
    <block wx:for="{{certList}}" wx:key="id">
      <view class="cert-card {{item.statusClass}}" data-id="{{item.id}}" bindtap="onCardTap">
        <view class="card-top">
          <view class="card-left">
            <view class="cert-icon">{{item.typeIcon}}</view>
            <view class="cert-info">
              <view class="cert-type">{{item.typeName}}</view>
              <view class="cert-name" wx:if="{{item.name}}">{{item.name}}</view>
            </view>
          </view>
          <view class="card-right">
            <view class="status-tag {{item.statusClass}}">{{item.statusText}}</view>
            <view class="days-num {{item.statusClass}}">{{item.daysText}}</view>
          </view>
        </view>
        <view class="card-bottom">
          <view class="expire-date">到期：{{item.expireDate}}</view>
          <view class="card-actions">
            <view class="btn-edit" catchtap="onEdit" data-id="{{item.id}}">编辑</view>
            <view class="btn-del" catchtap="onDelete" data-id="{{item.id}}">删除</view>
          </view>
        </view>
        <view class="remark-text" wx:if="{{item.remark}}" style="font-size:22rpx;color:#b2bec3;margin-top:10rpx;">📝 {{item.remark}}</view>
      </view>
    </block>

    <!-- 空态 -->
    <view class="empty-state" wx:if="{{certList.length === 0}}">
      <view class="empty-icon">🪪</view>
      <view class="empty-text">还没有添加任何证件</view>
      <view class="empty-sub">点击右下角 + 号添加第一张证件</view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab-btn" bindtap="onAdd">
    <view class="fab-icon">+</view>
  </view>

  <!-- 提醒天数设置弹窗 -->
  <view class="modal-mask" wx:if="{{showRemindModal}}" catchtap="onRemindModalBgTap">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">🔔 提前提醒天数</view>
      <view class="type-grid">
        <view class="type-item {{remindDays === item ? 'active' : ''}}"
              wx:for="{{remindOptions}}" wx:key="*this"
              bindtap="onSelectRemindDays" data-days="{{item}}">
          <view class="type-item-text">{{item}}天</view>
        </view>
      </view>
      <view class="modal-btns">
        <view class="modal-btn confirm" bindtap="onConfirmRemind">确定</view>
      </view>
    </view>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" catchtap="onModalBgTap">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">{{editId ? '编辑证件' : '添加证件'}}</view>

      <!-- 证件类型 -->
      <view class="form-group">
        <view class="form-label">证件类型</view>
        <view class="type-grid">
          <view class="type-item {{selectedType === item.key ? 'active' : ''}}"
                wx:for="{{typeOptions}}" wx:key="key"
                bindtap="onSelectType" data-key="{{item.key}}">
            <view class="type-item-icon">{{item.icon}}</view>
            <view class="type-item-text">{{item.name}}</view>
          </view>
        </view>
      </view>

      <!-- 自定义类型名 -->
      <view class="form-group" wx:if="{{selectedType === 'custom'}}">
        <view class="form-label">证件名称</view>
        <input class="form-input" placeholder="输入证件名称" value="{{form.customType}}" bindinput="onInputCustomType" />
      </view>

      <!-- 姓名/备注 -->
      <view class="form-group">
        <view class="form-label">持证人姓名（选填）</view>
        <input class="form-input" placeholder="如：张三" value="{{form.name}}" bindinput="onInputName" />
      </view>

      <!-- 到期日期 -->
      <view class="form-group">
        <view class="form-label">到期日期</view>
        <picker mode="date" value="{{form.expireDate}}" start="2020-01-01" end="2050-12-31" bindchange="onDateChange">
          <view class="date-picker">
            <view class="{{form.expireDate ? 'date-text' : 'date-placeholder'}}">
              {{form.expireDate || '请选择到期日期'}}
            </view>
            <view class="date-arrow">▶</view>
          </view>
        </picker>
      </view>

      <!-- 备注 -->
      <view class="form-group">
        <view class="form-label">备注（选填）</view>
        <input class="form-input remark-input" placeholder="如：十年期，2025年首次换证" value="{{form.remark}}" bindinput="onInputRemark" />
      </view>

      <!-- 按钮 -->
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="onCancelModal">取消</view>
        <view class="modal-btn confirm {{canSave ? '' : 'disabled'}}" bindtap="onConfirm">保存</view>
      </view>
    </view>
  </view>
</view>
