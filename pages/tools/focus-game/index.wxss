.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F4FF 0%, #E8ECFF 100%);
  padding-bottom: 60rpx;
}

/* 模式切换 */
.mode-scroll {
  background: #fff;
  white-space: nowrap;
  border-bottom: 1rpx solid #eee;
}
.mode-list {
  display: inline-flex;
  padding: 20rpx 16rpx;
  gap: 16rpx;
}
.mode-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  background: #F5F6FA;
  min-width: 100rpx;
}
.mode-item.active {
  background: linear-gradient(135deg, #6C63FF, #4ECDC4);
}
.mode-item.active .mode-name {
  color: #fff;
}
.mode-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
.mode-name {
  font-size: 22rpx;
  color: #666;
}

/* 信息条 */
.info-bar {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  padding: 24rpx 0 12rpx;
}
.info-item {
  text-align: center;
}
.info-label {
  font-size: 22rpx;
  color: #999;
  display: block;
}
.info-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}
.info-val.highlight {
  color: #6C63FF;
}

/* 难度选择 */
.diff-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 16rpx 30rpx;
}
.diff-item {
  padding: 10rpx 32rpx;
  border-radius: 20rpx;
  background: #fff;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #E0E0E0;
}
.diff-item.active {
  background: #6C63FF;
  color: #fff;
  border-color: #6C63FF;
}

/* 按钮 */
.btn-row {
  display: flex;
  justify-content: center;
  padding: 30rpx;
}
.btn-start {
  background: linear-gradient(135deg, #6C63FF, #4ECDC4);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 0 80rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.hint-text {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0 0;
}

/* ========== 舒尔特方格 ========== */
.schulte-grid {
  display: grid;
  gap: 8rpx;
  padding: 20rpx 30rpx;
}
.schulte-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
}
.schulte-cell:active {
  transform: scale(0.92);
}
.schulte-cell.done {
  background: #E8F5E9;
  color: #4CAF50;
  opacity: 0.6;
}
.schulte-cell.wrong {
  animation: shake 0.4s ease;
  background: #FFEBEE;
  color: #F44336;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

/* ========== 找不同 ========== */
.spot-area {
  padding: 20rpx 30rpx;
}
.spot-hint {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}
.spot-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}
.spot-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.2s;
  border: 4rpx solid transparent;
}
.spot-emoji-big {
  font-size: 72rpx;
}
.spot-cell.correct {
  border-color: #4CAF50;
  background: #E8F5E9;
  transform: scale(1.05);
}
.spot-cell.wrong {
  border-color: #F44336;
  background: #FFEBEE;
  animation: shake 0.4s ease;
}
.spot-cell.clicked {
  opacity: 0.7;
}

/* ========== 颜色干扰 ========== */
.stroop-area {
  padding: 40rpx 30rpx;
  text-align: center;
}
.stroop-question {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}
.stroop-word {
  font-size: 96rpx;
  font-weight: 900;
  margin-bottom: 50rpx;
  text-shadow: 2rpx 2rpx 8rpx rgba(0,0,0,0.1);
}
.stroop-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 20rpx;
}
.stroop-btn {
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 1rpx 1rpx 4rpx rgba(0,0,0,0.3);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.15);
}
.stroop-btn:active {
  transform: scale(0.95);
}

/* ========== 记忆翻牌 ========== */
.memory-grid {
  display: grid;
  gap: 12rpx;
  padding: 20rpx 30rpx;
}
.memory-card {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6C63FF, #4ECDC4);
  border-radius: 16rpx;
  font-size: 52rpx;
  box-shadow: 0 4rpx 12rpx rgba(108,99,255,0.2);
  transition: all 0.3s;
  border: 3rpx solid rgba(255,255,255,0.3);
}
.memory-card.flipped,
.memory-card.matched {
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  border-color: #E0E0E0;
}
.memory-card.matched {
  background: #E8F5E9;
  border-color: #4CAF50;
}
.memory-card:active {
  transform: scale(0.92);
}

/* 结果弹窗 */
.result-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.result-box {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 50rpx 40rpx;
  text-align: center;
}
.result-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}
.result-detail {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}
.btn-again {
  background: linear-gradient(135deg, #6C63FF, #4ECDC4);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
}
