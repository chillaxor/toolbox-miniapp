.error-box { padding: 16rpx 24rpx; background-color: #FFF0F0; border-radius: 12rpx; margin-bottom: 24rpx; }
.btn-group { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.btn-mode { flex: 1; text-align: center; padding: 20rpx 16rpx; border-radius: 44rpx; color: #FFFFFF; font-size: 26rpx; font-weight: 600; }
.btn-mode:active { opacity: 0.8; }
.btn-row { display: flex; justify-content: flex-end; }
.btn-small { padding: 12rpx 32rpx; background-color: var(--color-border); border-radius: 24rpx; font-size: 24rpx; color: var(--color-secondary); }
