<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">打地鼠</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 挑战信息栏 -->
  <view class="game-info" wx:if="{{state !== 'ready'}}">
    <view class="info-item">
      <text class="info-label">得分</text>
      <text class="info-value">{{score}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">时间</text>
      <text class="info-value {{timeLeft <= 5 ? 'time-warn' : ''}}">{{timeLeft}}s</text>
    </view>
    <view class="info-item">
      <text class="info-label">连击</text>
      <text class="info-value combo-value">{{combo}}</text>
    </view>
  </view>

  <!-- 准备阶段 -->
  <view wx:if="{{state === 'ready'}}">
    <view class="card">
      <text class="card-title">挑战时长</text>
      <view class="count-btns">
        <view class="count-btn {{duration === item ? 'count-active' : ''}}" wx:for="{{[15,30,60]}}" wx:key="*this" data-dur="{{item}}" bindtap="onDurationChange">{{item}}秒</view>
      </view>
    </view>
    <view class="card" style="margin-top:24rpx;text-align:center;">
      <text class="ready-emoji">🐹</text>
      <text class="ready-text">点击出现的地鼠得分，小心炸弹！</text>
      <text class="ready-text">连续命中获得连击加分</text>
    </view>
    <view class="best-info" wx:if="{{bestScore > 0}}">
      <text class="best-label">🏆 最高分</text>
      <text class="best-value">{{bestScore}}</text>
    </view>
    <button class="start-btn" bindtap="startGame">🔨 开始挑战</button>
  </view>

  <!-- 挑战网格 -->
  <view class="mole-grid" wx:if="{{state === 'playing'}}">
    <view class="mole-cell {{grid[idx] === 1 ? 'mole-up' : ''}} {{grid[idx] === 2 ? 'bomb-up' : ''}} {{hitAnim === idx ? 'hit-anim' : ''}}" wx:for="{{grid}}" wx:key="index" data-idx="{{idx}}" bindtap="onWhack">
      <text class="cell-emoji" wx:if="{{grid[idx] === 1}}">🐹</text>
      <text class="cell-emoji" wx:elif="{{grid[idx] === 2}}">💣</text>
      <text class="cell-emoji hole" wx:else>🕳️</text>
    </view>
  </view>

  <!-- 结束 -->
  <view wx:if="{{state === 'finished'}}">
    <view class="card result-card">
      <text class="result-emoji">🎯</text>
      <text class="result-title">挑战结束！</text>
      <text class="result-score">{{score}} 分</text>
      <view class="result-stats">
        <view class="stat-item">
          <text class="stat-value">{{maxCombo}}</text>
          <text class="stat-label">最大连击</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{bestScore}}</text>
          <text class="stat-label">历史最高</text>
        </view>
      </view>
      <view wx:if="{{score >= bestScore && score > 0}}" class="new-record">🎉 新纪录！</view>
      <button class="start-btn" bindtap="startGame" style="margin-top:32rpx;">🔄 再来一局</button>
    </view>
  </view>
</view>
