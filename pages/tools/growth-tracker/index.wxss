.container {
  padding: 20rpx 24rpx 40rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.tool-header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.tool-header-fav {
  font-size: 40rpx;
  padding: 10rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.card-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: #E74C3C;
  padding: 8rpx 16rpx;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-group.half {
  flex: 1;
}

.input-field {
  background: #F8F8F8;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-btn {
  background: #F8F8F8;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-btn.small {
  display: inline-block;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 10rpx;
  border: none;
}

/* Stats */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
}

.stat-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: -4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.bmi-tag {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  margin-top: 16rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

/* Chart */
.tab-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  padding: 12rpx 0;
  border-radius: 20rpx;
  background: #F5F5F5;
}

.tab-active {
  background: #4ECDC4;
  color: #fff;
  font-weight: bold;
}

.chart-canvas {
  width: 100%;
  height: 400rpx;
}

.chart-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.legend-line {
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.legend-line.normal {
  background: #E0E0E0;
}

.legend-line.actual {
  background: #4ECDC4;
}

.legend-text {
  font-size: 20rpx;
  color: #999;
  margin-right: 20rpx;
}

/* Standard ref */
.ref-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
  margin-top: -8rpx;
}

.ref-table {
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  overflow: hidden;
}

.ref-row {
  display: flex;
  border-bottom: 1rpx solid #F0F0F0;
}

.ref-row:last-child {
  border-bottom: none;
}

.ref-header {
  background: #F8F8F8;
}

.ref-cell {
  flex: 1;
  text-align: center;
  padding: 14rpx 8rpx;
  font-size: 24rpx;
  color: #333;
}

.ref-header .ref-cell {
  font-weight: bold;
  color: #666;
  font-size: 22rpx;
}

/* Records */
.record-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  flex: 1;
}

.record-date {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.record-detail {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.record-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.height-tag {
  background: #D8F5F3;
  color: #4ECDC4;
}

.weight-tag {
  background: #FFE5D9;
  color: #FF6B35;
}

.bmi-tag-sm {
  background: #EFD9F7;
  color: #9B59B6;
}

.record-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-change {
  display: flex;
  align-items: center;
}

.change-text {
  font-size: 24rpx;
  font-weight: bold;
}

.change-up {
  color: #27AE60;
}

.change-down {
  color: #E74C3C;
}

.delete-btn {
  font-size: 28rpx;
  color: #CCC;
  padding: 10rpx;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
}

/* Settings */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
}

.setting-btns {
  display: flex;
  gap: 16rpx;
}

.setting-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  color: #666;
}

.setting-active {
  background: #4ECDC4;
  color: #fff;
  font-weight: bold;
}
