.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #6a5acd, #8a6fd6);
  padding: 40rpx 32rpx 60rpx;
  box-sizing: border-box;
  position: relative;
  overflow-y: auto;
}

.fav {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  color: #fff;
  font-size: 28rpx;
  opacity: 0.92;
}

.hero {
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
  text-align: center;
  margin: 30rpx 0 20rpx;
}

.howto {
  background: rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  padding: 24rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.8;
}

.sec-label {
  color: #fff;
  font-size: 28rpx;
  margin: 36rpx 0 16rpx;
  font-weight: 600;
}

.chip-row {
  display: flex;
  gap: 20rpx;
}

.chip {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.chip-on {
  background: #fff;
  color: #6a5acd;
  font-weight: 700;
}

.switch-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.switch {
  width: 96rpx;
  height: 54rpx;
  border-radius: 27rpx;
  background: rgba(255, 255, 255, 0.25);
  position: relative;
  transition: .2s;
  flex-shrink: 0;
}

.switch-on {
  background: #7CFC9B;
}

.knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: #fff;
  transition: .2s;
}

.switch-on .knob {
  left: 46rpx;
}

.switch-tip {
  color: #fff;
  font-size: 26rpx;
}

.btn-primary {
  margin-top: 48rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: #fff;
  color: #6a5acd;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary.inline {
  margin-top: 0;
  flex: 1;
}

.tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 20rpx;
}

/* 游戏中 */
.progress {
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  margin: 20rpx 0 30rpx;
}

.card {
  background: #fff;
  border-radius: 28rpx;
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.2);
  transition: box-shadow .2s;
}

.word {
  font-size: 130rpx;
  font-weight: 800;
  color: #333;
  text-align: center;
  line-height: 1.15;
}

.card-correct {
  box-shadow: 0 0 0 8rpx #7CFC9B, 0 16rpx 40rpx rgba(0, 0, 0, 0.2);
}

.card-skip {
  box-shadow: 0 0 0 8rpx #FFB347, 0 16rpx 40rpx rgba(0, 0, 0, 0.2);
}

.stat-row {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin: 28rpx 0;
}

.stat {
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.btn-row {
  display: flex;
  gap: 24rpx;
  margin-top: 10rpx;
}

.btn-skip {
  flex: 1;
  height: 100rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-correct {
  flex: 1;
  height: 100rpx;
  border-radius: 50rpx;
  background: #7CFC9B;
  color: #1c5e34;
  font-weight: 800;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flip-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  margin-top: 24rpx;
}

/* 结果 */
.result-emoji {
  text-align: center;
  font-size: 100rpx;
  margin: 30rpx 0 10rpx;
}

.result-title {
  text-align: center;
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 30rpx;
}

.result-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.r-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 20rpx;
  padding: 30rpx 0;
  text-align: center;
  color: #fff;
  font-size: 26rpx;
}

.r-num {
  font-size: 56rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.btn-ghost {
  flex: 1;
  height: 92rpx;
  border-radius: 46rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ---------- 横屏适配：手机横过来，宽大、高小，压缩上下间距、放大词语 ---------- */
@media (orientation: landscape) {
  .page { padding: 20rpx 48rpx 30rpx; }

  .hero { font-size: 44rpx; margin: 12rpx 0; }
  .howto { font-size: 24rpx; padding: 18rpx 22rpx; line-height: 1.6; }
  .sec-label { margin: 18rpx 0 10rpx; }
  .btn-primary { margin-top: 24rpx; }

  .progress { font-size: 28rpx; margin: 10rpx 0 14rpx; }
  .card { min-height: 200rpx; padding: 28rpx 40rpx; }
  .word { font-size: 170rpx; }
  .stat-row { margin: 14rpx 0; gap: 80rpx; }
  .stat { font-size: 30rpx; }
  .btn-row { max-width: 72%; margin-left: auto; margin-right: auto; }
  .btn-skip, .btn-correct { height: 84rpx; }
  .flip-tip { margin-top: 14rpx; }

  .result-emoji { font-size: 80rpx; margin: 10rpx 0 6rpx; }
  .result-title { font-size: 34rpx; margin-bottom: 18rpx; }
}
