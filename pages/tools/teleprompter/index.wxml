<!-- 编辑模式 -->
<view class="container" wx:if="{{!fullscreen}}">
  <view class="tool-header">
    <text class="tool-header-title">📜 全屏提词器</text>
  </view>

  <!-- 文本输入 -->
  <view class="card">
    <view class="section-label">输入提词内容</view>
    <textarea
      class="text-area"
      placeholder="在这里粘贴或输入你的演讲稿、直播话术..."
      value="{{text}}"
      bindinput="onInput"
      maxlength="10000"
      auto-height
      show-confirm-bar="{{false}}"
    />
    <view class="char-count" wx:if="{{text}}">
      <text>{{text.length}} 字</text>
      <text class="clear-link" bindtap="onClearText">清空</text>
    </view>
  </view>

  <!-- 预设文本 -->
  <view class="card" wx:if="{{!text}}">
    <view class="section-label">快速开始</view>
    <view class="preset-list">
      <view class="preset-item" wx:for="{{presets}}" wx:key="label" data-index="{{index}}" bindtap="onSelectPreset">
        <text class="preset-label">{{item.label}}</text>
        <text class="preset-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 参数设置 -->
  <view class="card">
    <view class="section-label">播放设置</view>

    <view class="setting-row">
      <view class="setting-label">
        <text>滚动速度</text>
        <text class="setting-value">{{speedLabel}}</text>
      </view>
      <slider min="1" max="10" value="{{speed}}" step="1" bindchange="onSpeedChange" activeColor="#FF6B35" block-size="18" />
      <view class="speed-hints">
        <text>慢</text>
        <text>快</text>
      </view>
    </view>

    <view class="setting-row">
      <view class="setting-label">
        <text>字体大小</text>
        <text class="setting-value">{{fontSizeLabel}}rpx</text>
      </view>
      <slider min="36" max="96" value="{{fontSize}}" step="4" bindchange="onFontSizeChange" activeColor="#FF6B35" block-size="18" />
      <view class="speed-hints">
        <text>小</text>
        <text>大</text>
      </view>
    </view>

    <view class="setting-row mirror-row" bindtap="onMirrorToggle">
      <text class="mirror-label">镜像文字</text>
      <text class="mirror-desc">用于实体提词器玻璃反射</text>
      <view class="mirror-switch {{mirror ? 'on' : 'off'}}">
        <view class="mirror-knob"></view>
      </view>
    </view>
  </view>

  <!-- 开始按钮 -->
  <view class="play-btn-wrap">
    <view class="play-btn {{hasText ? '' : 'disabled'}}" bindtap="onPlay">
      <text class="play-btn-icon">▶</text>
      <text class="play-btn-text">开始提词</text>
    </view>
  </view>

  <!-- 提示 -->
  <view class="card tip-card">
    <text class="tip-title">💡 使用提示</text>
    <text class="tip-text">• 点击屏幕任意位置可暂停/继续</text>
    <text class="tip-text">• 提词内容会自动保存，下次打开可继续使用</text>
    <text class="tip-text">• 镜像模式适用于实体提词器的玻璃反射场景</text>
    <text class="tip-text">• 建议提前练习，找到适合自己的滚动速度</text>
  </view>
</view>

<!-- 全屏播放模式 -->
<view class="fullscreen-view" wx:if="{{fullscreen}}">
  <!-- 阅读引导线 -->
  <view class="guide-line"></view>

  <!-- 滚动文本 -->
  <scroll-view
    id="prompter-scroll"
    class="prompter-scroll"
    scroll-y
    scroll-top="{{scrollTop}}"
    enhanced
    show-scrollbar="{{false}}"
    bindtap="onTapScreen"
    style="{{mirror ? 'transform: scaleX(-1);' : ''}}"
  >
    <view class="scroll-padding-top"></view>
    <text class="prompter-text" style="font-size: {{fontSize}}rpx; line-height: {{lineHeight}};">{{text}}</text>
    <view class="scroll-padding-bottom"></view>
  </scroll-view>

  <!-- 顶部渐变遮罩 -->
  <view class="fade-top"></view>
  <!-- 底部渐变遮罩 -->
  <view class="fade-bottom"></view>

  <!-- 底部控制栏 -->
  <view class="control-bar">
    <view class="ctrl-btn" bindtap="onRestart">
      <text class="ctrl-icon">↺</text>
    </view>
    <view class="ctrl-btn ctrl-play" bindtap="onTogglePause">
      <text class="ctrl-icon-lg">{{playing ? '⏸' : '▶'}}</text>
    </view>
    <view class="ctrl-btn" bindtap="onStop">
      <text class="ctrl-icon">✕</text>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%;"></view>
  </view>
</view>
