<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">数学训练</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 计时和统计 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-label">用时</text>
      <text class="stat-value">{{formatTime(timer)}}</text>
    </view>
    <view class="stat-item">
      <text class="stat-label">最佳</text>
      <text class="stat-value">{{bestTime ? formatTime(bestTime) : '--'}}</text>
    </view>
    <view class="stat-item">
      <text class="stat-label">已解</text>
      <text class="stat-value">{{solvedCount}}</text>
    </view>
  </view>

  <!-- 数字卡片 -->
  <view class="number-cards">
    <view class="number-card {{selectedNums.indexOf(0) !== -1 ? 'card-selected' : ''}}" data-idx="0" bindtap="onNumberTap">
      <text class="card-face">{{cardFaces[0]}}</text>
      <text class="card-num">{{numbers[0]}}</text>
    </view>
    <view class="number-card {{selectedNums.indexOf(1) !== -1 ? 'card-selected' : ''}}" data-idx="1" bindtap="onNumberTap">
      <text class="card-face">{{cardFaces[1]}}</text>
      <text class="card-num">{{numbers[1]}}</text>
    </view>
    <view class="number-card {{selectedNums.indexOf(2) !== -1 ? 'card-selected' : ''}}" data-idx="2" bindtap="onNumberTap">
      <text class="card-face">{{cardFaces[2]}}</text>
      <text class="card-num">{{numbers[2]}}</text>
    </view>
    <view class="number-card {{selectedNums.indexOf(3) !== -1 ? 'card-selected' : ''}}" data-idx="3" bindtap="onNumberTap">
      <text class="card-face">{{cardFaces[3]}}</text>
      <text class="card-num">{{numbers[3]}}</text>
    </view>
  </view>

  <!-- 运算符 -->
  <view class="op-buttons">
    <view class="op-btn" data-op="+" bindtap="onOpTap">+</view>
    <view class="op-btn" data-op="-" bindtap="onOpTap">−</view>
    <view class="op-btn" data-op="×" bindtap="onOpTap">×</view>
    <view class="op-btn" data-op="÷" bindtap="onOpTap">÷</view>
  </view>

  <!-- 表达式显示 -->
  <view class="expr-box">
    <text class="expr-text">{{expression || '选择数字和运算符'}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="action-btns">
    <button class="btn-action btn-secondary" bindtap="onClearExpr">清空</button>
    <button class="btn-action btn-primary" bindtap="onHint">💡 提示</button>
    <button class="btn-action btn-accent" bindtap="onNewPuzzle">🔄 新题</button>
  </view>

  <!-- 提示弹窗 -->
  <view class="hint-overlay" wx:if="{{showHint}}" bindtap="onCloseHint">
    <view class="hint-card" catchtap="">
      <text class="hint-title">💡 参考答案</text>
      <text class="hint-content">{{hint}}</text>
      <text class="hint-close">点击关闭</text>
    </view>
  </view>
</view>