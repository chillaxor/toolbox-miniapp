.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #E74C3C;
}

.number-cards {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 32rpx 0;
}

.number-card {
  width: 140rpx;
  height: 180rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.card-selected {
  border-color: #E74C3C;
  background: #FDE8E8;
  transform: scale(1.05);
}

.card-face {
  font-size: 40rpx;
  font-weight: 700;
  color: #E74C3C;
}

.card-num {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.op-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 24rpx 0;
}

.op-btn {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  background: #F5F5F5;
  border-radius: 50%;
  color: #333;
}

.op-btn:active {
  background: #E74C3C;
  color: #fff;
}

.expr-box {
  margin: 24rpx 0;
  padding: 24rpx 32rpx;
  background: #F9F9F9;
  border-radius: 16rpx;
  text-align: center;
  min-height: 80rpx;
}

.expr-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
}

.btn-action {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-primary {
  background: #E74C3C;
  color: #fff;
}

.btn-secondary {
  background: #F0F0F0;
  color: #666;
}

.btn-accent {
  background: #FF6B35;
  color: #fff;
}

.hint-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.hint-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.hint-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.hint-content {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #E74C3C;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.hint-close {
  font-size: 24rpx;
  color: #999;
}