.category-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  overflow-x: auto;
  white-space: nowrap;
}

.cat-btn {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: #F5F5F5;
  color: #666;
  flex-shrink: 0;
}

.cat-active {
  background: #FDE8E8;
  color: #E74C3C;
  font-weight: 600;
}

.joke-card {
  margin: 24rpx 0;
  padding: 32rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
}

.joke-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  background: #FDE8E8;
  color: #E74C3C;
  margin-bottom: 20rpx;
}

.joke-content {
  display: block;
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
}

.joke-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.joke-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.fav-count {
  font-size: 22rpx;
  color: #999;
}

.btn-next {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #E74C3C;
  color: #fff;
  border: none;
  margin-top: 32rpx;
}