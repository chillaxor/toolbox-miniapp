<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">解压文案</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 分类标签 -->
  <view class="category-bar">
    <view class="cat-btn {{currentCategory === '' ? 'cat-active' : ''}}" data-cat="" bindtap="onCategoryTap">全部</view>
    <view class="cat-btn {{currentCategory === item ? 'cat-active' : ''}}"
          wx:for="{{categories}}" wx:key="*this"
          data-cat="{{item}}" bindtap="onCategoryTap">{{item}}</view>
  </view>

  <!-- 笑话卡片 -->
  <view class="joke-card">
    <view class="joke-tag">{{jokeCategory}}</view>
    <text class="joke-content">{{joke}}</text>
    <view class="joke-actions">
      <view class="joke-action" bindtap="onFavJoke">
        <text>{{isFavJoke ? '❤️' : '🤍'}}</text>
        <text class="action-text">{{isFavJoke ? '已收藏' : '收藏'}}</text>
      </view>
      <text class="fav-count">{{favCount}} 条收藏</text>
    </view>
  </view>

  <!-- 再来一条 -->
  <button class="btn-next" bindtap="onNextJoke">😂 再来一条</button>
</view>