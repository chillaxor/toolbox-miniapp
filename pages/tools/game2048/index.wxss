/* pages/tools/game2048/index.wxss */
.container {
  padding: 30rpx;
  background: #faf8ef;
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.logo {
  font-size: 72rpx;
  font-weight: 900;
  color: #776e65;
  letter-spacing: -4rpx;
}

.scores-row {
  display: flex;
  gap: 16rpx;
}

.score-box {
  background: #bbada0;
  border-radius: 12rpx;
  padding: 12rpx 28rpx;
  text-align: center;
  min-width: 120rpx;
}

.score-label {
  font-size: 22rpx;
  color: #eee4da;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.score-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 4rpx;
}

.controls {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ctrl-btn {
  flex: 1;
  text-align: center;
  background: #8f7a66;
  color: #f9f6f2;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 0;
  border-radius: 12rpx;
}

.ctrl-btn:active {
  opacity: 0.8;
}

.board {
  position: relative;
  background: #bbada0;
  border-radius: 16rpx;
  padding: 12rpx;
}

.grid-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.grid-row:last-child {
  margin-bottom: 0;
}

.grid-cell {
  flex: 1;
  aspect-ratio: 1;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-text {
  font-weight: 800;
  line-height: 1;
}

/* 覆盖层 */
.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(238, 228, 218, 0.85);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.overlay-title {
  font-size: 56rpx;
  font-weight: 900;
  color: #776e65;
  margin-bottom: 16rpx;
}

.overlay-score {
  font-size: 32rpx;
  color: #776e65;
  margin-bottom: 40rpx;
}

.overlay-btns {
  display: flex;
  gap: 20rpx;
}

.ov-btn {
  background: #8f7a66;
  color: #f9f6f2;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border-radius: 12rpx;
}

.ov-btn2 {
  background: #bbada0;
}

.tip {
  text-align: center;
  color: #776e65;
  font-size: 26rpx;
  margin-top: 30rpx;
  opacity: 0.7;
}
