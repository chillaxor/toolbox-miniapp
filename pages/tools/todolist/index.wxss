.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
}

/* 添加栏 */
.add-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.add-input {
  flex: 1;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 44rpx;
  padding: 0 36rpx;
  font-size: 30rpx;
  color: #333;
}

.add-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 300;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.filter-active {
  background: rgba(255, 255, 255, 0.95);
  color: #764ba2;
  font-weight: bold;
}

/* 待办列表 */
.todo-list {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 20rpx;
  min-height: 300rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 20rpx 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.todo-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.todo-checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-text {
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
}

.todo-done .todo-text {
  text-decoration: line-through;
  color: #bbb;
}

.todo-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 6rpx;
}

.todo-time {
  font-size: 22rpx;
  color: #bbb;
}

.todo-priority {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.priority-high { background: #ffebee; color: #f44336; }
.priority-medium { background: #fff8e1; color: #FF9800; }
.priority-low { background: #e8f5e9; color: #4CAF50; }

.todo-delete {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 28rpx;
  flex-shrink: 0;
}

.todo-empty {
  text-align: center;
  color: #bbb;
  padding: 80rpx 0;
  font-size: 28rpx;
}

/* 底部操作 */
.bottom-bar {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.btn-clear {
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
}

/* 统计 */
.stats-area {
  margin-top: 30rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
}

.stats-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.stats-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.stats-fill {
  height: 100%;
  background: #fff;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.stats-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  display: block;
  text-align: right;
}