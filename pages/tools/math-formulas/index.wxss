.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.tool-header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tool-header-fav {
  font-size: 44rpx;
  padding: 8rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 20rpx;
  display: block;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

.back-bar {
  margin-bottom: 20rpx;
}

.back-bar text {
  font-size: 28rpx;
  color: #E74C3C;
}

/* 搜索 */
.search-bar {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 30rpx;
  height: 72rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

.search-clear {
  font-size: 32rpx;
  color: #999;
  padding: 0 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
}

/* 年级段切换 */
.level-tabs {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.level-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.level-tab-active {
  background-color: #E74C3C;
}

.level-tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}

.level-tab-active .level-tab-text {
  color: #fff;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  width: calc(25% - 12rpx);
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background-color: #f8f8f8;
  text-align: center;
}

.category-item:active {
  background-color: #E74C3C;
}

.category-item:active .category-name {
  color: #fff;
}

.category-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
}

/* 公式列表 */
.formula-list {
  margin-top: 12rpx;
}

.formula-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.formula-item:last-child {
  border-bottom: none;
}

.formula-item-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.formula-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
}

.formula-item-cat {
  font-size: 22rpx;
  color: #999;
}

.formula-item-formula {
  font-size: 24rpx;
  color: #E74C3C;
  font-weight: 500;
  max-width: 320rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.view-more {
  text-align: center;
  padding: 24rpx 0;
}

.view-more text {
  font-size: 26rpx;
  color: #E74C3C;
  font-weight: 600;
}

/* 公式详情 */
.formula-detail-card {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.detail-header {
  text-align: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.08);
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1565C0;
  display: block;
  margin-bottom: 16rpx;
}

.detail-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.detail-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tag-level {
  background-color: #E74C3C;
  color: #fff;
}

.tag-cat {
  background-color: rgba(21, 101, 192, 0.15);
  color: #1565C0;
}

.formula-display {
  background-color: rgba(255,255,255,0.8);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
  border: 2rpx solid rgba(21, 101, 192, 0.2);
}

.formula-main {
  font-size: 36rpx;
  font-weight: 700;
  color: #1565C0;
  letter-spacing: 2rpx;
}

.detail-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0,0,0,0.08);
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12rpx;
  display: block;
}

.detail-section-text {
  font-size: 28rpx;
  color: #37474F;
  line-height: 1.8;
  display: block;
}

.example-box {
  background-color: rgba(255,255,255,0.6);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #E74C3C;
}

.example-text {
  font-size: 28rpx;
  color: #2C3E50;
  font-weight: 500;
  line-height: 1.6;
}

.detail-nav {
  margin-top: 24rpx;
}

.nav-btn {
  background-color: #E74C3C;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

.nav-btn::after {
  border: none;
}
