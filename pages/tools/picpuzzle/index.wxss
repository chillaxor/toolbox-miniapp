.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  box-sizing: border-box;
}

/* ========== 上传区 ========== */
.upload-area {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 580rpx;
  height: 580rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 4rpx dashed rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
}

.upload-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 拼图区 ========== */
.puzzle-area {
  padding-bottom: 40rpx;
}

/* 信息栏 */
.info-bar {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.tap-link {
  text-decoration: underline;
  font-size: 28rpx;
  font-weight: normal;
}

/* 难度选择 */
.level-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.level-chip {
  padding: 12rpx 36rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.level-active {
  background: #fff;
  color: #764ba2;
  font-weight: bold;
  border-color: #fff;
}

/* 完成提示 */
.complete-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.complete-emoji {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.complete-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

/* ========== 拼图网格 ========== */
.puzzle-grid {
  display: grid;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 30rpx;
}

.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

.grid-5 {
  grid-template-columns: repeat(5, 1fr);
}

.puzzle-cell {
  position: relative;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.15);
  transition: transform 0.15s, box-shadow 0.15s;
}

.puzzle-cell:active {
  transform: scale(0.95);
}

.cell-selected {
  box-shadow: 0 0 0 4rpx #FFD700, 0 0 20rpx rgba(255, 215, 0, 0.5);
  transform: scale(1.03);
  z-index: 1;
}

.cell-done {
  box-shadow: 0 0 0 3rpx rgba(76, 175, 80, 0.6);
}

.piece-img {
  width: 100%;
  height: 100%;
}

.piece-num {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: bold;
}

.pos-badge {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: rgba(255, 255, 255, 0.7);
  font-size: 18rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* ========== 操作栏 ========== */
.toolbar {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
  margin: 0;
}

.btn::after {
  border: none;
}

.btn-outline {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

/* ========== 加载 ========== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 30rpx;
  padding: 60rpx 80rpx;
}

.loading-spin {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #fff;
}
