<view class="page">
  <!-- 未选图状态 -->
  <view class="upload-area" wx:if="{{!imagePath}}">
    <view class="upload-btn" bindtap="onChooseImage">
      <text class="upload-icon">🧩</text>
      <text class="upload-text">选择图片开始拼图</text>
      <text class="upload-hint">选一张照片，切块打乱，拖动还原</text>
    </view>
  </view>

  <!-- 已选图状态 -->
  <view class="puzzle-area" wx:if="{{imagePath}}">
    <!-- 信息栏 -->
    <view class="info-bar">
      <view class="info-item">
        <text class="info-label">步数</text>
        <text class="info-value">{{moves}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">用时</text>
        <text class="info-value">{{timerStr}}</text>
      </view>
      <view class="info-item" bindtap="onPreview">
        <text class="info-label">原图</text>
        <text class="info-value tap-link">查看</text>
      </view>
    </view>

    <!-- 难度选择 -->
    <view class="level-bar">
      <view
        wx:for="{{levels}}"
        wx:key="*this"
        class="level-chip {{level === item ? 'level-active' : ''}}"
        data-level="{{item}}"
        bindtap="onLevelChange"
      >{{item}}×{{item}}</view>
    </view>

    <!-- 完成提示 -->
    <view class="complete-banner" wx:if="{{isComplete}}">
      <text class="complete-emoji">🎉</text>
      <text class="complete-text">拼图完成！共 {{moves}} 步，用时 {{timerStr}}</text>
    </view>

    <!-- 拼图网格 -->
    <view class="puzzle-grid grid-{{level}}">
      <view
        wx:for="{{grid}}"
        wx:key="index"
        class="puzzle-cell {{selected === index ? 'cell-selected' : ''}} {{isComplete ? 'cell-done' : ''}}"
        data-pos="{{index}}"
        bindtap="onTapPiece"
      >
        <image
          class="piece-img"
          wx:if="{{pieces[item] && pieces[item].path}}"
          src="{{pieces[item].path}}"
          mode="aspectFill"
        />
        <view class="piece-num" wx:else>{{item + 1}}</view>
        <!-- 正确位置小标记 -->
        <view class="pos-badge" wx:if="{{!isComplete}}">{{index + 1}}</view>
      </view>
    </view>

    <!-- 操作栏 -->
    <view class="toolbar">
      <button class="btn btn-outline" bindtap="onChooseImage">🔄 换图</button>
      <button class="btn btn-outline" bindtap="onReset">🔀 重新打乱</button>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-overlay" wx:if="{{isProcessing}}">
    <view class="loading-box">
      <text class="loading-spin">⏳</text>
      <text class="loading-text">正在生成拼图...</text>
    </view>
  </view>

  <!-- 隐藏 canvas -->
  <canvas canvas-id="picpuzzle-piece" style="position:fixed;left:-9999px;width:250px;height:250px;"></canvas>
</view>
