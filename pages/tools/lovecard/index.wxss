/* pages/tools/lovecard/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
  position: relative;
}

/* 收藏按钮 */
.fav-btn {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  z-index: 10;
}

/* 预览区域 */
.preview-area {
  padding: 30rpx;
  display: flex;
  justify-content: center;
}

.card-preview {
  width: 650rpx;
  min-height: 500rpx;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
}

/* 卡片背景 - 通过渐变模拟 */
.tpl-bg-pink {
  background: linear-gradient(135deg, #ff9a9e, #fecfef);
}
.tpl-bg-purple {
  background: linear-gradient(135deg, #667eea, #764ba2);
}
.tpl-bg-sunset {
  background: linear-gradient(135deg, #fa709a, #fee140);
}
.tpl-bg-ocean {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}
.tpl-bg-forest {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}
.tpl-bg-dark {
  background: linear-gradient(135deg, #0f0c29, #302b63);
}
.tpl-bg-warm {
  background: linear-gradient(135deg, #f6d365, #fda085);
}
.tpl-bg-paper {
  background: linear-gradient(135deg, #faf8f3, #f5f0e8);
}

.card-quote-mark {
  font-size: 120rpx;
  color: rgba(255, 255, 255, 0.18);
  font-family: Georgia, serif;
  line-height: 1;
  margin-bottom: -30rpx;
  position: absolute;
  top: 30rpx;
  left: 30rpx;
}

.card-text {
  flex: 1;
  display: flex;
  align-items: center;
  text-align: center;
  color: #fff;
  font-size: 36rpx;
  line-height: 1.8;
  font-weight: 500;
  letter-spacing: 4rpx;
  word-break: break-all;
  padding: 40rpx 0;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tpl-bg-warm .card-text,
.tpl-bg-paper .card-text {
  color: #5d4037;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.tpl-bg-warm .card-footer,
.tpl-bg-paper .card-footer {
  border-top-color: rgba(93, 64, 55, 0.15);
}

.card-category {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tpl-bg-warm .card-category,
.tpl-bg-paper .card-category {
  color: rgba(93, 64, 55, 0.5);
}

.card-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.tpl-bg-warm .card-date,
.tpl-bg-paper .card-date {
  color: rgba(93, 64, 55, 0.4);
}

/* 区块 */
.section {
  padding: 0 30rpx;
  margin-bottom: 28rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.optional-tag {
  font-weight: 400;
  color: #999;
  font-size: 24rpx;
}

/* 模板选择 */
.tpl-scroll,
.cat-scroll {
  white-space: nowrap;
}

.tpl-list,
.cat-list {
  display: flex;
  gap: 20rpx;
  padding: 8rpx 0;
}

.tpl-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.tpl-dot {
  width: 88rpx;
  height: 64rpx;
  border-radius: 14rpx;
  border: 3rpx solid transparent;
}

.tpl-item.active .tpl-dot {
  border-color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.tpl-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.tpl-item.active .tpl-name {
  color: #333;
  font-weight: 600;
}

/* 分类选择 */
.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 100rpx;
  padding: 16rpx 0;
  border-radius: 16rpx;
  background: #fff;
  border: 3rpx solid transparent;
}

.cat-item.active {
  border-color: #ff6b9d;
  background: #fff0f5;
}

.cat-icon {
  font-size: 40rpx;
}

.cat-name {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
}

.cat-item.active .cat-name {
  color: #ff6b9d;
  font-weight: 600;
}

/* 操作按钮组 */
.action-row {
  display: flex;
  gap: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 28rpx;
}

.mini-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: #fff !important;
  color: #333 !important;
  border-radius: 36rpx;
  border: 2rpx solid #e0e0e0;
  padding: 0;
}

.mini-btn::after {
  border: none;
}

/* 自定义输入 */
.custom-input {
  width: 100%;
  min-height: 100rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.use-custom-btn {
  margin-top: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background: #ff6b9d !important;
  color: #fff !important;
  border-radius: 36rpx;
  border: none;
}

.use-custom-btn::after {
  border: none;
}

/* 收藏列表 */
.collected-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.collected-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #ff6b9d;
}

.collected-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* 保存按钮 */
.btn-row {
  padding: 10rpx 30rpx 40rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #ff6b9d, #ff9a9e) !important;
  color: #fff !important;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.3);
}

.save-btn::after {
  border: none;
}

/* 隐藏画布 */
.offscreen-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 540px;
  height: 720px;
}
