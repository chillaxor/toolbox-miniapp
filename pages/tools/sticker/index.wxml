<view class="container">
  <view class="tool-header">
    <text class="tool-header-title">表情包制作</text>
    <text class="tool-header-fav" bindtap="toggleFavorite">{{isFavorite ? '❤️' : '🤍'}}</text>
  </view>

  <!-- 画布预览区 -->
  <view class="canvas-wrapper">
    <canvas canvas-id="stickerCanvas" class="sticker-canvas" style="width:{{canvasW}}px;height:{{canvasH}}px;" disable-scroll></canvas>
    <view class="canvas-placeholder" wx:if="{{!bgImage}}">
      <text class="placeholder-icon">🖼️</text>
      <text class="placeholder-text">点击下方按钮选择底图</text>
    </view>
  </view>

  <!-- 文字编辑区 -->
  <view class="card" wx:if="{{bgImage}}">
    <view class="section-title">
      <text class="section-icon">✏️</text>
      <text>添加文字</text>
    </view>

    <view class="form-group">
      <input class="input-field" placeholder="输入文字内容" value="{{textInput}}" bindinput="onTextInput" maxlength="30" />
    </view>

    <!-- 文字样式 -->
    <view class="style-row">
      <view class="style-group">
        <text class="style-label">字号</text>
        <view class="size-options">
          <view class="size-item {{fontSize === item ? 'size-active' : ''}}" wx:for="{{fontSizeOptions}}" wx:key="*this" data-size="{{item}}" bindtap="onFontSizeSelect">
            <text>{{item}}</text>
          </view>
        </view>
      </view>

      <view class="style-group">
        <text class="style-label">颜色</text>
        <view class="color-options">
          <view class="color-opt {{textColor === item ? 'color-active' : ''}}" wx:for="{{textColors}}" wx:key="*this" data-color="{{item}}" bindtap="onTextColorSelect">
            <view class="color-swatch" style="background-color: {{item}};"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 文字位置 -->
    <view class="style-group mt-sm">
      <text class="style-label">位置</text>
      <view class="pos-options">
        <view class="pos-item {{textPos === item.id ? 'pos-active' : ''}}" wx:for="{{posOptions}}" wx:key="id" data-pos="{{item.id}}" bindtap="onTextPosSelect">
          <text>{{item.icon}}</text>
          <text class="pos-label">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="btn-row">
      <button class="btn-primary" style="background-color: #9B59B6; flex:1;" bindtap="onAddText">添加文字到画布</button>
    </view>
  </view>

  <!-- 表情贴纸 -->
  <view class="card" wx:if="{{bgImage}}">
    <view class="section-title">
      <text class="section-icon">😀</text>
      <text>表情贴纸</text>
    </view>

    <view class="emoji-grid">
      <view class="emoji-item {{selectedEmoji === item ? 'emoji-active' : ''}}" wx:for="{{emojiList}}" wx:key="*this" data-emoji="{{item}}" bindtap="onEmojiSelect">
        <text class="emoji-text">{{item}}</text>
      </view>
    </view>

    <view class="style-group mt-sm">
      <text class="style-label">表情大小</text>
      <view class="size-options">
        <view class="size-item {{emojiSize === item ? 'size-active' : ''}}" wx:for="{{emojiSizeOptions}}" wx:key="*this" data-size="{{item}}" bindtap="onEmojiSizeSelect">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="style-group mt-sm">
      <text class="style-label">表情位置</text>
      <view class="pos-options">
        <view class="pos-item {{emojiPos === item.id ? 'pos-active' : ''}}" wx:for="{{emojiPosOptions}}" wx:key="id" data-pos="{{item.id}}" bindtap="onEmojiPosSelect">
          <text>{{item.icon}}</text>
          <text class="pos-label">{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="btn-row">
      <button class="btn-primary" style="background-color: #9B59B6; flex:1;" bindtap="onAddEmoji">添加表情到画布</button>
    </view>
  </view>

  <!-- 底图选择 -->
  <view class="card">
    <view class="section-title">
      <text class="section-icon">📷</text>
      <text>选择底图</text>
    </view>
    <view class="bg-options">
      <view class="bg-btn" bindtap="onChooseImage">
        <text class="bg-btn-icon">🖼️</text>
        <text class="bg-btn-label">从相册选择</text>
      </view>
      <view class="bg-btn" bindtap="onCameraCapture">
        <text class="bg-btn-icon">📸</text>
        <text class="bg-btn-label">拍照</text>
      </view>
    </view>

    <!-- 纯色底图 -->
    <view class="section-title mt-md">
      <text class="section-icon">🎨</text>
      <text>纯色底图</text>
    </view>
    <view class="pure-bg-options">
      <view class="pure-bg-item" wx:for="{{pureBgColors}}" wx:key="*this" data-color="{{item}}" bindtap="onPureBgSelect">
        <view class="pure-bg-preview" style="background-color: {{item}};"></view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section" wx:if="{{bgImage}}">
    <button class="btn-secondary" bindtap="onClearCanvas">🗑️ 清空重做</button>
    <button class="btn-primary" style="background-color: #9B59B6;" bindtap="onSaveSticker">💾 保存表情包</button>
  </view>

  <!-- 历史记录 -->
  <view class="card" wx:if="{{historyList.length > 0}}">
    <view class="section-title">
      <text class="section-icon">🕐</text>
      <text>本次会话记录</text>
    </view>
    <view class="history-grid">
      <image class="history-thumb" wx:for="{{historyList}}" wx:key="index" src="{{item}}" mode="aspectFill"></image>
    </view>
  </view>
</view>
