.canvas-wrapper {
  position: relative;
  background: #f0f0f0;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
}

.sticker-canvas {
  display: block;
}

.canvas-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
}

/* 样式选择行 */
.style-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.style-group {
  margin-bottom: 8rpx;
}

.style-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

/* 字号选项 */
.size-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.size-item {
  min-width: 72rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.size-active {
  background: #EFD9F7;
  color: #9B59B6;
  border-color: #9B59B6;
  font-weight: bold;
}

/* 颜色选项 */
.color-options {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.color-opt {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 3rpx solid transparent;
}

.color-opt .color-swatch {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.15);
}

.color-active {
  border-color: #9B59B6;
  background: #F5EEF8;
}

/* 位置选项 */
.pos-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.pos-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.pos-active {
  background: #EFD9F7;
  color: #9B59B6;
  border-color: #9B59B6;
}

.pos-label {
  font-size: 24rpx;
}

/* 表情网格 */
.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.emoji-item {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #f8f8f8;
  border: 2rpx solid transparent;
}

.emoji-active {
  background: #EFD9F7;
  border-color: #9B59B6;
  transform: scale(1.1);
}

.emoji-text {
  font-size: 40rpx;
}

/* 底图选择 */
.bg-options {
  display: flex;
  gap: 20rpx;
}

.bg-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 30rpx 0;
  border-radius: 16rpx;
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
}

.bg-btn-icon {
  font-size: 48rpx;
}

.bg-btn-label {
  font-size: 24rpx;
  color: #666;
}

/* 纯色底图 */
.pure-bg-options {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.pure-bg-item {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #e0e0e0;
}

.pure-bg-preview {
  width: 100%;
  height: 100%;
}

/* 操作按钮区 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.btn-row {
  margin-top: 20rpx;
}

/* 历史记录 */
.history-grid {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.history-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
}
