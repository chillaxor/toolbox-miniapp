.card-title {
  font-size: 28rpx;
  color: var(--color-secondary);
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.age-big {
  text-align: center;
  padding: 16rpx 0;
}

.age-num {
  font-size: 120rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1;
}

.age-unit {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-secondary);
  margin-left: 8rpx;
}

.age-sub {
  display: block;
  font-size: 28rpx;
  color: var(--color-hint);
  margin-top: 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0;
}

.info-card {
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  font-size: 48rpx;
}

.info-label {
  font-size: 24rpx;
  color: var(--color-hint);
}

.info-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}
