page {
  background: #f5f5f5;
  overflow: hidden;
}

.container {
  position: relative;
  width: 100vw;
  height: 100vh;
}

/* 尺子铺满整个屏幕 */
.ruler {
  display: block;
  width: 100%;
  height: 100%;
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  left: 10px;
  width: 36px;
  height: 36px;
  background: rgba(0,0,0,0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.back-icon {
  color: #fff;
  font-size: 18px;
  line-height: 1;
}

/* 悬浮操作面板 */
.float-panel {
  position: fixed;
  right: 10px;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.float-toggle {
  width: 36px;
  height: 36px;
  background: rgba(0,0,0,0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.toggle-icon {
  color: #fff;
  font-size: 12px;
}

.float-body {
  background: rgba(255,255,255,0.92);
  border-radius: 12px;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  backdrop-filter: blur(10px);
  transition: opacity 0.2s, transform 0.2s;
}

.float-body.hide {
  opacity: 0;
  transform: scale(0.8);
  pointer-events: none;
  height: 0;
  padding: 0;
  overflow: hidden;
}

.float-body.show {
  opacity: 1;
  transform: scale(1);
}

.float-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.fbtn {
  min-width: 36px;
  height: 36px;
  line-height: 36px;
  text-align: center;
  background: rgba(0,0,0,0.08);
  border-radius: 8px;
  font-size: 14px;
  color: #555;
  padding: 0 8px;
  box-sizing: border-box;
}

.fbtn.active {
  background: #8D6E63;
  color: #fff;
}

.cal-text {
  font-size: 14px;
  color: #333;
  font-weight: bold;
  min-width: 44px;
  text-align: center;
}
