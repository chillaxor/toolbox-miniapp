page {
  background: #f8f6f0;
  overflow: hidden;
}

.ruler-page {
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* ========== 竖屏布局 ========== */
.ruler-page.portrait {
  display: flex;
  flex-direction: row;
}

.ruler-body.vertical {
  position: relative;
  width: 200rpx;
  height: 100vh;
  flex-shrink: 0;
  background: linear-gradient(90deg, #FFF9E6 0%, #FFF3D0 100%);
  border-right: 4rpx solid #C9B87A;
  box-shadow: 4rpx 0 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.zero-line.vertical {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: #3E2723;
}

/* ========== 横屏布局 ========== */
.ruler-page.landscape {
  display: flex;
  flex-direction: column;
}

.ruler-body.horizontal {
  position: relative;
  width: 100vw;
  height: 200rpx;
  flex-shrink: 0;
  background: linear-gradient(0deg, #FFF9E6 0%, #FFF3D0 100%);
  border-top: 4rpx solid #C9B87A;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  order: 2;
  overflow: hidden;
}

.zero-line.horizontal {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: #3E2723;
}

/* ========== 刻度线 ========== */
.tick {
  position: absolute;
  display: flex;
  z-index: 2;
}

/* 竖屏刻度：水平线条，从左往右 */
.tick.vertical {
  left: 0;
  height: 1px;
  align-items: center;
  flex-direction: row;
}

.tick.vertical.tick-major {
  height: 2px;
  background: #3E2723;
}

.tick.vertical.tick-minor {
  background: #8D7B5A;
}

/* 横屏刻度：垂直线条，从上往下 */
.tick.horizontal {
  top: 0;
  width: 1px;
  align-items: center;
  flex-direction: column;
}

.tick.horizontal.tick-major {
  width: 2px;
  background: #3E2723;
}

.tick.horizontal.tick-minor {
  background: #8D7B5A;
}

/* 刻度数字标签 */
.tick-label {
  font-size: 20rpx;
  color: #3E2723;
  font-weight: 700;
  white-space: nowrap;
  font-family: 'DIN Alternate', 'Helvetica Neue', monospace;
}

.tick-label:not(.horizontal) {
  margin-left: 6rpx;
}

.tick-label.horizontal {
  margin-top: 4rpx;
}

/* ========== 右侧信息区（竖屏） ========== */
.info-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.info-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  width: 100%;
  max-width: 400rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3E2723;
  display: block;
  margin-bottom: 16rpx;
}

.info-device {
  font-size: 22rpx;
  color: #4CAF50;
  display: block;
  margin-bottom: 8rpx;
}

.info-range {
  font-size: 26rpx;
  color: #8D7B5A;
  display: block;
  margin-bottom: 20rpx;
}

.info-divider {
  height: 1rpx;
  background: #EDE8D8;
  margin: 16rpx 0;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #8D7B5A;
}

.unit-toggle {
  display: flex;
  background: #F0EAD8;
  border-radius: 30rpx;
  padding: 4rpx;
}

.unit-toggle.compact {
  border-radius: 20rpx;
  padding: 2rpx;
}

.unit-btn {
  padding: 8rpx 24rpx;
  border-radius: 26rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
  transition: all 0.2s;
}

.unit-btn.compact {
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  border-radius: 18rpx;
}

.unit-btn.active {
  background: #5C4033;
  color: #fff;
  font-weight: 600;
}

.info-tip {
  font-size: 20rpx;
  color: #aaa;
  display: block;
  line-height: 1.8;
}

/* ========== 横屏信息条 ========== */
.info-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #EDE8D8;
  order: 1;
}

.info-bar-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3E2723;
}

.info-bar-device {
  font-size: 20rpx;
  color: #4CAF50;
}

/* ========== 浮动设置按钮 ========== */
.fab {
  position: fixed;
  top: 40rpx;
  right: 24rpx;
  z-index: 100;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(92, 64, 51, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.25);
}

.fab:active {
  opacity: 0.8;
  transform: scale(0.95);
}
