page {
  background: #f8f6f0;
  overflow: hidden;
}

.ruler-page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
}

.ruler-page.portrait {
  display: flex;
  flex-direction: row;
}

.ruler-page.landscape {
  display: flex;
  flex-direction: column;
}

/* ===== 尺子刻度 ===== */
.ruler-strip {
  position: relative;
  overflow: hidden;
}

.ruler-strip.vertical {
  width: 220rpx;
  height: 100vh;
  background: linear-gradient(90deg, #FFF9E6 0%, #FFF5D6 100%);
  border-right: 3rpx solid #C9B87A;
  flex-shrink: 0;
}

.ruler-strip.horizontal {
  width: 100vw;
  height: 220rpx;
  background: linear-gradient(0deg, #FFF9E6 0%, #FFF5D6 100%);
  border-top: 3rpx solid #C9B87A;
  order: 2;
}

/* 零点线 */
.ruler-zero-line {
  position: absolute;
  background: #5C4033;
  z-index: 5;
}
.ruler-zero-line.vertical { bottom: 0; left: 0; right: 0; height: 4rpx; }
.ruler-zero-line.horizontal { left: 0; top: 0; bottom: 0; width: 4rpx; }

/* 刻度行 */
.mark-row { position: absolute; display: flex; z-index: 2; }
.mark-row.vertical { left: 0; flex-direction: row; align-items: center; height: 2rpx; }
.mark-row.horizontal { top: 0; flex-direction: column; align-items: center; width: 2rpx; }

.mark-bar { flex-shrink: 0; }
.mark-bar.vertical { height: 3rpx; }
.mark-bar.vertical.mark-major { height: 5rpx; background: #5C4033; }
.mark-bar.vertical.mark-minor { background: #A0926B; }
.mark-bar.horizontal { width: 3rpx; }
.mark-bar.horizontal.mark-major { width: 5rpx; background: #5C4033; }
.mark-bar.horizontal.mark-minor { background: #A0926B; }

.mark-label { font-size: 20rpx; color: #5C4033; font-weight: 700; white-space: nowrap; }
.mark-label.vertical { margin-left: 8rpx; }
.mark-label.horizontal { margin-top: 6rpx; }

/* ===== 浮动按钮 ===== */
.float-btn {
  position: fixed;
  right: 16rpx;
  z-index: 100;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(92, 64, 51, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
.float-btn:active { opacity: 0.8; }

/* ===== 浮动面板 ===== */
.float-panel {
  position: fixed;
  right: 16rpx;
  z-index: 99;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  width: 340rpx;
}

.float-panel.landscape {
  width: auto;
  min-width: 480rpx;
  max-width: 80vw;
  padding: 16rpx 20rpx;
}

.fp-device {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 20rpx;
  color: #2e7d32;
  margin-bottom: 12rpx;
}

.fp-auto {
  font-size: 18rpx;
  color: #fff;
  background: #4caf50;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  margin-left: 8rpx;
}

.fp-unit {
  display: flex;
  background: #f0ead8;
  border-radius: 24rpx;
  padding: 3rpx;
  margin-bottom: 10rpx;
}

.fp-unit.small { margin-bottom: 0; }

.fp-tag {
  flex: 1;
  text-align: center;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.fp-tag.small {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
}

.fp-tag.on {
  background: #8B7355;
  color: #fff;
  font-weight: 600;
}

.fp-range {
  font-size: 22rpx;
  color: #8B7355;
  margin-bottom: 12rpx;
  display: block;
}

.fp-range.small {
  margin-bottom: 0;
  font-size: 20rpx;
}

.fp-cal {
  margin-bottom: 12rpx;
}

.fp-cal-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 2rpx;
}

.fp-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.fp-row:last-child { margin-bottom: 0; }

.fp-row .fp-cal-label {
  margin-bottom: 0;
  white-space: nowrap;
}

.fp-row slider {
  flex: 1;
}

.fp-device-text {
  font-size: 18rpx;
  color: #2e7d32;
  flex: 1;
}

.fp-tip {
  font-size: 20rpx;
  color: #999;
  display: block;
  line-height: 1.8;
}
