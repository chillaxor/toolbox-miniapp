<!-- 竖屏：尺子在左侧，从底部(0)向上 -->
<view class="ruler-page portrait" wx:if="{{!isLandscape}}">
  <view class="ruler-body vertical">
    <view class="zero-line vertical"></view>
    <view
      wx:for="{{marks}}"
      wx:key="pos"
      class="tick vertical {{item.major ? 'tick-major' : 'tick-minor'}}"
      style="bottom: {{item.pos}}px; width: {{item.len}}rpx;"
    >
      <text class="tick-label" wx:if="{{item.label !== ''}}">{{item.label}}</text>
    </view>
  </view>

  <!-- 右侧信息区 -->
  <view class="info-area">
    <view class="info-card">
      <text class="info-title">📏 虚拟尺子</text>
      <text class="info-device" wx:if="{{deviceInfo}}">{{deviceInfo}}</text>
      <text class="info-range">可测 ≈ {{maxDisplay}} {{unit === 'cm' ? 'cm' : 'in'}}</text>

      <view class="info-divider"></view>

      <view class="info-row">
        <text class="info-label">单位</text>
        <view class="unit-toggle" bindtap="switchUnit">
          <text class="unit-btn {{unit === 'cm' ? 'active' : ''}}">cm</text>
          <text class="unit-btn {{unit === 'inch' ? 'active' : ''}}">in</text>
        </view>
      </view>

      <view class="info-row">
        <text class="info-label">微调校准</text>
      </view>
      <slider
        min="0" max="4000" value="2000" step="1"
        bindchanging="onCalibrate"
        block-size="16"
        activeColor="#5C4033"
        style="margin: 8rpx 0 20rpx;"
      />

      <text class="info-tip">💡 将尺子左下角对齐物体起点</text>
      <text class="info-tip">🔄 旋转手机可测更长距离</text>
    </view>
  </view>
</view>

<!-- 横屏：尺子在底部，从左侧(0)向右 -->
<view class="ruler-page landscape" wx:if="{{isLandscape}}">
  <view class="ruler-body horizontal">
    <view class="zero-line horizontal"></view>
    <view
      wx:for="{{marks}}"
      wx:key="pos"
      class="tick horizontal {{item.major ? 'tick-major' : 'tick-minor'}}"
      style="left: {{item.pos}}px; height: {{item.len}}rpx;"
    >
      <text class="tick-label horizontal" wx:if="{{item.label !== ''}}">{{item.label}}</text>
    </view>
  </view>

  <!-- 顶部信息条 -->
  <view class="info-bar">
    <text class="info-bar-title">📏 {{maxDisplay}}{{unit === 'cm' ? 'cm' : 'in'}}</text>
    <text class="info-bar-device" wx:if="{{deviceInfo}}">{{deviceInfo}}</text>
    <view class="unit-toggle compact" bindtap="switchUnit">
      <text class="unit-btn compact {{unit === 'cm' ? 'active' : ''}}">cm</text>
      <text class="unit-btn compact {{unit === 'inch' ? 'active' : ''}}">in</text>
    </view>
  </view>
</view>

<!-- 浮动设置按钮 -->
<view class="fab" bindtap="toggleCtrl">
  <text>{{showCtrl ? '✕' : '⚙'}}</text>
</view>
