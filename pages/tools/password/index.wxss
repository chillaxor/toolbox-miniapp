.password-display {
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  word-break: break-all;
}

.password-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
}

.password-actions {
  display: flex;
  gap: 16rpx;
}

.btn-action {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-action::after {
  border: none;
}

.btn-refresh {
  background: #F5F5F5;
  color: var(--color-primary);
}

.btn-copy {
  background: var(--color-text);
  color: #fff;
}

.btn-copy.copied {
  background: var(--color-success);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  color: var(--color-secondary);
  font-weight: 600;
}

.length-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-hint);
}

.option-list {
  margin-top: 16rpx;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.option-item:last-child {
  border-bottom: none;
}

.option-label {
  font-size: 30rpx;
  color: var(--color-primary);
}

.option-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}

.option-check.checked {
  background: var(--color-text);
  border-color: var(--color-text);
  color: #fff;
}
