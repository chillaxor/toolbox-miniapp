/* pages/tools/countdown2/index.wxss */

/* ========== 编辑模式 ========== */

.time-input-card {
  padding: 40rpx 32rpx;
}

.time-inputs {
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-input-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-input {
  width: 140rpx;
  height: 120rpx;
  text-align: center;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
  background-color: var(--color-bg);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  line-height: 120rpx;
}

.time-input:focus {
  border-color: var(--color-life);
}

.time-input-label {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-hint);
}

.time-colon {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-hint);
  margin: 0 16rpx;
  margin-bottom: 40rpx;
}

/* 预设标签 */
.section-label {
  font-size: 28rpx;
  color: var(--color-secondary);
  margin-bottom: 24rpx;
  display: block;
}

/* 预设按钮网格 */
.preset-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.preset-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  background-color: var(--color-bg);
  border: 2rpx solid var(--color-border);
  font-size: 26rpx;
  color: var(--color-secondary);
  transition: all 0.2s ease;
}

.preset-btn:active {
  transform: scale(0.95);
}

.preset-btn-active {
  background-color: rgba(255, 107, 53, 0.12);
  border-color: var(--color-life);
  color: var(--color-life);
  font-weight: 600;
}

/* 开始按钮 */
.start-btn-wrapper {
  margin-top: 48rpx;
  padding: 0 24rpx;
}

.start-btn {
  background: linear-gradient(135deg, #FF6B35, #FF8F5E);
  height: 96rpx;
  font-size: 34rpx;
  letter-spacing: 4rpx;
}

/* ========== 倒计时全屏模式 ========== */

.countdown-fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #111111;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 时间到脉冲背景 */
.timeup-pulse-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0;
}

.timeup-pulse-bg.active {
  animation: pulseBg 1.5s ease-in-out infinite;
}

@keyframes pulseBg {
  0% {
    opacity: 0;
    background-color: rgba(231, 76, 60, 0);
  }
  50% {
    opacity: 1;
    background-color: rgba(231, 76, 60, 0.15);
  }
  100% {
    opacity: 0;
    background-color: rgba(231, 76, 60, 0);
  }
}

/* 圆环 + 时间居中容器 */
.timer-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.canvas-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-canvas {
  display: block;
}

/* 时间文字叠加 */
.time-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.time-display {
  font-size: 120rpx;
  font-weight: 200;
  color: #FFFFFF;
  font-family: 'Courier New', 'SF Mono', 'Menlo', monospace;
  letter-spacing: 6rpx;
}

/* MM:SS 短格式 - 更大字体 */
.time-display-short {
  font-size: 200rpx;
  font-weight: 200;
  color: #FFFFFF;
  font-family: 'Courier New', 'SF Mono', 'Menlo', monospace;
  letter-spacing: 8rpx;
}

.time-display-alert {
  color: #E74C3C;
  animation: timePulse 0.8s ease-in-out infinite;
}

@keyframes timePulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.05);
  }
}

.time-status {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
}

.time-status-running {
  color: rgba(78, 205, 196, 0.7);
}

.time-status-done {
  color: #E74C3C;
  font-weight: 600;
  animation: timePulse 0.8s ease-in-out infinite;
}

/* ========== 底部浮动控制栏 ========== */

.control-bar {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
  padding: 24rpx 48rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
}

.control-btn:active {
  opacity: 0.6;
  transform: scale(0.92);
}

.control-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  line-height: 1;
}

.control-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.control-btn-pause .control-icon {
  color: #4ECDC4;
}

.control-btn-reset .control-icon {
  color: rgba(255, 255, 255, 0.7);
}

.control-btn-back .control-icon {
  color: rgba(255, 255, 255, 0.5);
  font-size: 36rpx;
}
