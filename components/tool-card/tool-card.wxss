.tool-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 38, 89, 0.07);
  transition: all 0.2s ease;
}

.tool-card-hover {
  transform: scale(0.97);
  opacity: 0.95;
}

.tool-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tool-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tool-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2a2e3d;
  line-height: 1.4;
}

.tool-card-desc {
  font-size: 23rpx;
  color: #9aa0ad;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-card-arrow {
  font-size: 36rpx;
  color: #c8ccd6;
  margin-left: 12rpx;
  flex-shrink: 0;
}
